---
import type { PickedEntity } from "@engine/solver";
import { protocolLabel, hubLabel } from "./labels";

interface Props {
  pick: PickedEntity;
  vertical: string;
  userEcosystem: string;
  idx?: number;
}

const ECOSYSTEMS = [
  { id: "homekit", short: "homekit", name: "Apple HomeKit" },
  { id: "alexa", short: "alexa", name: "Amazon Alexa" },
  { id: "google_home", short: "google", name: "Google Home" },
  { id: "home_assistant", short: "home-asst", name: "Home Assistant" },
];

const { pick, vertical, userEcosystem, idx = 0 } = Astro.props;
const { entity, hub_required, native_in_ecosystem } = pick;
const sku = entity.sku ?? entity.id;
const affiliateHref = `/go/${vertical}/${sku}`;
const detailHref = `/${vertical}/devices/${sku}/`;
const attrs = entity.attributes;

const ecosystems = (attrs.ecosystems ?? []) as string[];
const ecosystemsUnsupported = (attrs.ecosystems_unsupported ?? []) as string[];
const ecosystemsViaBridge: string[] = [];
for (const k of Object.keys(attrs)) {
  if (k.startsWith("ecosystems_via_")) {
    for (const e of (attrs[k] as string[]) ?? []) {
      if (!ecosystemsViaBridge.includes(e)) ecosystemsViaBridge.push(e);
    }
  }
}

function ecoStatus(ecoId: string): "native" | "bridge" | "no" {
  if (ecosystemsUnsupported.includes(ecoId)) return "no";
  if (!ecosystems.includes(ecoId)) return "no";
  // If the ecosystem support comes only via a bridge attribute, mark as bridge.
  if (ecosystemsViaBridge.includes(ecoId) && !nativeProtocolFor(ecoId)) return "bridge";
  return "native";
}
function nativeProtocolFor(ecoId: string): boolean {
  // Heuristic: if the protocol is thread_matter / matter_over_wifi or the device
  // has a vendor-direct path (no `requires_hub` other than thread/matter_controller),
  // treat as native; otherwise the only path is via the brand bridge → "bridge".
  const proto = (attrs.protocol ?? "") as string;
  if (proto === "thread_matter" || proto === "matter_over_wifi" || proto === "wifi_2_4ghz" || proto === "wifi") {
    return true;
  }
  // Zigbee / BLE / proprietary RF require a hub — except Home Assistant which has
  // first-class support via Zigbee2MQTT / ZHA / direct integrations
  if (ecoId === "home_assistant") return true;
  return false;
}

const priceUsd = attrs.price_usd;
const priceLabel = typeof priceUsd === "number" ? `$${priceUsd}` : null;
const protoText = attrs.protocol ? protocolLabel(attrs.protocol as string) : "";
const hubText = hubLabel(hub_required);

// Build the small stats grid: protocol + hub + up to 3 spec rows pulled from
// well-known optional attribute keys
const specRows: [string, string][] = [];
for (const [k, niceK] of [
  ["lumens", "lumens"],
  ["color", "color"],
  ["base", "base"],
  ["max_load_watts", "max load"],
  ["form_factor", "form"],
  ["power", "power"],
  ["indoor_outdoor", "use"],
  ["measures", "measures"],
] as [string, string][]) {
  const v = attrs[k];
  if (v == null) continue;
  if (Array.isArray(v)) specRows.push([niceK, v.join(", ")]);
  else specRows.push([niceK, String(v)]);
  if (specRows.length >= 3) break;
}

const pinNum = String(idx + 1).padStart(2, "0");
---
<article class={`pcard${attrs.featured ? " featured" : ""}`}>
  <div class="topline">
    <span class="left">
      <span class="mono pid">{entity.id}</span>
      {native_in_ecosystem ? (
        <span class="badge-native">native</span>
      ) : (
        <span class="badge-bridge">via bridge</span>
      )}
    </span>
    <span class="pin">#{pinNum}</span>
  </div>
  <h4 class="title"><a href={detailHref}>{entity.name}</a></h4>
  <div class="submodel">
    {attrs.brand && <span>{attrs.brand}</span>}
    {attrs.brand && attrs.model && <span class="sep">·</span>}
    {attrs.model && <span>{attrs.model}</span>}
    {attrs.protocol && <span class="sep">·</span>}
    {attrs.protocol && <span>{protoText}</span>}
  </div>

  <div class="compat-strip" aria-label="Ecosystem compatibility">
    {ECOSYSTEMS.map((e) => {
      const s = ecoStatus(e.id);
      const cls = `compat-cell s-${s}${e.id === userEcosystem ? " s-active" : ""}`;
      return (
        <span class={cls} title={`${e.name}: ${s === "native" ? "native" : s === "bridge" ? "via bridge" : "no path"}`}>
          <span class="dot"></span>
          <span class="lbl">{e.short}</span>
        </span>
      );
    })}
  </div>

  <dl class="stats">
    <div class="stat">
      <dt class="k">protocol</dt>
      <dd class="v">{protoText || "—"}</dd>
    </div>
    <div class="stat">
      <dt class="k">hub</dt>
      <dd class={`v${hub_required === "none" ? " ok" : " warn"}`}>{hubText}</dd>
    </div>
    {specRows.map(([k, v]) => (
      <div class="stat">
        <dt class="k">{k}</dt>
        <dd class="v">{v}</dd>
      </div>
    ))}
  </dl>

  {attrs.note && <p class="why">{attrs.note}</p>}

  <div class="pcard-foot">
    <span class="price">
      {priceLabel ?? <span class="nope">price not tracked</span>}
    </span>
    <a class="cta" href={affiliateHref} rel="sponsored nofollow noopener" target="_blank">
      find on retailer <span class="arr">→</span>
    </a>
  </div>
</article>
<style is:global>
  .pcard {
    background: var(--paper-0);
    border: 1px solid var(--paper-edge);
    border-radius: 10px;
    padding: var(--card-pad);
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color .12s, box-shadow .12s, transform .12s;
  }
  .pcard:hover {
    border-color: var(--ink-4);
    box-shadow: 0 6px 20px oklch(0.20 0.02 250 / 0.06);
  }
  .pcard.featured {
    border: 1px solid var(--ink-1);
    box-shadow: inset 0 0 0 1px var(--ink-1);
  }
  .topline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ink-2);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .topline .left { display: flex; align-items: center; gap: 8px; }
  .topline .pid { color: var(--ink-3); }
  .badge-native, .badge-bridge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 2px 9px;
    border-radius: 99px;
    font-weight: 600;
    font-size: 11.5px;
  }
  .badge-native { background: var(--ok-soft); color: var(--ok-dark); }
  .badge-native::before {
    content: "";
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ok);
  }
  .badge-bridge { background: var(--warn-soft); color: var(--warn-dark); }
  .badge-bridge::before {
    content: "";
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--warn);
  }
  .pin { font-family: var(--mono); font-weight: 600; color: var(--ink-3); }
  .title {
    font-size: 15.5px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.012em;
    text-wrap: balance;
    margin: 0;
  }
  .title a {
    color: inherit;
    text-decoration: none;
  }
  .title a:hover {
    text-decoration: underline;
    text-decoration-color: var(--ink-3);
    text-underline-offset: 3px;
  }
  .submodel {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-3);
    margin-top: -4px;
  }
  .submodel .sep { color: var(--ink-4); margin: 0 4px; }

  .compat-strip {
    display: flex;
    font-family: var(--mono);
    font-size: 11.5px;
    background: var(--paper-1);
    border: 1px solid var(--paper-edge);
    border-radius: 6px;
    overflow: hidden;
  }
  .compat-cell {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 6px 4px;
    line-height: 1.1;
    gap: 3px;
    border-left: 1px solid var(--paper-edge);
    text-align: center;
  }
  .compat-cell:first-child { border-left: 0; }
  .compat-cell .lbl { font-size: 11px; color: var(--ink-3); }
  .compat-cell .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--ink-4);
    opacity: 0.5;
  }
  .compat-cell.s-native { background: var(--ok-soft); }
  .compat-cell.s-native .lbl { color: var(--ok-dark); font-weight: 600; }
  .compat-cell.s-native .dot { background: var(--ok); opacity: 0.95; }
  .compat-cell.s-bridge { background: var(--warn-soft); }
  .compat-cell.s-bridge .lbl { color: var(--warn-dark); font-weight: 600; }
  .compat-cell.s-bridge .dot { background: var(--warn); opacity: 0.9; }
  .compat-cell.s-no .lbl { color: var(--ink-4); text-decoration: line-through; }
  .compat-cell.s-active { box-shadow: inset 0 -2px 0 var(--ink-0); }

  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--paper-edge);
    border: 1px solid var(--paper-edge);
    border-radius: 6px;
    overflow: hidden;
    margin: 0;
  }
  .stat {
    background: var(--paper-1);
    padding: 7px 10px;
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .stat .k {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-2);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
    margin: 0;
  }
  .stat .v {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ink-1);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin: 0;
  }
  .stat .v.ok { color: var(--ok); }
  .stat .v.warn { color: var(--warn); }

  .why {
    font-size: 13.5px;
    color: var(--ink-2);
    line-height: 1.5;
    text-wrap: pretty;
    margin: 0;
  }
  .pcard-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: auto;
  }
  .pcard-foot .price {
    font-family: var(--mono);
    font-size: 14.5px;
    font-weight: 600;
    color: var(--ink-0);
  }
  .pcard-foot .price .nope {
    color: var(--ink-4);
    font-weight: 500;
    font-size: 12.5px;
  }
  .pcard-foot .cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 14px;
    border-radius: 6px;
    background: var(--ink-0);
    color: var(--paper-0);
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
  }
  .pcard-foot .cta:hover { background: var(--ink-1); }
  .pcard-foot .cta .arr { transition: transform .15s; display: inline-block; }
  .pcard-foot .cta:hover .arr { transform: translateX(2px); }
</style>
