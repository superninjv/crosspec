---
import ProductCard from "./ProductCard.astro";
import ReasoningChain from "./ReasoningChain.astro";
import type { Solution } from "@engine/solver";

interface Props {
  vertical: string;
  headline: string;
  subheadline: string;
  examples: string[];
  solution: Solution;
}

const { vertical, headline, subheadline, examples, solution } = Astro.props;
const motionPicks = solution.picks.filter((p) => p.entity.type === "motion_sensor");
const bulbPicks = solution.picks.filter((p) => p.entity.type === "smart_bulb");
const plugPicks = solution.picks.filter((p) => p.entity.type === "smart_plug");
const lockPicks = solution.picks.filter((p) => p.entity.type === "smart_lock");
---
<section class="hero">
  <h1>{headline}</h1>
  <p class="sub">{subheadline}</p>
</section>

<form id="configurator-form" class="config-form" data-vertical={vertical}>
  <fieldset>
    <legend>Which ecosystem are you on?</legend>
    <label><input type="radio" name="ecosystem" value="homekit" checked /> HomeKit (Apple)</label>
    <label><input type="radio" name="ecosystem" value="alexa" /> Alexa (Amazon)</label>
    <label><input type="radio" name="ecosystem" value="google_home" /> Google Home</label>
    <label><input type="radio" name="ecosystem" value="home_assistant" /> Home Assistant</label>
  </fieldset>

  <fieldset>
    <legend>What do you want to add?</legend>
    <label><input type="checkbox" name="wants" value="smart_bulb" checked /> Smart bulb</label>
    <label><input type="checkbox" name="wants" value="motion_sensor" checked /> Motion sensor</label>
    <label><input type="checkbox" name="wants" value="smart_plug" /> Smart plug</label>
    <label><input type="checkbox" name="wants" value="smart_lock" /> Smart lock</label>
  </fieldset>

  <div class="examples">
    <span class="examples-label">Try an example:</span>
    {examples.map((q) => (
      <button type="button" class="chip" data-example={q}>{q}</button>
    ))}
  </div>

  <div class="share">
    <button type="button" id="copy-link" class="copy-btn">
      <span class="copy-label">Copy link to this config</span>
    </button>
    <span id="copy-status" class="copy-status" role="status" aria-live="polite"></span>
  </div>
</form>

<section id="result" class="result">
  <h2>
    Ecosystem: <code>{solution.inputs.ecosystem}</code> &middot; wants: <code>{solution.inputs.wants.join(", ")}</code>
  </h2>

  {solution.warnings.length > 0 && (
    <div class="warnings">
      <strong>Heads up:</strong>
      <ul>{solution.warnings.map((w) => <li>{w}</li>)}</ul>
    </div>
  )}

  {bulbPicks.length > 0 && (
    <>
      <h3>Smart bulbs</h3>
      <div class="grid">
        {bulbPicks.map((p) => <ProductCard pick={p} vertical={vertical} />)}
      </div>
    </>
  )}

  {plugPicks.length > 0 && (
    <>
      <h3>Smart plugs</h3>
      <div class="grid">
        {plugPicks.map((p) => <ProductCard pick={p} vertical={vertical} />)}
      </div>
    </>
  )}

  {lockPicks.length > 0 && (
    <>
      <h3>Smart locks</h3>
      <div class="grid">
        {lockPicks.map((p) => <ProductCard pick={p} vertical={vertical} />)}
      </div>
    </>
  )}

  {motionPicks.length > 0 && (
    <>
      <h3>Motion sensors</h3>
      <div class="grid">
        {motionPicks.map((p) => <ProductCard pick={p} vertical={vertical} />)}
      </div>
    </>
  )}

  <p class="hub-summary">
    Hubs needed across this selection:
    <strong>
      {solution.hubs_required.length > 0
        ? solution.hubs_required.join(", ")
        : "none"}
    </strong>
  </p>

  <ReasoningChain steps={solution.reasoning_chain} />
</section>

<script>
  import { solve } from "@engine/solver";
  import type { KnowledgeBase, UserInputs } from "@engine/solver";
  import kbRaw from "@verticals/smart-home/kb.json";
  import {
    matchExample,
    renderSolutionHTML,
    encodeInputs,
    decodeInputs,
  } from "@engine/ui/render";

  const kb = kbRaw as KnowledgeBase;
  const form = document.getElementById("configurator-form") as HTMLFormElement | null;
  const result = document.getElementById("result");
  if (form && result) {
    const vertical = form.dataset.vertical ?? "smart-home";

    function readForm(): UserInputs {
      const data = new FormData(form!);
      const ecosystem = (data.get("ecosystem") as string) ?? "homekit";
      const wants = data.getAll("wants") as string[];
      return { ecosystem, wants, picks_per_type: 3 };
    }

    function populateForm(inputs: UserInputs) {
      for (const input of form!.querySelectorAll<HTMLInputElement>(
        'input[name="ecosystem"]',
      )) {
        input.checked = input.value === inputs.ecosystem;
      }
      for (const input of form!.querySelectorAll<HTMLInputElement>(
        'input[name="wants"]',
      )) {
        input.checked = inputs.wants.includes(input.value);
      }
    }

    function render(inputs: UserInputs) {
      const [solution] = solve(kb, inputs);
      result!.innerHTML = renderSolutionHTML(solution, vertical);
    }

    function syncHash(inputs: UserInputs) {
      const next = "#" + encodeInputs(inputs);
      if (location.hash !== next) {
        history.replaceState(null, "", next);
      }
    }

    function onFormChange() {
      const inputs = readForm();
      render(inputs);
      syncHash(inputs);
    }

    const fromHash = decodeInputs(location.hash);
    if (fromHash) {
      populateForm(fromHash);
      render(fromHash);
    }

    form.addEventListener("change", onFormChange);

    window.addEventListener("hashchange", () => {
      const inputs = decodeInputs(location.hash);
      if (inputs) {
        populateForm(inputs);
        render(inputs);
      }
    });

    document
      .querySelectorAll<HTMLButtonElement>(".chip[data-example]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const match = matchExample(btn.dataset.example ?? "");
          if (!match) return;
          populateForm(match);
          render(match);
          syncHash(match);
        });
      });

    const copyBtn = document.getElementById("copy-link") as HTMLButtonElement | null;
    const copyStatus = document.getElementById("copy-status");
    if (copyBtn && copyStatus) {
      copyBtn.addEventListener("click", async () => {
        syncHash(readForm());
        const url = location.href;
        try {
          await navigator.clipboard.writeText(url);
          copyStatus.textContent = "Link copied";
        } catch {
          copyStatus.textContent = url;
        }
        setTimeout(() => {
          if (copyStatus.textContent === "Link copied") copyStatus.textContent = "";
        }, 2000);
      });
    }
  }
</script>

<style>
  .hero h1 { font-size: 1.85rem; line-height: 1.2; margin: 0 0 0.5rem; }
  .hero .sub { color: var(--muted); margin: 0 0 1.25rem; }

  .config-form {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .config-form fieldset {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: center;
  }
  .config-form legend {
    font-weight: 600;
    font-size: 0.85rem;
    margin-right: 0.5rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .config-form label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .config-form input[type="radio"],
  .config-form input[type="checkbox"] { accent-color: var(--accent); }

  .examples {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }
  .examples-label {
    font-size: 0.8rem;
    color: var(--muted);
    margin-right: 0.25rem;
  }
  .chip {
    background: white;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font: inherit;
    font-size: 0.8rem;
    color: var(--fg);
    cursor: pointer;
    transition: background 0.1s ease, border-color 0.1s ease;
  }
  .chip:hover {
    background: #f4f2ea;
    border-color: var(--accent);
  }
  .chip:active { transform: translateY(1px); }

  .share {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.25rem;
  }
  .copy-btn {
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0.4rem 0.85rem;
    font: inherit;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .copy-btn:hover { filter: brightness(1.08); }
  .copy-btn:active { transform: translateY(1px); }
  .copy-status {
    font-size: 0.82rem;
    color: var(--muted);
    min-height: 1em;
  }

  .result h2 { font-size: 1.05rem; margin: 1.5rem 0 0.5rem; }
  .result h2 code {
    background: #efece2;
    padding: 0.05rem 0.35rem;
    border-radius: 4px;
    font-size: 0.85rem;
  }
  .result h3 { margin: 1.25rem 0 0.5rem; font-size: 1rem; }
  .grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .warnings {
    background: #fff8e0;
    border: 1px solid #f0d97a;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .warnings ul { margin: 0.25rem 0 0 1rem; padding: 0; }
  .hub-summary { margin-top: 1rem; font-size: 0.9rem; }
  .empty {
    background: #fff8e0;
    border: 1px solid #f0d97a;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
  }
</style>
