---
import ProductCard from "./ProductCard.astro";
import ReasoningChain from "./ReasoningChain.astro";
import type { Solution } from "@engine/solver";
import { hubLabel, ecosystemLabel } from "./labels";

interface Props {
  vertical: string;
  headline: string;
  subheadline: string;
  examples: string[];
  solution: Solution;
}

const { vertical, headline, subheadline, examples, solution } = Astro.props;

const ECOSYSTEMS = [
  { id: "homekit", name: "Apple HomeKit", controllers: "HomePod / Apple TV 4K" },
  { id: "google_home", name: "Google Home", controllers: "Nest Hub / Nest Mini" },
  { id: "alexa", name: "Amazon Alexa", controllers: "Echo / Echo Hub" },
  { id: "home_assistant", name: "Home Assistant", controllers: "any HA instance" },
];

const DEVICE_TYPES = [
  { id: "smart_bulb", label: "Smart bulb" },
  { id: "smart_plug", label: "Smart plug" },
  { id: "motion_sensor", label: "Motion sensor" },
  { id: "contact_sensor", label: "Door / window" },
  { id: "smart_switch", label: "Switch / dimmer" },
  { id: "smart_lock", label: "Smart lock" },
  { id: "thermostat", label: "Thermostat" },
  { id: "leak_sensor", label: "Water leak" },
  { id: "temperature_sensor", label: "Temp / humidity" },
  { id: "smart_shade", label: "Motorized shade" },
  { id: "camera", label: "Security camera" },
  { id: "doorbell", label: "Video doorbell" },
];

const PRESETS = [
  {
    id: "matter_first_apartment",
    label: "Matter-first apartment starter",
    tag: "new build",
    eco: "homekit",
    wants: ["smart_bulb", "smart_plug", "motion_sensor"],
  },
  {
    id: "home_assistant_zigbee",
    label: "Home Assistant + Zigbee maximalist",
    tag: "power user",
    eco: "home_assistant",
    wants: ["motion_sensor", "contact_sensor", "temperature_sensor"],
  },
  {
    id: "alexa_renter",
    label: "Alexa renter, no rewiring",
    tag: "renter-friendly",
    eco: "alexa",
    wants: ["smart_bulb", "smart_plug", "leak_sensor"],
  },
  {
    id: "google_home_security",
    label: "Google Home, entry security",
    tag: "safety pack",
    eco: "google_home",
    wants: ["smart_lock", "contact_sensor", "motion_sensor"],
  },
];

// Group picks by type for SSR rendering
const motionPicks = solution.picks.filter((p) => p.entity.type === "motion_sensor");
const bulbPicks = solution.picks.filter((p) => p.entity.type === "smart_bulb");
const plugPicks = solution.picks.filter((p) => p.entity.type === "smart_plug");
const lockPicks = solution.picks.filter((p) => p.entity.type === "smart_lock");
const tempPicks = solution.picks.filter((p) => p.entity.type === "temperature_sensor");
const contactPicks = solution.picks.filter((p) => p.entity.type === "contact_sensor");
const switchPicks = solution.picks.filter((p) => p.entity.type === "smart_switch");
const leakPicks = solution.picks.filter((p) => p.entity.type === "leak_sensor");
const thermostatPicks = solution.picks.filter((p) => p.entity.type === "thermostat");
const shadePicks = solution.picks.filter((p) => p.entity.type === "smart_shade");
const cameraPicks = solution.picks.filter((p) => p.entity.type === "camera");
const doorbellPicks = solution.picks.filter((p) => p.entity.type === "doorbell");
const hubPicks = solution.picks.filter((p) => p.entity.type === "hub");

const sections: { type: string; label: string; picks: typeof solution.picks }[] = [
  { type: "hub", label: "Hubs & controllers", picks: hubPicks },
  { type: "smart_bulb", label: "Smart bulbs", picks: bulbPicks },
  { type: "smart_plug", label: "Smart plugs", picks: plugPicks },
  { type: "smart_lock", label: "Smart locks", picks: lockPicks },
  { type: "motion_sensor", label: "Motion sensors", picks: motionPicks },
  { type: "temperature_sensor", label: "Temperature & humidity", picks: tempPicks },
  { type: "contact_sensor", label: "Door & window sensors", picks: contactPicks },
  { type: "smart_switch", label: "Smart switches & dimmers", picks: switchPicks },
  { type: "leak_sensor", label: "Water leak sensors", picks: leakPicks },
  { type: "thermostat", label: "Thermostats", picks: thermostatPicks },
  { type: "smart_shade", label: "Smart shades & blinds", picks: shadePicks },
  { type: "camera", label: "Security cameras", picks: cameraPicks },
  { type: "doorbell", label: "Video doorbells", picks: doorbellPicks },
];

const totalPicks = solution.picks.length;
const totalPriceRaw = solution.picks.reduce(
  (a, p) => a + (typeof p.entity.attributes.price_usd === "number" ? p.entity.attributes.price_usd : 0),
  0,
);
const totalPrice = Math.round(totalPriceRaw);
const nativeCount = solution.picks.filter((p) => p.native_in_ecosystem).length;
const ecoObj = ECOSYSTEMS.find((e) => e.id === solution.inputs.ecosystem);
const today = new Date().toISOString().slice(0, 10);
---
<section class="hero">
  <div class="hero-inner">
    <span class="h-eyebrow"><span class="pip"></span> {vertical} v0.1</span>
    <h1 class="h-title">
      Compose a smart-home setup that <em>actually works together</em>.
    </h1>
    <p class="h-sub">{subheadline}</p>

    <form id="configurator-form" class="config-card" data-vertical={vertical}>
      <div class="config-tabs" id="config-tabs">
        <div class="config-tab" data-tab="eco">
          <span class="n">1</span> ecosystem
        </div>
        <div class="config-tab" data-tab="wants">
          <span class="n">2</span> devices
        </div>
        <div class="config-tab" data-tab="solve">
          <span class="n">→</span> solve
        </div>
      </div>

      <div class="config-body">
        <fieldset class="cfg-step">
          <legend class="sr-only">Ecosystem</legend>
          <h3><span class="ord">1</span> Which ecosystem?</h3>
          <p class="hint">The voice / app you'll use day-to-day. Determines which devices show up.</p>
          <div class="eco-grid" role="radiogroup" aria-label="Ecosystem">
            {ECOSYSTEMS.map((e) => (
              <label class="eco-pick">
                <input type="radio" name="ecosystem" value={e.id} checked={e.id === "homekit"} />
                <span class="eco-pick-body">
                  <span class="name">{e.name}</span>
                  <span class="sub">{e.controllers}</span>
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <fieldset class="cfg-step">
          <legend class="sr-only">Device types</legend>
          <h3><span class="ord">2</span> What do you want to add?</h3>
          <p class="hint">Tap any combination. Counts show how many compatible devices we have.</p>
          <div class="want-grid">
            {DEVICE_TYPES.map((t) => (
              <label class="want-chip">
                <input type="checkbox" name="wants" value={t.id} checked={t.id === "smart_bulb" || t.id === "motion_sensor"} />
                <span class="want-chip-body">
                  <span class="check">✓</span>
                  <span class="lbl">{t.label}</span>
                  <span class="ct" data-want-count={t.id}>—</span>
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <div class="cfg-solve">
          <span class="solve-label">live preview</span>
          <div class="solve-stats">
            <div class="solve-stat">
              <span class="k">picks</span>
              <span class="v" id="stat-picks">{totalPicks || "—"}</span>
            </div>
            <div class="solve-stat">
              <span class="k">device types</span>
              <span class="v" id="stat-types">{solution.inputs.wants.length || "—"}</span>
            </div>
            <div class="solve-stat">
              <span class="k">hubs needed</span>
              <span class={`v${solution.hubs_required.length === 0 && totalPicks > 0 ? " ok" : ""}`} id="stat-hubs">
                {totalPicks === 0 ? "—" : (solution.hubs_required.length || "0")}
              </span>
            </div>
            <div class="solve-stat">
              <span class="k">ecosystem</span>
              <span class="v small" id="stat-eco">{ecoObj?.name ?? "—"}</span>
            </div>
          </div>
          <button type="button" class="btn-solve" id="btn-solve">
            <span id="btn-solve-text">show {totalPicks} compatible picks</span>
            <span class="arr">↓</span>
          </button>
        </div>
      </div>
    </form>
  </div>

  <div class="presets-row">
    <span class="presets-label">or jump in:</span>
    {PRESETS.map((p) => (
      <button
        type="button"
        class="preset-chip"
        data-preset-eco={p.eco}
        data-preset-wants={p.wants.join(",")}
      >
        <span>{p.label}</span>
        <span class="tag">{p.tag}</span>
      </button>
    ))}
  </div>

  <div class="share">
    <span>shareable URL</span>
    <span class="hash" id="share-hash">#</span>
    <button type="button" class="copy" id="copy-link">copy link</button>
    <span id="copy-status" class="copy-status" role="status" aria-live="polite"></span>
  </div>

  <div class="examples">
    <span class="examples-label">try an example:</span>
    {examples.map((q) => (
      <button type="button" class="chip" data-example={q}>{q}</button>
    ))}
  </div>
</section>

<section id="result" class="results" aria-live="polite">
  {totalPicks > 0 ? (
    <>
      <header class="results-head">
        <h2>
          <span class="num">{totalPicks}</span> picks for{" "}
          <span class="qb">{ecoObj?.name ?? solution.inputs.ecosystem}</span>, ranked by native compatibility, Matter support, and price.
        </h2>
        <span class="stamp">solved · {today}</span>
      </header>

      <div class="meta-strip">
        <div class="cell">
          <span class="k">ecosystem</span>
          <span class="v">{ecoObj?.name ?? solution.inputs.ecosystem}</span>
        </div>
        <div class="cell">
          <span class="k">native picks</span>
          <span class={`v${nativeCount === totalPicks ? " ok" : ""}`}>{nativeCount}/{totalPicks}</span>
        </div>
        <div class="cell">
          <span class="k">hubs</span>
          <span class={`v${solution.hubs_required.length === 0 ? " ok" : " warn"}`}>
            {solution.hubs_required.length || "none"}
          </span>
        </div>
        <div class="cell">
          <span class="k">est. parts cost</span>
          <span class="v">{totalPrice > 0 ? `$${totalPrice}` : "—"}</span>
        </div>
        <div class="cell">
          <span class="k">price freshness</span>
          <span class="v">2026-05-05</span>
        </div>
      </div>

      <div class="hub-callout">
        <span class="lbl">hubs you'll need</span>
        <div class="hubs">
          {solution.hubs_required.length === 0 ? (
            <span class="hub-chip none">none required. Every pick works without an extra hub.</span>
          ) : (
            solution.hubs_required.map((h) => <span class="hub-chip">{hubLabel(h)}</span>)
          )}
        </div>
        <div class="total">
          <span>picks shown</span>
          <span class="v">{totalPicks}</span>
        </div>
      </div>

      {totalPicks > 0 && (
        <div class="build-summary" id="build-summary">
          <div class="bs-totals">
            <span class="bs-label">build total</span>
            <span class="bs-amount" id="bs-amount">$0</span>
            <span class="bs-meta">tick the products you want, then add to cart</span>
          </div>
          <a
            class="bs-cart disabled"
            id="bs-cart"
            href={`/go/${vertical}/cart?skus=`}
            rel="sponsored nofollow noopener"
            target="_blank"
          >
            <span class="bs-cart-glyph" aria-hidden="true">▣</span>
            <span>Add to Amazon cart</span>
            <span class="bs-cart-arr" aria-hidden="true">→</span>
          </a>
        </div>
      )}

      {solution.warnings.length > 0 && (
        <div class="warnings">
          <strong>Heads up:</strong>
          <ul>{solution.warnings.map((w) => <li>{w}</li>)}</ul>
        </div>
      )}

      {sections
        .filter((s) => s.picks.length > 0)
        .map((s) => (
          <section class="res-section">
            <header class="res-section-head">
              <h3>{s.label}</h3>
              <span class="ct">{s.picks.length} {s.picks.length === 1 ? "pick" : "picks"}</span>
            </header>
            <div class="grid">
              {s.picks.map((p, i) => (
                <ProductCard
                  pick={p}
                  vertical={vertical}
                  userEcosystem={solution.inputs.ecosystem}
                  idx={i}
                />
              ))}
            </div>
          </section>
        ))}

      <ReasoningChain steps={solution.reasoning_chain} />
    </>
  ) : (
    <div class="empty">
      <h3>Pick a device type to see compatible recommendations.</h3>
      <p>
        Or tap a preset above for an opinionated start. The configurator filters
        the knowledge base in real time as you change inputs.
      </p>
    </div>
  )}
</section>

<script>
  import { solve } from "@engine/solver";
  import type { KnowledgeBase, UserInputs } from "@engine/solver";
  import kbRaw from "@verticals/smart-home/kb.json";
  import {
    matchExample,
    renderSolutionHTML,
    encodeInputs,
    decodeInputs,
  } from "@engine/ui/render";

  const kb = kbRaw as KnowledgeBase;
  const form = document.getElementById("configurator-form") as HTMLFormElement | null;
  const result = document.getElementById("result");

  if (form && result) {
    const vertical = form.dataset.vertical ?? "smart-home";

    function readForm(): UserInputs {
      const data = new FormData(form!);
      const ecosystem = (data.get("ecosystem") as string) ?? "homekit";
      const wants = data.getAll("wants") as string[];
      return { ecosystem, wants, picks_per_type: 3 };
    }

    function populateForm(inputs: UserInputs) {
      for (const input of form!.querySelectorAll<HTMLInputElement>('input[name="ecosystem"]')) {
        input.checked = input.value === inputs.ecosystem;
      }
      for (const input of form!.querySelectorAll<HTMLInputElement>('input[name="wants"]')) {
        input.checked = inputs.wants.includes(input.value);
      }
    }

    function render(inputs: UserInputs) {
      const [solution] = solve(kb, inputs);
      result!.innerHTML = renderSolutionHTML(solution, vertical);
      updateLivePreview(inputs, solution);
      updateTabs(inputs);
      updateWantCounts(inputs);
      updateShareHash(inputs);
      syncSelectionUI();
    }

    function syncSelectionUI() {
      // Recompute build-summary total + cart-link href from selected pcards.
      const cards = Array.from(document.querySelectorAll<HTMLElement>(".pcard[data-sku]"));
      let total = 0;
      const selectedSkus: string[] = [];
      for (const card of cards) {
        const cb = card.querySelector<HTMLInputElement>(".pick-checkbox");
        const selected = cb ? cb.checked : true;
        card.dataset.selected = selected ? "1" : "0";
        if (!selected) continue;
        const sku = card.dataset.sku ?? "";
        const price = parseFloat(card.dataset.price ?? "0") || 0;
        if (sku) selectedSkus.push(sku);
        total += price;
      }
      const amountEl = document.getElementById("bs-amount");
      if (amountEl) {
        amountEl.textContent = total > 0 ? `$${Math.round(total)}` : "$0";
      }
      const metaEl = document.querySelector<HTMLElement>(".build-summary .bs-meta");
      if (metaEl) {
        metaEl.textContent =
          selectedSkus.length === 0
            ? "tick the products you want, then add to cart"
            : `across ${selectedSkus.length} ${selectedSkus.length === 1 ? "pick" : "picks"}`;
      }
      const cartEl = document.getElementById("bs-cart") as HTMLAnchorElement | null;
      if (cartEl) {
        const href = `/go/${vertical}/cart?skus=${selectedSkus.join(",")}`;
        cartEl.href = href;
        cartEl.classList.toggle("disabled", selectedSkus.length === 0);
      }
    }

    // Delegate-listen for checkbox changes anywhere in the result area.
    if (result) {
      result.addEventListener("change", (e) => {
        const t = e.target as HTMLElement;
        if (t && t.classList && t.classList.contains("pick-checkbox")) {
          syncSelectionUI();
        }
      });
    }

    function updateLivePreview(
      inputs: UserInputs,
      solution: { picks: { entity: { attributes: { price_usd?: number } }; native_in_ecosystem: boolean }[]; hubs_required: string[] },
    ) {
      const totalPicks = solution.picks.length;
      const setText = (id: string, text: string) => {
        const el = document.getElementById(id);
        if (el) el.textContent = text;
      };
      setText("stat-picks", totalPicks > 0 ? String(totalPicks) : "—");
      setText("stat-types", inputs.wants.length > 0 ? String(inputs.wants.length) : "—");
      const hubsEl = document.getElementById("stat-hubs");
      if (hubsEl) {
        hubsEl.textContent = totalPicks === 0 ? "—" : String(solution.hubs_required.length || "0");
        hubsEl.classList.toggle("ok", solution.hubs_required.length === 0 && totalPicks > 0);
      }
      const ecoEl = document.getElementById("stat-eco");
      if (ecoEl) {
        const labels: Record<string, string> = {
          homekit: "Apple HomeKit",
          google_home: "Google Home",
          alexa: "Amazon Alexa",
          home_assistant: "Home Assistant",
        };
        ecoEl.textContent = labels[inputs.ecosystem] ?? inputs.ecosystem;
      }
      const btnText = document.getElementById("btn-solve-text");
      const btnSolve = document.getElementById("btn-solve") as HTMLButtonElement | null;
      const allDone = !!inputs.ecosystem && inputs.wants.length > 0;
      if (btnText) {
        btnText.textContent = allDone
          ? `show ${totalPicks} compatible picks`
          : "pick at least one device";
      }
      if (btnSolve) {
        btnSolve.disabled = !allDone;
        btnSolve.classList.toggle("disabled", !allDone);
      }
    }

    function updateTabs(inputs: UserInputs) {
      const tabs = form!.querySelectorAll<HTMLDivElement>(".config-tab");
      const stepEcoDone = !!inputs.ecosystem;
      const stepWantsDone = inputs.wants.length > 0;
      const allDone = stepEcoDone && stepWantsDone;
      tabs.forEach((tab) => {
        const k = tab.dataset.tab;
        tab.classList.remove("done", "active");
        if (k === "eco") {
          if (stepEcoDone) tab.classList.add("done");
          if (!stepEcoDone) tab.classList.add("active");
        } else if (k === "wants") {
          if (stepWantsDone) tab.classList.add("done");
          if (stepEcoDone && !stepWantsDone) tab.classList.add("active");
        } else if (k === "solve") {
          if (allDone) tab.classList.add("active");
        }
      });
    }

    function updateWantCounts(inputs: UserInputs) {
      // Count how many entities of each type are compatible with the chosen ecosystem.
      const eco = inputs.ecosystem;
      for (const span of document.querySelectorAll<HTMLSpanElement>("[data-want-count]")) {
        const t = span.dataset.wantCount;
        const n = kb.entities.filter((e: { type: string; attributes: { ecosystems?: string[] } }) =>
          e.type === t && (e.attributes.ecosystems ?? []).includes(eco),
        ).length;
        span.textContent = String(n);
      }
    }

    function updateShareHash(inputs: UserInputs) {
      const el = document.getElementById("share-hash");
      if (el) el.textContent = "#" + encodeInputs(inputs);
    }

    function syncHash(inputs: UserInputs) {
      const next = "#" + encodeInputs(inputs);
      if (location.hash !== next) {
        history.replaceState(null, "", next);
      }
    }

    function onFormChange() {
      const inputs = readForm();
      render(inputs);
      syncHash(inputs);
    }

    function scrollToResults() {
      result!.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    // Initial hydration: hash overrides defaults if present
    const fromHash = decodeInputs(location.hash);
    if (fromHash) {
      populateForm(fromHash);
    }
    // Always re-render to pick up live counts + tab state, even if SSR matched
    onFormChange();

    form.addEventListener("change", onFormChange);

    window.addEventListener("hashchange", () => {
      const inputs = decodeInputs(location.hash);
      if (inputs) {
        populateForm(inputs);
        render(inputs);
      }
    });

    document.querySelectorAll<HTMLButtonElement>(".chip[data-example]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const match = matchExample(btn.dataset.example ?? "");
        if (!match) return;
        populateForm(match);
        render(match);
        syncHash(match);
        scrollToResults();
      });
    });

    document.querySelectorAll<HTMLButtonElement>(".preset-chip[data-preset-eco]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const eco = btn.dataset.presetEco ?? "homekit";
        const wants = (btn.dataset.presetWants ?? "").split(",").filter(Boolean);
        const inputs: UserInputs = { ecosystem: eco, wants, picks_per_type: 3 };
        populateForm(inputs);
        render(inputs);
        syncHash(inputs);
        setTimeout(scrollToResults, 80);
      });
    });

    const btnSolve = document.getElementById("btn-solve");
    if (btnSolve) {
      btnSolve.addEventListener("click", () => {
        if (!(btnSolve as HTMLButtonElement).disabled) scrollToResults();
      });
    }

    const copyBtn = document.getElementById("copy-link") as HTMLButtonElement | null;
    const copyStatus = document.getElementById("copy-status");
    if (copyBtn && copyStatus) {
      copyBtn.addEventListener("click", async () => {
        syncHash(readForm());
        const url = location.href;
        try {
          await navigator.clipboard.writeText(url);
          copyStatus.textContent = "copied ✓";
          copyStatus.classList.add("ok-flash");
        } catch {
          copyStatus.textContent = url;
        }
        setTimeout(() => {
          copyStatus.textContent = "";
          copyStatus.classList.remove("ok-flash");
        }, 1400);
      });
    }
  }
</script>

<style is:global>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── HERO ─── */
  .hero {
    background:
      radial-gradient(1200px 400px at 50% -200px, oklch(0.92 0.04 145 / 0.45), transparent 60%),
      var(--paper-0);
    border-bottom: 1px solid var(--paper-edge);
    padding: 36px 24px 0;
  }
  .hero-inner { max-width: 1180px; margin: 0 auto; }
  .h-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 99px;
    background: var(--paper-1);
    border: 1px solid var(--paper-edge);
  }
  .h-eyebrow .pip { width: 5px; height: 5px; border-radius: 50%; background: var(--ok); }
  .h-title {
    font-size: 44px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--ink-0);
    margin: 14px 0 8px;
    text-wrap: balance;
    max-width: 780px;
  }
  .h-title em {
    font-style: normal;
    background: linear-gradient(180deg, transparent 60%, oklch(0.88 0.10 145) 60%);
    padding: 0 2px;
  }
  .h-sub {
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 640px;
    margin: 0 0 28px;
    text-wrap: pretty;
  }

  /* ─── CONFIGURATOR CARD ─── */
  .config-card {
    background: var(--paper-0);
    border: 1px solid var(--paper-edge);
    border-radius: 14px;
    box-shadow:
      0 1px 0 var(--paper-1) inset,
