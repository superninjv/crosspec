---
interface Props {
  title: string;
  description?: string;
  path?: string;
  ogImage?: string;
  crumbs?: string[];
  kbStatus?: string;
}
const {
  title,
  description = "Crosspec. Vertical configurator hub.",
  path = Astro.url.pathname,
  ogImage = "/og-image.png",
  crumbs,
  kbStatus = "v0.1",
} = Astro.props;
const canonical = `https://crosspec.com${path}`;
const ogImageURL = `https://crosspec.com${ogImage}`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="crosspec" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <header class="topbar">
      <a href="/" class="brand" aria-label="crosspec home">
        <span class="glyph">×</span>
        <span class="name">crosspec</span>
        {crumbs && crumbs.length > 0 && (
          <span class="crumbs">
            {crumbs.map((c, i) => (
              <>
                <span class="sep">/</span>
                <span class={i === crumbs.length - 1 ? "here" : undefined}>{c}</span>
              </>
            ))}
          </span>
        )}
      </a>
      <div class="topbar-spacer"></div>
      <div class="topbar-meta">
        <span><span class="pip"></span>live</span>
        <span class="kb-status"><code>{kbStatus}</code></span>
      </div>
    </header>
    <main id="main-content"><slot /></main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="disclosure">
          Compatibility data sourced from public registries, cited per recommendation.
          crosspec earns affiliate commission on qualifying purchases; this does not
          change ranking.
        </p>
        <p class="footer-links">
          <a href="https://www.home-assistant.io/integrations/" rel="nofollow" target="_blank">HA integrations</a>
          <span class="sep">·</span>
          <a href="https://csa-iot.org/csa-iot_products/" rel="nofollow" target="_blank">CSA Matter products</a>
          <span class="sep">·</span>
          <a href="https://www.zigbee2mqtt.io/supported-devices/" rel="nofollow" target="_blank">Zigbee2MQTT</a>
          <span class="sep">|</span>
          <a href="https://github.com/superninjv/crosspec" rel="nofollow" target="_blank">GitHub</a>
          <span class="sep">|</span>
          <a href="/about/">About</a>
        </p>
      </div>
    </footer>
    <style is:global>
      :root {
        /* oklch design tokens — fall back to var() consumers */
        --ink-0: oklch(0.14 0.012 250);
        --ink-1: oklch(0.22 0.011 250);
        --ink-2: oklch(0.40 0.009 250);
        --ink-3: oklch(0.58 0.008 250);
        --ink-4: oklch(0.74 0.006 250);
        --paper-0: oklch(0.985 0.003 250);
        --paper-1: oklch(0.965 0.004 250);
        --paper-2: oklch(0.935 0.005 250);
        --paper-3: oklch(0.895 0.006 250);
        --paper-edge: oklch(0.86 0.007 250);
        --ok: oklch(0.58 0.13 145);
        --ok-soft: oklch(0.93 0.05 145);
        --ok-dark: oklch(0.32 0.10 145);
        --warn: oklch(0.66 0.14 70);
        --warn-soft: oklch(0.95 0.06 80);
        --warn-dark: oklch(0.36 0.10 70);

        --sans: "Inter Tight", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        --mono: "JetBrains Mono", ui-monospace, "SF Mono", Menlo, monospace;

        --row-pad-y: 10px;
        --row-pad-x: 14px;
        --grid-gap: 12px;
        --card-pad: 16px;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        background: var(--paper-1);
        color: var(--ink-0);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      ::selection { background: oklch(0.88 0.04 145); color: var(--ink-0); }
      a { color: inherit; }
      button {
        font: inherit;
        color: inherit;
        background: none;
        border: 0;
        padding: 0;
        cursor: pointer;
      }
      code, kbd, samp, .mono {
        font-family: var(--mono);
        font-feature-settings: "ss01", "zero";
      }
      a:focus-visible, button:focus-visible, input:focus-visible {
        outline: 2px solid var(--ink-0);
        outline-offset: 2px;
        border-radius: 4px;
      }
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--ink-0);
        color: var(--paper-0);
        padding: 8px 14px;
        text-decoration: none;
        z-index: 100;
        font-family: var(--mono);
        font-size: 12px;
      }
      .skip-link:focus { left: 8px; top: 8px; }

      .topbar {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 10px 24px;
        background: var(--paper-0);
        border-bottom: 1px solid var(--paper-edge);
        position: sticky;
        top: 0;
        z-index: 20;
      }
      .topbar .brand {
        display: flex;
        align-items: baseline;
        gap: 8px;
        font-family: var(--mono);
        font-size: 12.5px;
        font-weight: 600;
        text-decoration: none;
        color: var(--ink-0);
      }
      .topbar .brand .glyph {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        border-radius: 3px;
        background: var(--ink-0);
        color: var(--paper-0);
        font-size: 11px;
        font-weight: 700;
        transform: translateY(2px);
      }
      .topbar .brand .name { color: var(--ink-0); }
      .topbar .brand .crumbs { color: var(--ink-3); font-weight: 500; }
      .topbar .brand .crumbs .sep { margin: 0 4px; color: var(--ink-4); }
      .topbar .brand .crumbs .here { color: var(--ink-1); font-weight: 600; }
      .topbar-spacer { flex: 1; }
      .topbar-meta {
        display: flex;
        align-items: center;
        gap: 14px;
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-3);
      }
      .topbar-meta .pip {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--ok);
        box-shadow: 0 0 0 3px oklch(0.58 0.13 145 / 0.18);
        display: inline-block;
        margin-right: 6px;
      }
      .topbar-meta {
        font-size: 12.5px;
        color: var(--ink-2);
        font-weight: 600;
      }
      .topbar-meta .kb-status code {
        font-size: 12.5px;
      }

      main { display: block; }

      .site-footer {
        border-top: 1px solid var(--paper-edge);
        padding: 24px 24px 36px;
        background: var(--paper-0);
        color: var(--ink-3);
      }
      .footer-inner {
        max-width: 1180px;
        margin: 0 auto;
        font-size: 13.5px;
      }
      .site-footer p { margin: 0 0 8px; }
      .site-footer a { color: var(--ink-2); text-decoration: underline; text-underline-offset: 2px; }
      .site-footer a:hover { color: var(--ink-0); }
      .site-footer .footer-links .sep { padding: 0 6px; color: var(--ink-4); }
      .site-footer .disclosure { line-height: 1.55; max-width: 720px; }

      @media (max-width: 640px) {
        .topbar { padding: 9px 14px; gap: 10px; }
        .topbar .brand .crumbs { display: none; }
        .topbar-meta .kb-status { display: none; }
        .site-footer { padding: 18px 14px 28px; }
      }
    </style>
  </body>
</html>
