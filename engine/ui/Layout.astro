---
interface Props {
  title: string;
  description?: string;
  path?: string;
  ogImage?: string;
}
const {
  title,
  description = "Crosspec — vertical configurator hub.",
  path = Astro.url.pathname,
  ogImage = "/og-image.png",
} = Astro.props;
const canonical = `https://crosspec.com${path}`;
const ogImageURL = `https://crosspec.com${ogImage}`;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="crosspec" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <header class="site-header">
      <a href="/" class="brand" aria-label="crosspec home">crosspec</a>
      <nav aria-label="Primary">
        <a href="/smart-home" aria-current={currentPath.startsWith("/smart-home") ? "page" : undefined}>Smart Home</a>
        <a href="/about" aria-current={currentPath === "/about" ? "page" : undefined}>About</a>
      </nav>
    </header>
    <main id="main-content"><slot /></main>
    <footer class="site-footer">
      <p class="disclosure">
        Compatibility data sourced from public registries — cited per recommendation.
        crosspec earns affiliate commission on qualifying purchases; this does not
        change ranking.
      </p>
      <p class="footer-links">
        Sources:
        <a href="https://www.home-assistant.io/integrations/" rel="nofollow" target="_blank">HA integrations</a>
        ·
        <a href="https://csa-iot.org/csa-iot_products/" rel="nofollow" target="_blank">CSA Matter products</a>
        ·
        <a href="https://www.zigbee2mqtt.io/supported-devices/" rel="nofollow" target="_blank">Zigbee2MQTT devices</a>
        <span class="sep">|</span>
        <a href="https://github.com/superninjv/crosspec" rel="nofollow" target="_blank">GitHub</a>
        <span class="sep">|</span>
        <a href="/about">About</a>
      </p>
    </footer>
    <style is:global>
      :root {
        --fg: #111;
        --muted: #555;
        --bg: #fafaf7;
        --accent: #0b6e4f;
        --accent-dark: #0a4d3a;
        --accent-soft: #d6f0e3;
        --card: #fff;
        --border: #e2e0d8;
        --warn-bg: #fff8e0;
        --warn-border: #f0d97a;
        --warn-fg: #7a5b00;
      }
      * { box-sizing: border-box; }
      body {
        font: 16px/1.55 system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        text-rendering: optimizeLegibility;
      }
      a { color: var(--accent); }
      a:focus-visible, button:focus-visible, input:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 4px;
      }
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--accent);
        color: #fff;
        padding: 0.5rem 1rem;
        text-decoration: none;
        z-index: 100;
      }
      .skip-link:focus { left: 0.5rem; top: 0.5rem; }

      .site-header {
        padding: 0.85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        gap: 1rem;
        align-items: center;
        background: var(--card);
      }
      .site-header .brand {
        font-weight: 700;
        letter-spacing: -0.02em;
        text-decoration: none;
        color: var(--fg);
        font-size: 1.05rem;
      }
      .site-header nav {
        margin-left: auto;
        display: flex;
        gap: 0.25rem;
      }
      .site-header nav a {
        color: var(--fg);
        text-decoration: none;
        padding: 0.4rem 0.75rem;
        border-radius: 6px;
        font-size: 0.95rem;
      }
      .site-header nav a:hover { background: var(--accent-soft); }
      .site-header nav a[aria-current="page"] {
        background: var(--accent-soft);
        color: var(--accent-dark);
        font-weight: 600;
      }

      main {
        padding: 1.5rem 1.25rem;
        max-width: 920px;
        margin: 0 auto;
      }

      .site-footer {
        border-top: 1px solid var(--border);
        padding: 1.25rem 1.25rem 1.5rem;
        font-size: 0.8rem;
        color: var(--muted);
        max-width: 920px;
        margin: 2rem auto 0;
      }
      .site-footer p { margin: 0 0 0.5rem; }
      .site-footer .footer-links a { color: var(--muted); text-decoration: underline; }
      .site-footer .footer-links a:hover { color: var(--accent); }
      .site-footer .sep { padding: 0 0.4rem; color: var(--border); }
      .site-footer .disclosure { line-height: 1.5; }

      @media (max-width: 480px) {
        main { padding: 1rem 0.85rem; }
        .site-header { padding: 0.75rem 0.85rem; }
        .site-footer { padding: 1rem 0.85rem 1.25rem; }
        .site-header nav a { padding: 0.4rem 0.55rem; font-size: 0.9rem; }
      }
    </style>
  </body>
</html>
