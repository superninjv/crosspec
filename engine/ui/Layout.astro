---
interface Props {
  title: string;
  description?: string;
  path?: string;
  ogImage?: string;
  crumbs?: string[];
  kbStatus?: string;
}
const {
  title,
  description = "Crosspec. Vertical configurator hub.",
  path = Astro.url.pathname,
  ogImage = "/og-image.png",
  crumbs,
  kbStatus = "v0.1",
} = Astro.props;
const canonical = `https://crosspec.com${path}`;
const ogImageURL = `https://crosspec.com${ogImage}`;
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN as string | undefined;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="crosspec" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {cfAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      />
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <header class="topbar">
      <a href="/" class="brand" aria-label="crosspec home">
        <span class="glyph">×</span>
        <span class="name">crosspec</span>
        {crumbs && crumbs.length > 0 && (
          <span class="crumbs">
            {crumbs.map((c, i) => (
              <>
                <span class="sep">/</span>
                <span class={i === crumbs.length - 1 ? "here" : undefined}>{c}</span>
              </>
            ))}
          </span>
        )}
      </a>
      <div class="topbar-spacer"></div>
      <div class="topbar-meta">
        <span><span class="pip"></span>live</span>
        <span class="kb-status"><code>{kbStatus}</code></span>
      </div>
    </header>
    <main id="main-content"><slot /></main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="disclosure">
          Compatibility data sourced from public registries, cited per recommendation.
          crosspec earns affiliate commission on qualifying purchases; this does not
          change ranking.
        </p>
        <p class="footer-links">
          <a href="https://www.home-assistant.io/integrations/" rel="nofollow" target="_blank">HA integrations</a>
          <span class="sep">·</span>
          <a href="https://csa-iot.org/csa-iot_products/" rel="nofollow" target="_blank">CSA Matter products</a>
          <span class="sep">·</span>
          <a href="https://www.zigbee2mqtt.io/supported-devices/" rel="nofollow" target="_blank">Zigbee2MQTT</a>
          <span class="sep">|</span>
          <a href="https://github.com/superninjv/crosspec" rel="nofollow" target="_blank">GitHub</a>
          <span class="sep">|</span>
          <a href="/about/">About</a>
        </p>
        <p class="powered-by">
          <a class="synoros-pill" href="https://synoros.io" target="_blank" rel="noopener">
            <span class="pb-label">powered by</span>
            <span class="pb-brand">synoros</span>
            <span class="pb-arr" aria-hidden="true">↗</span>
          </a>
        </p>
      </div>
    </footer>
    <style is:global>
      :root {
        /* oklch design tokens — fall back to var() consumers */
        --ink-0: oklch(0.14 0.012 250);
        --ink-1: oklch(0.22 0.011 250);
        --ink-2: oklch(0.40 0.009 250);
        --ink-3: oklch(0.58 0.008 250);
        --ink-4: oklch(0.74 0.006 250);
        --paper-0: oklch(0.985 0.003 250);
        --paper-1: oklch(0.965 0.004 250);
        --paper-2: oklch(0.935 0.005 250);
        --paper-3: oklch(0.895 0.006 250);
        --paper-edge: oklch(0.86 0.007 250);
        --ok: oklch(0.58 0.13 145);
        --ok-soft: oklch(0.93 0.05 145);
        --ok-dark: oklch(0.32 0.10 145);
        --warn: oklch(0.66 0.14 70);
        --warn-soft: oklch(0.95 0.06 80);
        --warn-dark: oklch(0.36 0.10 70);

        --sans: "Inter Tight", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        --mono: "JetBrains Mono", ui-monospace, "SF Mono", Menlo, monospace;

        --row-pad-y: 10px;
        --row-pad-x: 14px;
        --grid-gap: 12px;
        --card-pad: 16px;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        background: var(--paper-1);
        color: var(--ink-0);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      ::selection { background: oklch(0.88 0.04 145); color: var(--ink-0); }
      a { color: inherit; }
      button {
        font: inherit;
        color: inherit;
        background: none;
        border: 0;
        padding: 0;
        cursor: pointer;
      }
      code, kbd, samp, .mono {
        font-family: var(--mono);
        font-feature-settings: "ss01", "zero";
      }
      a:focus-visible, button:focus-visible, input:focus-visible {
        outline: 2px solid var(--ink-0);
        outline-offset: 2px;
        border-radius: 4px;
      }
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--ink-0);
        color: var(--paper-0);
        padding: 8px 14px;
        text-decoration: none;
        z-index: 100;
        font-family: var(--mono);
        font-size: 12px;
      }
      .skip-link:focus { left: 8px; top: 8px; }

      .topbar {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 10px 24px;
        background: var(--paper-0);
        border-bottom: 1px solid var(--paper-edge);
        position: sticky;
        top: 0;
        z-index: 20;
      }
      .topbar .brand {
        display: flex;
        align-items: baseline;
        gap: 8px;
        font-family: var(--mono);
        font-size: 12.5px;
        font-weight: 600;
        text-decoration: none;
        color: var(--ink-0);
      }
      .topbar .brand .glyph {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        border-radius: 3px;
        background: var(--ink-0);
        color: var(--paper-0);
        font-size: 11px;
        font-weight: 700;
        transform: translateY(2px);
      }
      .topbar .brand .name { color: var(--ink-0); }
      .topbar .brand .crumbs { color: var(--ink-3); font-weight: 500; }
      .topbar .brand .crumbs .sep { margin: 0 4px; color: var(--ink-4); }
      .topbar .brand .crumbs .here { color: var(--ink-1); font-weight: 600; }
      .topbar-spacer { flex: 1; }
      .topbar-meta {
        display: flex;
        align-items: center;
        gap: 14px;
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-3);
      }
      .topbar-meta .pip {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--ok);
        box-shadow: 0 0 0 3px oklch(0.58 0.13 145 / 0.18);
        display: inline-block;
        margin-right: 6px;
      }
      .topbar-meta {
        font-size: 12.5px;
        color: var(--ink-2);
        font-weight: 600;
      }
      .topbar-meta .kb-status code {
        font-size: 12.5px;
      }

      main { display: block; }

      .site-footer {
        border-top: 1px solid var(--paper-edge);
        padding: 24px 24px 36px;
        background: var(--paper-0);
        color: var(--ink-3);
      }
      .footer-inner {
        max-width: 1180px;
        margin: 0 auto;
        font-size: 13.5px;
      }
      .site-footer p { margin: 0 0 8px; }
      .site-footer a { color: var(--ink-2); text-decoration: underline; text-underline-offset: 2px; }
      .site-footer a:hover { color: var(--ink-0); }
      .site-footer .footer-links .sep { padding: 0 6px; color: var(--ink-4); }
      .site-footer .disclosure { line-height: 1.55; max-width: 720px; }

      /* ─── Shared configurator-shell styles (used by solar, keyboards, arduino) ─── */
      .ai-helper { max-width: 1100px; margin: 24px auto 0; padding: 0 24px; }
      .ai-inner { background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 12px; padding: 18px 20px; }
      .ai-head { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
      .ai-glyph { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 6px; background: var(--ink-1); color: var(--paper-0); font-family: var(--mono); font-weight: 700; font-size: 13px; }
      .ai-title { font-size: 15px; font-weight: 700; color: var(--ink-0); }
      .ai-sub { font-size: 12.5px; color: var(--ink-3); font-style: italic; }
      .ai-transcript { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; max-height: 320px; overflow-y: auto; }
      .ai-transcript:empty { display: none; }
      .ai-bubble { padding: 8px 12px; border-radius: 8px; font-size: 13.5px; line-height: 1.5; max-width: 80%; }
      .ai-user { align-self: flex-end; background: var(--ink-0); color: var(--paper-0); }
      .ai-assistant { align-self: flex-start; background: var(--paper-1); color: var(--ink-0); border: 1px solid var(--paper-edge); }
      .ai-system { align-self: center; font-size: 12px; color: var(--ink-3); font-style: italic; }
      .ai-form { display: flex; gap: 8px; margin-bottom: 10px; }
      .ai-form input { flex: 1; padding: 10px 12px; border: 1px solid var(--paper-edge); border-radius: 7px; background: var(--paper-1); color: var(--ink-0); font-size: 14px; font-family: var(--sans); }
      .ai-form input:focus { outline: 2px solid var(--ink-1); outline-offset: 1px; }
      .ai-submit { padding: 10px 18px; background: var(--ink-0); color: var(--paper-0); border: 0; border-radius: 7px; font-size: 13.5px; font-weight: 700; cursor: pointer; }
      .ai-submit:disabled { opacity: 0.5; cursor: not-allowed; }
      .ai-examples { display: flex; flex-wrap: wrap; gap: 6px; }
      .ai-chip { padding: 6px 12px; background: var(--paper-1); border: 1px solid var(--paper-edge); border-radius: 99px; font-size: 12px; color: var(--ink-2); cursor: pointer; font-family: var(--mono); }
      .ai-chip:hover { background: var(--paper-0); border-color: var(--ink-3); color: var(--ink-0); }

      .picker-form { max-width: 1100px; margin: 16px auto 0; padding: 0 24px; display: flex; flex-direction: column; gap: 20px; }
      .picker-step { border: 0; padding: 0; margin: 0; }
      .picker-step legend { display: flex; align-items: center; gap: 10px; font-size: 16px; font-weight: 700; color: var(--ink-0); margin-bottom: 12px; }
      .step-num { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; background: var(--ink-0); color: var(--paper-0); font-family: var(--mono); font-size: 12px; font-weight: 700; }
      .chip-row { display: flex; flex-wrap: wrap; gap: 8px; }
      .chip { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 99px; font-size: 13.5px; cursor: pointer; transition: border-color .12s, background-color .12s; }
      .chip input { position: absolute; opacity: 0; pointer-events: none; }
      .chip:has(input:checked) { background: var(--ink-0); color: var(--paper-0); border-color: var(--ink-0); }
      .chip:hover { border-color: var(--ink-3); }

      .want-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; }
      .want-tile { cursor: pointer; background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 9px; padding: 12px 14px; display: grid; grid-template-columns: auto 1fr; gap: 10px; align-items: start; transition: border-color .12s, box-shadow .12s; }
      .want-tile input { appearance: none; -webkit-appearance: none; width: 18px; height: 18px; border: 1.5px solid var(--ink-3); border-radius: 4px; background: var(--paper-0); margin-top: 1px; cursor: pointer; position: relative; }
      .want-tile input:checked { background: var(--ink-0); border-color: var(--ink-0); }
      .want-tile input:checked::after { content: ""; position: absolute; left: 4px; top: 1px; width: 7px; height: 11px; border: solid var(--paper-0); border-width: 0 2px 2px 0; transform: rotate(45deg); }
      .want-tile:hover { border-color: var(--ink-3); }
      .want-tile.want-required { border-color: var(--ink-3); background: var(--paper-1); }
      .wt-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
      .wt-label { font-size: 14px; font-weight: 700; color: var(--ink-0); }
      .wt-blurb { font-size: 12.5px; color: var(--ink-2); line-height: 1.4; }
      .wt-count { font-family: var(--mono); font-size: 11px; color: var(--ink-3); margin-top: 2px; }
      .wt-required-badge { font-family: var(--mono); font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-2); background: var(--paper-2); border-radius: 99px; padding: 1px 6px; margin-top: 4px; align-self: flex-start; }

      .picker-result { max-width: 1100px; margin: 0 auto; padding: 8px 24px 0; min-height: 80px; }
      .picker-empty { color: var(--ink-3); font-size: 14px; padding: 20px 0; text-align: center; font-style: italic; }
      .res-section { margin-top: 24px; }
      .res-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--paper-edge); padding-bottom: 6px; margin-bottom: 10px; }
      .res-head h2 { font-size: 18px; font-weight: 700; margin: 0; }
      .res-ct { font-family: var(--mono); font-size: 12px; color: var(--ink-3); }
      .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px; }

      .pcard { background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 10px; padding: 14px; display: flex; flex-direction: column; gap: 8px; transition: border-color .12s, opacity .12s; }
      .pcard[data-selected="0"] { opacity: 0.62; background: var(--paper-1); }
      .pcard:hover { border-color: var(--ink-4); }
      .pc-top { display: flex; align-items: center; gap: 8px; }
      .pick-toggle { display: inline-flex; align-items: center; cursor: pointer; }
      .pick-toggle input { position: absolute; opacity: 0; pointer-events: none; }
      .pick-box { width: 16px; height: 16px; border: 1.5px solid var(--ink-3); border-radius: 4px; display: inline-flex; align-items: center; justify-content: center; }
      .pick-toggle input:checked + .pick-box { background: var(--ink-0); border-color: var(--ink-0); }
      .pick-toggle input:checked + .pick-box::after { content: ""; width: 8px; height: 4px; border-left: 2px solid var(--paper-0); border-bottom: 2px solid var(--paper-0); transform: rotate(-45deg) translate(1px, -1px); }
      .pc-brand { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); font-weight: 600; }
      .pc-qty { display: inline-flex; align-items: center; gap: 4px; margin-left: auto; background: var(--paper-1); border: 1px solid var(--paper-edge); border-radius: 6px; padding: 1px 2px; }
      .qty-btn { width: 22px; height: 22px; border: 0; background: transparent; font-family: var(--mono); font-size: 14px; font-weight: 700; color: var(--ink-1); cursor: pointer; padding: 0; line-height: 1; }
      .qty-btn:hover { color: var(--ink-0); background: var(--paper-2); border-radius: 4px; }
      .qty-val { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--ink-0); min-width: 18px; text-align: center; }
      .pc-name { font-size: 14.5px; font-weight: 600; line-height: 1.3; margin: 0; }
      .pc-name a { color: var(--ink-0); text-decoration: none; }
      .pc-name a:hover { text-decoration: underline; text-underline-offset: 3px; }
      .pc-note { font-size: 12.5px; color: var(--ink-2); line-height: 1.5; margin: 0; }
      .pc-foot { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: auto; padding-top: 6px; }
      .pc-price { font-family: var(--mono); font-size: 14.5px; font-weight: 700; color: var(--ink-0); }
      .pc-cta { display: inline-flex; align-items: center; gap: 4px; padding: 7px 12px; background: var(--ink-0); color: var(--paper-0); border-radius: 5px; font-size: 12.5px; font-weight: 600; text-decoration: none; }
      .pc-cta:hover { background: var(--ink-1); }

      .build-summary { position: sticky; bottom: 12px; z-index: 10; max-width: 1100px; margin: 24px auto 12px; padding: 14px 20px; background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 12px; box-shadow: 0 6px 20px -8px oklch(0.20 0.02 250 / 0.18); display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
      .bs-totals { display: flex; align-items: baseline; gap: 12px; }
      .bs-label { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); font-weight: 600; }
      .bs-amount { font-family: var(--mono); font-size: 24px; font-weight: 700; color: var(--ink-0); }
      .bs-meta { font-family: var(--mono); font-size: 12px; color: var(--ink-2); }
      .bs-cart { display: inline-flex; align-items: center; gap: 8px; padding: 12px 22px; background: oklch(0.62 0.18 35); color: var(--paper-0); font-weight: 700; font-size: 14.5px; text-decoration: none; border-radius: 7px; box-shadow: 0 2px 0 oklch(0.45 0.18 35); transition: transform .12s, box-shadow .12s; }
      .bs-cart:hover { transform: translateY(-1px); box-shadow: 0 3px 0 oklch(0.45 0.18 35), 0 6px 14px -4px oklch(0.40 0.15 35 / 0.55); }
      .bs-cart.disabled { pointer-events: none; opacity: 0.45; box-shadow: none; }

      .ai-sizing { max-width: 1100px; margin: 16px auto 0; padding: 16px 20px; background: linear-gradient(135deg, oklch(0.96 0.04 80) 0%, var(--paper-0) 100%); border: 1px solid var(--ink-3); border-radius: 12px; }
      .sz-head { font-size: 14.5px; font-weight: 700; color: var(--ink-0); margin-bottom: 12px; }
      .sz-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 8px; }
      .sz-cell { background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 8px; padding: 10px 12px; display: flex; flex-direction: column; gap: 2px; }
      .sz-k { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); font-weight: 600; }
      .sz-v { font-family: var(--mono); font-size: 14px; font-weight: 700; color: var(--ink-0); }
      .sz-foot { font-size: 11.5px; color: var(--ink-3); margin: 10px 0 0; line-height: 1.5; }
      .sz-gap { margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--paper-edge); }
      .sz-gap-head { font-size: 12.5px; font-weight: 700; color: var(--ink-1); margin-bottom: 8px; }
      .gap-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 6px; }
      .gap-cell { display: flex; flex-direction: column; gap: 2px; padding: 6px 10px; background: var(--paper-1); border-radius: 6px; font-size: 12.5px; }
      .gap-k { font-family: var(--mono); font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); font-weight: 600; }
      .gap-met { color: oklch(0.32 0.10 145); font-weight: 600; }
      .gap-short { color: oklch(0.36 0.10 70); font-weight: 500; }
      .gap-short strong { color: oklch(0.32 0.13 30); }

      .deps-banner { max-width: 1100px; margin: 12px auto 0; padding: 10px 18px; background: oklch(0.95 0.05 70); border: 1px solid oklch(0.66 0.14 70); border-left-width: 4px; border-radius: 8px; font-size: 13px; color: var(--ink-1); }
      .deps-banner strong { color: oklch(0.36 0.10 70); }

      .all-products { max-width: 1100px; margin: 28px auto 80px; padding: 0 24px; }
      .all-products summary { font-family: var(--mono); font-size: 13px; color: var(--ink-2); cursor: pointer; padding: 10px 0; }
      .all-products summary:hover { color: var(--ink-0); }
      .all-inner { padding-top: 12px; }
      .cat-section { margin-top: 24px; }
      .cat-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--paper-edge); padding-bottom: 6px; margin-bottom: 10px; }
      .cat-head h3 { font-size: 17px; font-weight: 700; margin: 0; }
      .cat-count { font-family: var(--mono); font-size: 11px; color: var(--ink-3); }
      .cat-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 6px; }
      .cat-card .cc-link { display: grid; grid-template-columns: 1fr auto; align-items: baseline; column-gap: 8px; padding: 8px 10px; background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 6px; text-decoration: none; color: var(--ink-0); transition: border-color .12s; }
      .cat-card .cc-link:hover { border-color: var(--ink-3); }
      .cc-brand { grid-column: 1; font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); font-weight: 600; }
      .cc-name { grid-column: 1; grid-row: 2; font-size: 13px; font-weight: 500; line-height: 1.25; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .cc-price { grid-column: 2; grid-row: 1 / 3; align-self: center; font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--ink-0); }
      .site-footer .powered-by { margin-top: 14px; margin-bottom: 0; }
      .synoros-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 5px 12px 5px 10px;
        background: var(--paper-1);
        border: 1px solid var(--paper-edge);
        border-radius: 99px;
        font-family: var(--mono);
        font-size: 11.5px;
        text-decoration: none !important;
        color: var(--ink-2) !important;
        transition: border-color .12s, color .12s, background-color .12s;
      }
      .synoros-pill:hover {
        border-color: var(--ink-3);
        color: var(--ink-0) !important;
        background: var(--paper-0);
      }
      .synoros-pill .pb-label {
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ink-3);
        font-size: 10px;
      }
      .synoros-pill .pb-brand {
        font-weight: 700;
        color: var(--ink-0);
      }
      .synoros-pill .pb-arr {
        font-size: 11px;
        color: var(--ink-3);
      }

      @media (max-width: 640px) {
        .topbar { padding: 9px 14px; gap: 10px; }
        .topbar .brand .crumbs { display: none; }
        .topbar-meta .kb-status { display: none; }
        .site-footer { padding: 18px 14px 28px; }
      }

      /* Configurator hero — shared across all vertical pages.
         Lives here (not on each page) so it's available regardless of which
         page bundle Astro ships, since <style is:global> on a page only loads
         on that page. */
      .solar-hero {
        background: linear-gradient(180deg, oklch(0.96 0.04 80) 0%, var(--paper-1) 100%);
        border-bottom: 1px solid var(--paper-edge);
        padding: 36px 24px 30px;
      }
      .solar-hero .hero-inner { max-width: 1100px; margin: 0 auto; }
      .solar-hero .eyebrow {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-3);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin: 0 0 6px;
      }
      .solar-hero h1 {
        font-size: 38px;
        line-height: 1.1;
        letter-spacing: -0.02em;
        font-weight: 700;
        margin: 0 0 14px;
        color: var(--ink-0);
        text-wrap: balance;
        max-width: 820px;
      }
      .solar-hero h1 em { font-style: normal; color: var(--accent); }
      .solar-hero .lede {
        font-size: 16px;
        color: var(--ink-2);
        line-height: 1.55;
        max-width: 720px;
        margin: 0;
      }
    </style>
  </body>
</html>
