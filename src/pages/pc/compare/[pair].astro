---
import Layout from "@engine/ui/Layout.astro";
import type { Entity, KnowledgeBase } from "@engine/solver";
import kbRaw from "@verticals/pc/kb.json";
import affiliatesRaw from "@verticals/pc/affiliates.json";

const kb = kbRaw as KnowledgeBase;

interface AffRaw {
  products?: Record<string, { merchant?: string; asin?: string }>;
  skus?: Record<string, { asin?: string }>;
}
const affRaw = affiliatesRaw as AffRaw;
const affProducts: Record<string, { asin?: string }> = affRaw.products ?? affRaw.skus ?? {};

const VERTICAL = "pc";

const TYPE_LABEL: Record<string, string> = {
  cpu: "CPU",
  gpu: "GPU",
  motherboard: "motherboard",
  ram: "RAM kit",
  psu: "power supply",
  case: "case",
  cooler: "cooler",
  storage: "storage drive",
};

export async function getStaticPaths() {
  const k = kbRaw as KnowledgeBase;
  const byType = new Map<string, Entity[]>();
  for (const e of k.entities) {
    if (!byType.has(e.type)) byType.set(e.type, []);
    byType.get(e.type)!.push(e);
  }
  const out: Array<{ params: { pair: string }; props: { aId: string; bId: string } }> = [];
  for (const [, ents] of byType) {
    const top = ents.slice(0, 5);
    for (let i = 0; i < top.length; i++) {
      for (let j = i + 1; j < top.length; j++) {
        const a = top[i];
        const b = top[j];
        const aSku = a.sku ?? a.id;
        const bSku = b.sku ?? b.id;
        const pair = `${aSku}-vs-${bSku}`;
        out.push({ params: { pair }, props: { aId: a.id, bId: b.id } });
      }
    }
  }
  return out;
}

interface PageProps { aId: string; bId: string }
const { aId, bId } = Astro.props as PageProps;
const a = kb.entities.find((e) => e.id === aId)! as Entity;
const b = kb.entities.find((e) => e.id === bId)! as Entity;
const aSku = a.sku ?? a.id;
const bSku = b.sku ?? b.id;
const aAttrs = a.attributes;
const bAttrs = b.attributes;

type Attrs = Record<string, unknown>;
const aAttrsT = aAttrs as Attrs;
const bAttrsT = bAttrs as Attrs;

const typeLabel = TYPE_LABEL[a.type] ?? a.type;
const aPrice = typeof aAttrs.price_usd === "number" ? (aAttrs.price_usd as number) : null;
const bPrice = typeof bAttrs.price_usd === "number" ? (bAttrs.price_usd as number) : null;
const aAsin = affProducts[a.id]?.asin ?? affProducts[aSku]?.asin ?? null;
const bAsin = affProducts[b.id]?.asin ?? affProducts[bSku]?.asin ?? null;

const pageTitle = `${a.name} vs ${b.name} · specs, socket, price | crosspec`;
const description = `Side-by-side comparison of the ${a.name} and ${b.name} ${typeLabel}s: socket, TDP, cores, memory support, and price. Sourced from vendor spec sheets.`;

const specs: Array<{ k: string; aV: string; bV: string }> = [
  { k: "Brand", aV: String(aAttrsT.brand ?? "—"), bV: String(bAttrsT.brand ?? "—") },
  { k: "Price (last verified 2026-05-05)", aV: aPrice != null ? `$${aPrice}` : "—", bV: bPrice != null ? `$${bPrice}` : "—" },
];

const extraKeys: [string, string][] = [
  // CPU
  ["socket", "Socket"],
  ["cores", "Cores"],
  ["threads", "Threads"],
  ["base_clock_ghz", "Base clock (GHz)"],
  ["boost_clock_ghz", "Boost clock (GHz)"],
  ["tdp_w", "TDP (W)"],
  ["memory_type", "Memory type"],
  ["max_memory_mt_s", "Max memory (MT/s)"],
  ["igpu", "Integrated GPU"],
  // GPU
  ["vram_gb", "VRAM (GB)"],
  ["vram_type", "VRAM type"],
  ["cuda_cores", "CUDA cores"],
  ["stream_processors", "Stream processors"],
  ["power_connectors", "Power connectors"],
  ["pcie_slot", "PCIe slot"],
  // Motherboard
  ["chipset", "Chipset"],
  ["form_factor", "Form factor"],
  ["memory_slots", "Memory slots"],
  ["max_memory_gb", "Max memory (GB)"],
  ["pcie_slots", "PCIe slots"],
  ["m2_slots", "M.2 slots"],
  // RAM
  ["capacity_gb", "Capacity (GB)"],
  ["speed_mt_s", "Speed (MT/s)"],
  ["latency_cl", "Latency (CL)"],
  ["voltage_v", "Voltage (V)"],
  // PSU
  ["wattage_w", "Wattage (W)"],
  ["efficiency_rating", "Efficiency rating"],
  ["modular", "Modular"],
  // Case
  ["max_gpu_length_mm", "Max GPU length (mm)"],
  ["max_cpu_cooler_mm", "Max CPU cooler (mm)"],
  ["drive_bays", "Drive bays"],
  // Cooler
  ["tdp_support_w", "TDP support (W)"],
  ["radiator_size_mm", "Radiator size (mm)"],
  ["socket_support", "Socket support"],
  // Storage
  ["interface", "Interface"],
  ["capacity", "Capacity"],
  ["read_mbps", "Read (MB/s)"],
  ["write_mbps", "Write (MB/s)"],
];
for (const [k, niceK] of extraKeys) {
  const av = aAttrsT[k];
  const bv = bAttrsT[k];
  if (av != null || bv != null) {
    specs.push({
      k: niceK,
      aV: Array.isArray(av) ? av.join(", ") : av != null ? String(av) : "—",
      bV: Array.isArray(bv) ? bv.join(", ") : bv != null ? String(bv) : "—",
    });
  }
}

// Compat note based on component type
const aSocket = String(aAttrsT.socket ?? "");
const bSocket = String(bAttrsT.socket ?? "");
const compatNote =
  a.type === "cpu" && aSocket && bSocket && aSocket === bSocket
    ? `Both fit the ${aSocket} socket — they are drop-in compatible with the same motherboards.`
    : a.type === "cpu" && aSocket && bSocket && aSocket !== bSocket
    ? `These CPUs use different sockets (${aSocket} vs ${bSocket}) and require separate motherboards.`
    : a.type === "gpu"
    ? `Both are standard PCIe x16 cards and will seat in any full-size ATX, mATX, or ITX board with a PCIe x16 slot.`
    : null;

function buyHref(sku: string, asin: string | null): string {
  if (asin) return `https://www.amazon.com/dp/${asin}/?tag=crosspec20-20&ascsubtag=compare`;
  return `/go/${VERTICAL}/${sku}?ref=compare`;
}
const aBuyHref = buyHref(aSku, aAsin);
const bBuyHref = buyHref(bSku, bAsin);

const compareJsonLd = {
  "@context": "https://schema.org/",
  "@type": "ItemList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: a.name, url: `https://crosspec.com/${VERTICAL}/devices/${aSku}/` },
    { "@type": "ListItem", position: 2, name: b.name, url: `https://crosspec.com/${VERTICAL}/devices/${bSku}/` },
  ],
};
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(compareJsonLd)} />

<Layout
  title={pageTitle}
  description={description}
  crumbs={[VERTICAL, "compare", `${aSku}-vs-${bSku}`]}
  kbStatus={`kb v0.1 · ${kb.entities.length} entities`}
>
  <section class="cmp-page">
    <p class="eyebrow">
      <a href={`/${VERTICAL}/`}>{VERTICAL}</a>
      <span class="sep">›</span>
      <span>compare</span>
    </p>
    <h1 class="cmp-title">{a.name} <span class="vs">vs</span> {b.name}</h1>
    <p class="lede">Quick side-by-side: socket, performance, power, and price. Both are {typeLabel}s.{compatNote ? ` ${compatNote}` : ""} Specs sourced from vendor datasheets.</p>

    <table class="cmp-table">
      <thead>
        <tr>
          <th></th>
          <th>
            <a class="cmp-col-link" href={`/${VERTICAL}/devices/${aSku}/`}>{a.name}</a>
          </th>
          <th>
            <a class="cmp-col-link" href={`/${VERTICAL}/devices/${bSku}/`}>{b.name}</a>
          </th>
        </tr>
      </thead>
      <tbody>
        {specs.map((row) => (
          <tr>
            <th class="rkey">{row.k}</th>
            <td>{row.aV}</td>
            <td>{row.bV}</td>
          </tr>
        ))}
      </tbody>
    </table>

    {(aAttrsT.note || bAttrsT.note) && (
      <div class="cmp-notes">
        {aAttrsT.note && (
          <div class="cmp-note">
            <h3>{a.name} · what to know</h3>
            <p>{String(aAttrsT.note)}</p>
          </div>
        )}
        {bAttrsT.note && (
          <div class="cmp-note">
            <h3>{b.name} · what to know</h3>
            <p>{String(bAttrsT.note)}</p>
          </div>
        )}
      </div>
    )}

    <div class="cmp-cta">
      <a class="cta" href={aBuyHref} target="_blank" rel="sponsored nofollow noopener">
        <span>Open {a.name} on Amazon</span>
        <span class="arr" aria-hidden="true">→</span>
      </a>
      <a class="cta" href={bBuyHref} target="_blank" rel="sponsored nofollow noopener">
        <span>Open {b.name} on Amazon</span>
        <span class="arr" aria-hidden="true">→</span>
      </a>
    </div>

    <p class="disclosure">
      crosspec is an Amazon Associate. Prices last verified 2026-05-05. Compatibility claims sourced from each vendor's product catalog and datasheets; see the device pages above for full citations.
    </p>
  </section>
</Layout>

<style is:global>
  .cmp-page { max-width: 940px; margin: 0 auto; padding: 28px 24px 80px; }
  .eyebrow { font-family: var(--mono); font-size: 12px; color: var(--ink-3); margin: 0 0 12px; }
  .eyebrow a { color: var(--ink-2); text-decoration: none; }
  .eyebrow a:hover { color: var(--ink-0); text-decoration: underline; }
  .eyebrow .sep { margin: 0 6px; opacity: 0.5; }
  .cmp-title {
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 10px;
    text-wrap: balance;
  }
  .cmp-title .vs {
    font-family: var(--mono);
    font-size: 18px;
    color: var(--ink-3);
    font-weight: 500;
    margin: 0 6px;
    text-transform: lowercase;
  }
  .lede { color: var(--ink-2); font-size: 15px; line-height: 1.55; max-width: 720px; margin: 0 0 22px; }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--paper-0);
    border: 1px solid var(--paper-edge);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 24px;
  }
  .cmp-table th, .cmp-table td {
    padding: 12px 16px;
    text-align: left;
    vertical-align: top;
    border-top: 1px solid var(--paper-edge);
    font-size: 14px;
  }
  .cmp-table thead th { font-size: 14.5px; background: var(--paper-1); }
  .cmp-table thead th:first-child { width: 18%; }
  .cmp-col-link { color: var(--ink-0); text-decoration: none; }
  .cmp-col-link:hover { text-decoration: underline; text-underline-offset: 3px; }
  .rkey { font-family: var(--mono); font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--ink-2); font-weight: 600; }
  .cmp-notes { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
  @media (max-width: 700px) { .cmp-notes { grid-template-columns: 1fr; } }
  .cmp-note { background: var(--paper-1); border: 1px solid var(--paper-edge); border-radius: 8px; padding: 14px 16px; }
  .cmp-note h3 { font-size: 14px; margin: 0 0 6px; color: var(--ink-0); }
  .cmp-note p { font-size: 13.5px; line-height: 1.55; color: var(--ink-1); margin: 0; }
  .cmp-cta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 30px;
  }
  @media (max-width: 700px) { .cmp-cta { grid-template-columns: 1fr; } }
  .cmp-cta .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 22px;
    background: oklch(0.50 0.14 240);
    color: var(--paper-0);
    border-radius: 7px;
    font-weight: 700;
    font-size: 14.5px;
    text-decoration: none;
    box-shadow: 0 2px 0 oklch(0.37 0.14 240);
    transition: transform .12s, box-shadow .12s;
  }
  .cmp-cta .cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 3px 0 oklch(0.37 0.14 240), 0 6px 14px -4px oklch(0.34 0.12 240 / 0.55);
  }
  .disclosure { font-size: 12px; color: var(--ink-3); line-height: 1.5; margin-top: 24px; border-top: 1px solid var(--paper-edge); padding-top: 14px; }
</style>
