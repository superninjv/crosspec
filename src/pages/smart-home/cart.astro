---
import Layout from "@engine/ui/Layout.astro";
import type { KnowledgeBase } from "@engine/solver";
import kbRaw from "@verticals/smart-home/kb.json";

const kb = kbRaw as KnowledgeBase;
const VERTICAL = "smart-home";

// Embed a slim id → {name, brand, model, price} index for client-side lookup.
const slim = kb.entities.map((e) => ({
  id: e.id,
  sku: e.sku ?? e.id,
  name: e.name,
  type: e.type,
  brand: (e.attributes.brand ?? "") as string,
  model: (e.attributes.model ?? "") as string,
  price: typeof e.attributes.price_usd === "number" ? (e.attributes.price_usd as number) : null,
}));
const slimJSON = JSON.stringify(slim);
---

<Layout
  title="Your build — crosspec smart home"
  description="Open each selected product on Amazon to add it to your cart. crosspec earns a commission at no extra cost to you."
>
  <main class="cart-wrap">
    <header class="cart-head">
      <a class="back" href="/smart-home/">&larr; back to configurator</a>
      <h1>Your build</h1>
      <p class="subtitle" id="cart-subtitle">Open each product below on Amazon and add it to your cart. crosspec earns a small commission on each purchase &mdash; no extra cost to you.</p>
      <div class="cart-totals">
        <span class="t-label">build total</span>
        <span class="t-amount" id="cart-amount">$0</span>
        <span class="t-meta" id="cart-meta">0 picks</span>
      </div>
    </header>

    <section class="cart-list" id="cart-list">
      <p class="cart-empty">Loading your build&hellip;</p>
    </section>

    <p class="disclosure">
      crosspec.com participates in the Amazon Associates program. As an Amazon Associate we earn from qualifying purchases. Prices shown are last verified 2026-05-05 and may change &mdash; click through to confirm.
    </p>
  </main>
</Layout>

<script id="kb-slim" type="application/json" set:html={slimJSON} />

<script>
  type Slim = {
    id: string;
    sku: string;
    name: string;
    type: string;
    brand: string;
    model: string;
    price: number | null;
  };

  const VERTICAL = "smart-home";
  const dataEl = document.getElementById("kb-slim");
  const slim: Slim[] = dataEl ? JSON.parse(dataEl.textContent ?? "[]") : [];
  const bySku = new Map<string, Slim>();
  for (const s of slim) {
    bySku.set(s.sku, s);
    bySku.set(s.id, s);
  }

  const params = new URLSearchParams(location.search);
  const skuParam = params.get("skus") ?? "";
  const ref = params.get("ref") ?? "cart";
  const wanted = skuParam
    .split(",")
    .map((s) => s.trim())
    .filter(Boolean);

  const list = document.getElementById("cart-list");
  const amountEl = document.getElementById("cart-amount");
  const metaEl = document.getElementById("cart-meta");
  const subtitleEl = document.getElementById("cart-subtitle");

  if (!list || !amountEl || !metaEl) {
    // Should never happen
  } else if (wanted.length === 0) {
    list.innerHTML =
      '<p class="cart-empty">No products selected. <a href="/smart-home/">Go back to the configurator</a> and tick the products you want.</p>';
    if (subtitleEl) subtitleEl.style.display = "none";
  } else {
    const found = wanted.map((s) => bySku.get(s)).filter((x): x is Slim => Boolean(x));
    let total = 0;
    for (const s of found) total += s.price ?? 0;
    amountEl.textContent = total > 0 ? `$${Math.round(total)}` : "no price tracked";
    metaEl.textContent = `${found.length} ${found.length === 1 ? "pick" : "picks"}`;

    list.innerHTML = found
      .map((s) => {
        const refQs = `?ref=${encodeURIComponent(ref)}`;
        const goHref = `/go/${VERTICAL}/${s.sku}${refQs}`;
        const detailHref = `/${VERTICAL}/devices/${s.sku}/`;
        const sub = [s.brand, s.model].filter(Boolean).join(" · ");
        const priceTxt = s.price != null ? `$${s.price}` : "&mdash;";
        return `<article class="cart-row">
        <div class="cart-info">
          <a class="cart-title" href="${detailHref}">${escapeHtml(s.name)}</a>
          <div class="cart-sub">${escapeHtml(sub)}</div>
        </div>
        <div class="cart-price">${priceTxt}</div>
        <a class="cart-buy" href="${goHref}" target="_blank" rel="sponsored nofollow noopener">
          <span>Open on Amazon</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      </article>`;
      })
      .join("");
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }
</script>

<style is:global>
  .cart-wrap {
    max-width: 880px;
    margin: 0 auto;
    padding: 36px 24px 80px;
  }
  .cart-head { margin-bottom: 28px; }
  .back {
    display: inline-block;
    color: var(--ink-3);
    text-decoration: none;
    font-family: var(--mono);
    font-size: 12.5px;
    margin-bottom: 12px;
  }
  .back:hover { color: var(--ink-1); }
  .cart-head h1 {
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
    color: var(--ink-0);
  }
  .subtitle {
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.5;
    margin: 0 0 18px;
    max-width: 640px;
  }
  .cart-totals {
    display: inline-flex;
    align-items: baseline;
    gap: 14px;
    background: var(--paper-1);
    border: 1px solid var(--paper-edge);
    padding: 12px 18px;
    border-radius: 8px;
  }
  .cart-totals .t-label {
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 11px;
    color: var(--ink-3);
  }
  .cart-totals .t-amount {
    font-family: var(--mono);
    font-size: 26px;
    font-weight: 700;
    color: var(--ink-0);
  }
  .cart-totals .t-meta {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink-2);
  }

  .cart-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .cart-empty {
    text-align: center;
    color: var(--ink-3);
    padding: 40px 0;
    font-size: 15px;
  }
  .cart-empty a { color: var(--ink-0); }

  .cart-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 18px;
    align-items: center;
    background: var(--paper-0);
    border: 1px solid var(--paper-edge);
    border-radius: 10px;
    padding: 14px 18px;
    transition: border-color .12s, box-shadow .12s;
  }
  .cart-row:hover {
    border-color: var(--ink-4);
    box-shadow: 0 4px 14px oklch(0.20 0.02 250 / 0.05);
  }
  .cart-info { min-width: 0; }
  .cart-title {
    display: block;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink-0);
    text-decoration: none;
    line-height: 1.25;
    letter-spacing: -0.012em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cart-title:hover {
    text-decoration: underline;
    text-decoration-color: var(--ink-3);
    text-underline-offset: 3px;
  }
  .cart-sub {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-3);
    margin-top: 2px;
  }
  .cart-price {
    font-family: var(--mono);
    font-size: 17px;
    font-weight: 700;
    color: var(--ink-0);
    min-width: 70px;
    text-align: right;
  }
  .cart-buy {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: oklch(0.62 0.18 35);
    color: var(--paper-0);
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    box-shadow: 0 2px 0 oklch(0.45 0.18 35);
    transition: transform .12s, box-shadow .12s;
  }
  .cart-buy:hover {
    transform: translateY(-1px);
    box-shadow: 0 3px 0 oklch(0.45 0.18 35), 0 6px 14px -4px oklch(0.40 0.15 35 / 0.55);
  }
  .cart-buy:active { transform: translateY(1px); box-shadow: 0 1px 0 oklch(0.45 0.18 35); }

  .disclosure {
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.5;
    margin-top: 36px;
    border-top: 1px solid var(--paper-edge);
    padding-top: 18px;
  }

  @media (max-width: 640px) {
    .cart-row { grid-template-columns: 1fr auto; }
    .cart-buy { grid-column: 1 / -1; justify-content: center; }
  }
</style>
