---
import Layout from "@engine/ui/Layout.astro";
import ConfiguratorShell from "@engine/ui/ConfiguratorShell.astro";
import { solve } from "@engine/solver";
import type { KnowledgeBase } from "@engine/solver";
import kbRaw from "@verticals/smart-home/kb.json";

const kb = kbRaw as KnowledgeBase;

const [solution] = solve(kb, {
  ecosystem: "homekit",
  wants: ["smart_bulb", "motion_sensor"],
  picks_per_type: 3,
});

const headline = "Smart Home Compatibility Configurator";
const subheadline =
  "Tell us your ecosystem and what you want to add. We'll pick compatible devices and show exactly why they work.";
const examples = [
  "I'm on Apple HomeKit and want a motion sensor and a smart bulb",
  "I want Matter-over-Thread devices that work with Home Assistant",
  "What's the cheapest way into Zigbee without committing to Philips Hue",
];
---
<Layout title={headline} description={subheadline}>
  <ConfiguratorShell
    vertical="smart-home"
    headline={headline}
    subheadline={subheadline}
    examples={examples}
    solution={solution}
  />
</Layout>
