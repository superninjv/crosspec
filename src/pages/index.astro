---
import Layout from "@engine/ui/Layout.astro";
import type { KnowledgeBase } from "@engine/solver";
import smartHomeKb from "@verticals/smart-home/kb.json";
import solarKb from "@verticals/solar/kb.json";
import keyboardsKb from "@verticals/keyboards/kb.json";
import arduinoKb from "@verticals/arduino/kb.json";
import threedPrinterKb from "@verticals/3d-printer/kb.json";
import cncKb from "@verticals/cnc/kb.json";
import pcKb from "@verticals/pc/kb.json";
import pedalboardKb from "@verticals/pedalboard/kb.json";
import headphonesKb from "@verticals/headphones/kb.json";
import speakersKb from "@verticals/speakers/kb.json";
import carAudioKb from "@verticals/car-audio/kb.json";

interface Vertical {
  slug: string;
  name: string;
  blurb: string;
  pitch: string;
  count: number;
  accent: string;
  status: "live" | "soon";
}

const ICONS: Record<string, string> = {
  "smart-home": `<svg class="vi vi-smart-home" viewBox="0 0 32 32" width="32" height="32">
    <path class="vi-house" d="M5 14 L16 5 L27 14 V26 Q27 28 25 28 H7 Q5 28 5 26 Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    <circle class="vi-pulse vi-pulse-1" cx="16" cy="18" r="2" fill="currentColor"/>
    <circle class="vi-pulse vi-pulse-2" cx="16" cy="18" r="4" fill="none" stroke="currentColor" stroke-width="1.2"/>
    <circle class="vi-pulse vi-pulse-3" cx="16" cy="18" r="6" fill="none" stroke="currentColor" stroke-width="1"/>
  </svg>`,
  "solar": `<svg class="vi vi-solar" viewBox="0 0 32 32" width="32" height="32">
    <g class="vi-sun-rays">
      <line x1="16" y1="3" x2="16" y2="7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <line x1="16" y1="25" x2="16" y2="29" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <line x1="3" y1="16" x2="7" y2="16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <line x1="25" y1="16" x2="29" y2="16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <line x1="6.5" y1="6.5" x2="9.5" y2="9.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="22.5" y1="22.5" x2="25.5" y2="25.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="6.5" y1="25.5" x2="9.5" y2="22.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="22.5" y1="9.5" x2="25.5" y2="6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </g>
    <circle cx="16" cy="16" r="5" fill="currentColor"/>
  </svg>`,
  "keyboards": `<svg class="vi vi-keyboards" viewBox="0 0 32 32" width="32" height="32">
    <rect x="4" y="11" width="24" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.6"/>
    <rect class="vi-key vi-key-1" x="7" y="14" width="4" height="3" rx="0.6" fill="currentColor"/>
    <rect class="vi-key vi-key-2" x="14" y="14" width="4" height="3" rx="0.6" fill="currentColor"/>
    <rect class="vi-key vi-key-3" x="21" y="14" width="4" height="3" rx="0.6" fill="currentColor"/>
    <rect x="7" y="19" width="18" height="3" rx="0.6" fill="currentColor" opacity="0.45"/>
  </svg>`,
  "arduino": `<svg class="vi vi-arduino" viewBox="0 0 32 32" width="32" height="32">
    <rect x="6" y="11" width="20" height="10" rx="1" fill="none" stroke="currentColor" stroke-width="1.6"/>
    <line x1="9" y1="11" x2="9" y2="9" stroke="currentColor" stroke-width="1.4"/>
    <line x1="13" y1="11" x2="13" y2="9" stroke="currentColor" stroke-width="1.4"/>
    <line x1="17" y1="11" x2="17" y2="9" stroke="currentColor" stroke-width="1.4"/>
    <line x1="21" y1="11" x2="21" y2="9" stroke="currentColor" stroke-width="1.4"/>
    <line x1="9" y1="21" x2="9" y2="23" stroke="currentColor" stroke-width="1.4"/>
    <line x1="13" y1="21" x2="13" y2="23" stroke="currentColor" stroke-width="1.4"/>
    <line x1="17" y1="21" x2="17" y2="23" stroke="currentColor" stroke-width="1.4"/>
    <line x1="21" y1="21" x2="21" y2="23" stroke="currentColor" stroke-width="1.4"/>
    <circle class="vi-led" cx="22" cy="16" r="2" fill="currentColor"/>
  </svg>`,
  "3d-printer": `<svg class="vi vi-3d-printer" viewBox="0 0 32 32" width="32" height="32">
    <line x1="3" y1="9" x2="29" y2="9" stroke="currentColor" stroke-width="1.6"/>
    <g class="vi-nozzle">
      <rect x="14" y="9" width="4" height="5" fill="currentColor"/>
      <polygon points="13,14 19,14 17,17 15,17" fill="currentColor"/>
    </g>
    <rect x="5" y="22" width="22" height="4" rx="1" fill="none" stroke="currentColor" stroke-width="1.4"/>
    <line x1="8" y1="22" x2="8" y2="20" stroke="currentColor" stroke-width="1.2" opacity="0.6"/>
    <line x1="16" y1="22" x2="16" y2="20" stroke="currentColor" stroke-width="1.2" opacity="0.6"/>
    <line x1="24" y1="22" x2="24" y2="20" stroke="currentColor" stroke-width="1.2" opacity="0.6"/>
  </svg>`,
  "cnc": `<svg class="vi vi-cnc" viewBox="0 0 32 32" width="32" height="32">
    <rect x="4" y="22" width="24" height="4" rx="1" fill="none" stroke="currentColor" stroke-width="1.4"/>
    <g class="vi-spindle" style="transform-origin: 16px 14px;">
      <rect x="13" y="6" width="6" height="8" fill="currentColor"/>
      <polygon points="13,14 19,14 17,18 15,18" fill="currentColor"/>
    </g>
    <line x1="16" y1="18" x2="16" y2="22" stroke="currentColor" stroke-width="1" opacity="0.5"/>
  </svg>`,
  "pc": `<svg class="vi vi-pc" viewBox="0 0 32 32" width="32" height="32">
    <rect x="9" y="3" width="14" height="26" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.6"/>
    <g class="vi-fan" style="transform-origin: 16px 16px;">
      <circle cx="16" cy="16" r="6" fill="none" stroke="currentColor" stroke-width="1"/>
      <path d="M16 10 Q19 12 16 16 Z" fill="currentColor"/>
      <path d="M22 16 Q20 19 16 16 Z" fill="currentColor"/>
      <path d="M16 22 Q13 20 16 16 Z" fill="currentColor"/>
      <path d="M10 16 Q12 13 16 16 Z" fill="currentColor"/>
    </g>
    <circle cx="16" cy="6" r="0.8" fill="currentColor"/>
  </svg>`,
};

const smartHome = smartHomeKb as KnowledgeBase;
const solar = solarKb as KnowledgeBase;
const keyboards = keyboardsKb as KnowledgeBase;
const arduino = arduinoKb as KnowledgeBase;
const threedPrinter = threedPrinterKb as KnowledgeBase;
const cnc = cncKb as KnowledgeBase;
const pc = pcKb as KnowledgeBase;
const pedalboard = pedalboardKb as KnowledgeBase;
const headphones = headphonesKb as KnowledgeBase;
const speakers = speakersKb as KnowledgeBase;
const carAudio = carAudioKb as KnowledgeBase;

const verticals: Vertical[] = [
  {
    slug: "smart-home",
    name: "Smart home",
    blurb: "Matter / Thread / Zigbee / HomeKit / Google / Alexa / HA",
    pitch: "Pick devices that match your ecosystem. Hubs auto-included. Per-pick checkboxes for build cost. Sources cited.",
    count: smartHome.entities.length,
    accent: "oklch(0.55 0.13 145)",
    status: "live",
  },
  {
    slug: "solar",
    name: "Solar + battery",
    blurb: "Panels, inverters, charge controllers, batteries, power stations",
    pitch: "Match panel Voc to controller, battery chemistry to charge profile, inverter watts to BMS amp limits.",
    count: solar.entities.length,
    accent: "oklch(0.62 0.16 70)",
    status: "live",
  },
  {
    slug: "keyboards",
    name: "Mechanical keyboards",
    blurb: "Kits, switches, keycaps, plates, stabs, PCBs",
    pitch: "Stabs that match the cutout. Keycaps that cover the layout. Switches that fit your hotswap sockets.",
    count: keyboards.entities.length,
    accent: "oklch(0.50 0.16 280)",
    status: "live",
  },
  {
    slug: "arduino",
    name: "Arduino + embedded",
    blurb: "Microcontrollers, sensors, displays, motors, power",
    pitch: "Logic-voltage match. I2C address conflicts. Current budget. LiPo + charger combos.",
    count: arduino.entities.length,
    accent: "oklch(0.50 0.13 200)",
    status: "live",
  },
  {
    slug: "3d-printer",
    name: "3D printers + filament",
    blurb: "Printers, filament, hotends, nozzles, build surfaces",
    pitch: "Hardened nozzle for carbon fiber. Enclosure for ABS / ASA. Direct-drive for TPU.",
    count: threedPrinter.entities.length,
    accent: "oklch(0.55 0.13 30)",
    status: "live",
  },
  {
    slug: "cnc",
    name: "CNC routers",
    blurb: "Machines, spindles, bits, fixtures, dust shoes",
    pitch: "Match collet to bit shank, spindle mount to machine, dust shoe to router diameter.",
    count: cnc.entities.length,
    accent: "oklch(0.45 0.06 250)",
    status: "live",
  },
  {
    slug: "pc",
    name: "PC build",
    blurb: "CPUs, GPUs, motherboards, RAM, PSUs, cases, coolers, storage",
    pitch: "Socket compat, RAM speed limits, PSU wattage, GPU and cooler clearance.",
    count: pc.entities.length,
    accent: "oklch(0.50 0.14 240)",
    status: "live",
  },
  {
    slug: "pedalboard",
    name: "Guitar pedalboard",
    blurb: "Pedals, boards, power supplies, patch cables, tuners",
    pitch: "Power supply current vs pedal draw. Isolated outputs for digital pedals. Patch cable count.",
    count: pedalboard.entities.length,
    accent: "oklch(0.45 0.18 30)",
    status: "live",
  },
  {
    slug: "headphones",
    name: "Headphones + IEMs",
    blurb: "Open / closed cans, IEMs, DAC / amps, cables",
    pitch: "Sensitivity vs amp output. Balanced cable termination. Universal IEM ear-tip fit.",
    count: headphones.entities.length,
    accent: "oklch(0.40 0.10 280)",
    status: "live",
  },
  {
    slug: "speakers",
    name: "Home audio",
    blurb: "Bookshelf, floorstanding, subs, AVRs, stereo amps, streamers",
    pitch: "Amp wattage matched to speaker spec, sub crossover, AVR vs integrated tradeoffs.",
    count: speakers.entities.length,
    accent: "oklch(0.45 0.10 200)",
    status: "live",
  },
  {
    slug: "car-audio",
    name: "Car audio",
    blurb: "Head units, components, coaxials, subs, amps, wiring",
    pitch: "Amp power matched to speaker RMS. Wiring gauge for current draw. Head-unit preouts.",
    count: carAudio.entities.length,
    accent: "oklch(0.42 0.16 25)",
    status: "live",
  },
];

const totalLive = verticals.filter((v) => v.status === "live").reduce((a, v) => a + v.count, 0);
const liveCount = verticals.filter((v) => v.status === "live").length;
---
<Layout
  title="crosspec · configurators that pick parts that actually work together"
  description={`${totalLive.toLocaleString()}+ products with sourced compatibility data across smart home, solar, keyboards, and Arduino. No signup, no ads, no tracking.`}
  kbStatus={`${totalLive}+ products · ${liveCount} live verticals`}
>
  <section class="home-hero">
    <div class="hero-inner">
      <p class="eyebrow">crosspec · configurators</p>
      <h1>Pick parts that <em>actually work together.</em></h1>
      <p class="lede">{totalLive.toLocaleString()} products with sourced compatibility data. No signup, no ads, no tracking.</p>
      <div class="hero-meta">
        <span><strong>{totalLive.toLocaleString()}</strong> products</span>
        <span class="dot" aria-hidden="true">·</span>
        <span><strong>{liveCount}</strong> live verticals</span>
        <span class="dot" aria-hidden="true">·</span>
        <span>tools, not articles</span>
      </div>
    </div>
  </section>

  <section class="verticals">
    <div class="verticals-inner">
      <ul class="vert-grid">
        {verticals.map((v) => (
          <li class={`vert-card ${v.status}`} style={`--accent: ${v.accent}`}>
            <a href={v.status === "live" ? `/${v.slug}/` : "#"} class="vc-link" aria-disabled={v.status === "soon"}>
              <span class="vc-icon" aria-hidden="true" set:html={ICONS[v.slug] ?? ""} />
              <span class="vc-status">{v.status === "live" ? "live" : "coming online"}</span>
              <h2>{v.name}</h2>
              <p class="vc-blurb">{v.blurb}</p>
              <p class="vc-pitch">{v.pitch}</p>
              <p class="vc-cta">
                {v.status === "live" ? <>Open configurator <span aria-hidden="true">→</span></> : <>Soon</>}
              </p>
              {v.status === "live" && (
                <p class="vc-count">{v.count} products</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="why">
    <div class="why-inner">
      <h2>Why crosspec exists</h2>
      <div class="why-cols">
        <div>
          <h3>Configurators, not buying guides.</h3>
          <p>Every page is an interactive tool that filters real products against real constraints. No "best X of 2026" listicles, no AI-generated copy padding.</p>
        </div>
        <div>
          <h3>Sources cited per claim.</h3>
          <p>When a product page says "works with HomeKit via Matter" you can click through to the registry entry with the ingest date. The data layer is the moat.</p>
        </div>
        <div>
          <h3>One revenue model, disclosed.</h3>
          <p>Amazon Associates affiliate links. That's it. No ads, no signup, no tracking cookies, no email capture. Direct buy works fine if you'd rather skip the kickback.</p>
        </div>
        <div>
          <h3>Open data.</h3>
          <p>The KBs are <a href="https://github.com/superninjv/crosspec" rel="noopener" target="_blank">on GitHub</a> under MIT for code and CC-BY-4.0 for data. Cite + redistribute. PRs that fix wrong mappings are welcome.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .home-hero {
    background:
      radial-gradient(1200px 500px at 50% -200px, oklch(0.92 0.04 145 / 0.55), transparent 60%),
      var(--paper-0);
    border-bottom: 1px solid var(--paper-edge);
    padding: 72px 24px 60px;
  }
  .hero-inner { max-width: 980px; margin: 0 auto; text-align: center; }
  .home-hero .eyebrow {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 16px;
  }
  .home-hero h1 {
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 700;
    margin: 0 0 18px;
    color: var(--ink-0);
    text-wrap: balance;
  }
  .home-hero h1 em {
    font-style: normal;
    background: linear-gradient(120deg, oklch(0.45 0.13 145), oklch(0.50 0.16 240));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }
  .home-hero .lede {
    font-size: 17px;
    color: var(--ink-2);
    line-height: 1.55;
    max-width: 740px;
    margin: 0 auto 22px;
  }
  .hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ink-2);
    background: var(--paper-1);
    border: 1px solid var(--paper-edge);
    padding: 8px 18px;
    border-radius: 99px;
  }
  .hero-meta strong { font-weight: 700; color: var(--ink-0); }
  .hero-meta .dot { opacity: 0.45; }

  .verticals { padding: 56px 24px 36px; }
  .verticals-inner { max-width: 1180px; margin: 0 auto; }
  .vert-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
  }
  .vert-card { display: block; }
  .vc-link {
    display: block;
    padding: 22px 22px 18px;
    background: var(--paper-0);
    border: 1px solid var(--paper-edge);
    border-radius: 12px;
    text-decoration: none;
    color: var(--ink-0);
    height: 100%;
    position: relative;
    transition: border-color .15s, box-shadow .15s, transform .15s;
  }
  .vert-card.live .vc-link:hover {
    border-color: var(--accent);
    box-shadow: 0 6px 22px -8px var(--accent);
    transform: translateY(-2px);
  }
  .vert-card.soon .vc-link {
    opacity: 0.65;
    pointer-events: none;
  }
  .vc-status {
    display: inline-block;
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 99px;
    background: var(--paper-2);
    color: var(--ink-2);
    margin-bottom: 12px;
  }
  .vert-card.live .vc-status {
    background: oklch(0.93 0.05 145);
    color: oklch(0.32 0.10 145);
  }
  .vc-link h2 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.012em;
    margin: 0 0 4px;
    color: var(--ink-0);
  }
  .vc-blurb {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ink-3);
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.4;
  }
  .vc-pitch {
    font-size: 14px;
    color: var(--ink-1);
    line-height: 1.5;
    margin: 0 0 16px;
  }
  .vc-cta {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 6px;
  }
  .vc-count {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    margin: 0;
  }

  .vc-icon {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 32px;
    height: 32px;
    color: var(--accent);
    opacity: 0.85;
    pointer-events: none;
  }
  .vert-card.soon .vc-icon { opacity: 0.4; }
  .vc-icon svg { display: block; width: 100%; height: 100%; overflow: visible; }

  .vert-card.live .vc-link:hover .vi-pulse-1 { animation: vi-pulse 1.6s ease-out infinite; }
  .vert-card.live .vc-link:hover .vi-pulse-2 { animation: vi-pulse 1.6s ease-out 0.25s infinite; }
  .vert-card.live .vc-link:hover .vi-pulse-3 { animation: vi-pulse 1.6s ease-out 0.5s infinite; }
  @keyframes vi-pulse {
    0% { opacity: 1; transform: scale(0.4); transform-origin: 16px 18px; }
    100% { opacity: 0; transform: scale(1.5); transform-origin: 16px 18px; }
  }

  .vi-sun-rays { transform-origin: 16px 16px; transform-box: fill-box; }
  .vert-card.live .vc-link:hover .vi-sun-rays { animation: vi-rotate-slow 8s linear infinite; }
  @keyframes vi-rotate-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .vert-card.live .vc-link:hover .vi-key-1 { animation: vi-keypress 1.2s ease-in-out infinite; }
  .vert-card.live .vc-link:hover .vi-key-2 { animation: vi-keypress 1.2s ease-in-out 0.2s infinite; }
  .vert-card.live .vc-link:hover .vi-key-3 { animation: vi-keypress 1.2s ease-in-out 0.4s infinite; }
  @keyframes vi-keypress {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(1.5px); opacity: 0.7; }
  }

  .vert-card.live .vc-link:hover .vi-led { animation: vi-blink 1.4s ease-in-out infinite; }
  @keyframes vi-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  .vi-nozzle { transform-box: fill-box; }
  .vert-card.live .vc-link:hover .vi-nozzle,
  .vert-card.soon .vc-link .vi-nozzle { animation: vi-shuttle 2.4s ease-in-out infinite; }
  @keyframes vi-shuttle {
    0%, 100% { transform: translateX(-7px); }
    50% { transform: translateX(7px); }
  }

  .vert-card.soon .vc-link .vi-spindle { animation: vi-rotate-slow 4s linear infinite; }
  .vert-card.soon .vc-link .vi-fan { animation: vi-rotate-slow 3s linear infinite; }

  @media (prefers-reduced-motion: reduce) {
    .vi-pulse-1, .vi-pulse-2, .vi-pulse-3,
    .vi-sun-rays, .vi-key-1, .vi-key-2, .vi-key-3,
    .vi-led, .vi-nozzle, .vi-spindle, .vi-fan {
      animation: none !important;
    }
  }

  .why {
    padding: 36px 24px 80px;
    border-top: 1px solid var(--paper-edge);
    background: var(--paper-1);
  }
  .why-inner { max-width: 1100px; margin: 0 auto; }
  .why-inner > h2 {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.012em;
    margin: 0 0 22px;
    color: var(--ink-0);
  }
  .why-cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 22px;
  }
  .why-cols h3 {
    font-size: 15px;
    font-weight: 700;
    margin: 0 0 6px;
    color: var(--ink-0);
  }
  .why-cols p {
    font-size: 14px;
    color: var(--ink-1);
    line-height: 1.55;
    margin: 0;
  }
  .why-cols a { color: var(--ink-1); text-underline-offset: 2px; }
</style>
