---
import Layout from "@engine/ui/Layout.astro";
import type { KnowledgeBase } from "@engine/solver";
import kbRaw from "@verticals/solar/kb.json";

const kb = kbRaw as KnowledgeBase;

const TYPE_LABEL: Record<string, { label: string; blurb: string }> = {
  solar_panel: {
    label: "Solar panels",
    blurb: "Rigid, flexible, and portable monocrystalline panels from 100W to 400W.",
  },
  inverter: {
    label: "Inverters",
    blurb: "Pure sine wave inverters sized for off-grid, hybrid, and grid-tied use.",
  },
  solar_charge_controller: {
    label: "Charge controllers",
    blurb: "MPPT and PWM controllers matched to your panel array and battery bank.",
  },
  battery: {
    label: "Batteries",
    blurb: "LiFePO4 deep-cycle batteries, drop-in 12V/24V/48V banks.",
  },
  power_station: {
    label: "Power stations",
    blurb: "All-in-one solar generators with built-in inverter, MPPT, and battery.",
  },
  solar_mounting: {
    label: "Mounting hardware",
    blurb: "Z-brackets, ground mounts, RV-roof tilt mounts, and rail systems.",
  },
  solar_cable_kit: {
    label: "Cables & accessories",
    blurb: "MC4 connectors, branch splitters, fuses, and gauge-rated DC cabling.",
  },
};

const TYPE_ORDER = [
  "solar_panel",
  "battery",
  "inverter",
  "solar_charge_controller",
  "power_station",
  "solar_mounting",
  "solar_cable_kit",
];

const byType = new Map<string, typeof kb.entities>();
for (const e of kb.entities) {
  if (!byType.has(e.type)) byType.set(e.type, []);
  byType.get(e.type)!.push(e);
}
---
<Layout
  title="Solar component compatibility — panels, inverters, batteries, controllers | crosspec"
  description="Browse 140+ solar components with compatibility data. Match panels to charge controllers, inverters to battery banks, and avoid the dumb mistakes that torch a build."
  crumbs={["solar"]}
  kbStatus={`solar v0.1 · ${kb.entities.length} entities`}
>
  <section class="solar-hero">
    <div class="solar-hero-inner">
      <p class="eyebrow">crosspec / solar</p>
      <h1>Pick solar components that <em>actually work together.</em></h1>
      <p class="lede">{kb.entities.length} components across {TYPE_ORDER.length} categories. Every spec sourced from the manufacturer datasheet, with the cold-temperature Voc derate, BMS amp limits, and panel-Voc-vs-MPPT-window quirks people miss.</p>
      <p class="cta-row">
        <a class="cta-primary" href="#solar_panel">Browse panels</a>
        <a class="cta-secondary" href="#battery">Browse batteries</a>
      </p>
    </div>
  </section>

  <div class="solar-page">
    {TYPE_ORDER.map((t) => {
      const ents = byType.get(t) ?? [];
      const meta = TYPE_LABEL[t];
      return (
        <section class="cat-section" id={t}>
          <header class="cat-head">
            <h2>{meta.label}</h2>
            <span class="cat-count">{ents.length} {ents.length === 1 ? "product" : "products"}</span>
          </header>
          <p class="cat-blurb">{meta.blurb}</p>
          <ul class="cat-grid">
            {ents.map((e) => {
              const sku = e.sku ?? e.id;
              const attrs = e.attributes;
              const priceUsd = typeof attrs.price_usd === "number" ? attrs.price_usd : null;
              return (
                <li class="cat-card">
                  <a class="cc-link" href={`/solar/devices/${sku}/`}>
                    <span class="cc-brand">{String(attrs.brand ?? "").replace(/_/g, " ")}</span>
                    <span class="cc-name">{e.name}</span>
                    <span class="cc-price">{priceUsd != null ? `$${priceUsd}` : ""}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      );
    })}
  </div>
</Layout>

<style is:global>
  .solar-hero {
    background: linear-gradient(180deg, oklch(0.96 0.04 80) 0%, var(--paper-1) 100%);
    border-bottom: 1px solid var(--paper-edge);
    padding: 36px 24px 30px;
  }
  .solar-hero-inner { max-width: 1100px; margin: 0 auto; }
  .solar-hero .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 6px;
  }
  .solar-hero h1 {
    font-size: 38px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 14px;
    color: var(--ink-0);
    text-wrap: balance;
    max-width: 800px;
  }
  .solar-hero h1 em { font-style: normal; color: oklch(0.45 0.13 70); }
  .solar-hero .lede {
    font-size: 16px;
    color: var(--ink-2);
    line-height: 1.55;
    max-width: 720px;
    margin: 0 0 18px;
  }
  .solar-hero .cta-row { display: flex; gap: 10px; margin: 0; }
  .cta-primary, .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
  }
  .cta-primary { background: var(--ink-0); color: var(--paper-0); }
  .cta-primary:hover { background: var(--ink-1); }
  .cta-secondary { background: var(--paper-0); color: var(--ink-0); border: 1px solid var(--paper-edge); }
  .cta-secondary:hover { border-color: var(--ink-3); }

  .solar-page { max-width: 1100px; margin: 0 auto; padding: 28px 24px 80px; }
  .cat-section { margin-top: 36px; }
  .cat-section:first-child { margin-top: 0; }
  .cat-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--paper-edge); padding-bottom: 8px; margin-bottom: 6px; }
  .cat-head h2 { font-size: 22px; font-weight: 700; letter-spacing: -0.012em; margin: 0; }
  .cat-count { font-family: var(--mono); font-size: 12px; color: var(--ink-3); }
  .cat-blurb { color: var(--ink-2); font-size: 14px; line-height: 1.5; margin: 0 0 14px; max-width: 720px; }
  .cat-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 8px;
  }
  .cat-card .cc-link {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    column-gap: 8px;
    padding: 10px 12px;
    background: var(--paper-0);
    border: 1px solid var(--paper-edge);
    border-radius: 7px;
    text-decoration: none;
    color: var(--ink-0);
    transition: border-color .12s, box-shadow .12s;
  }
  .cat-card .cc-link:hover { border-color: var(--ink-3); box-shadow: 0 3px 10px oklch(0.20 0.02 80 / 0.06); }
  .cc-brand {
    grid-column: 1 / 2;
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-3);
    font-weight: 600;
  }
  .cc-name {
    grid-column: 1 / 2;
    grid-row: 2;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.25;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cc-price {
    grid-column: 2 / 3;
    grid-row: 1 / 3;
    align-self: center;
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--ink-0);
  }
</style>
