---
import Layout from "@engine/ui/Layout.astro";
import type { KnowledgeBase } from "@engine/solver";
import kbRaw from "@verticals/solar/kb.json";
import affRaw from "@verticals/solar/affiliates.json";

const kb = kbRaw as KnowledgeBase;
const VERTICAL = "solar";
const ACCENT = "oklch(0.62 0.16 70)";

interface ProductMap { products: Record<string, { merchant: string; asin?: string }>; }
const aff = affRaw as ProductMap;

const TYPES = [
  { slug: "solar_panel", label: "Solar panels", blurb: "100W to 400W rigid, flexible, and portable." },
  { slug: "battery", label: "Batteries", blurb: "LiFePO4 deep-cycle 12V/24V/48V banks." },
  { slug: "inverter", label: "Inverters", blurb: "Pure sine wave, off-grid + grid-tied." },
  { slug: "solar_charge_controller", label: "Charge controllers", blurb: "MPPT and PWM, 12V/24V/48V auto." },
  { slug: "power_station", label: "Power stations", blurb: "All-in-one solar generators." },
  { slug: "solar_mounting", label: "Mounts", blurb: "Z-bracket, ground mount, RV tilt, rail." },
  { slug: "solar_cable_kit", label: "Cables & accessories", blurb: "MC4, fuses, branch splitters." },
];

const USE_CASES = [
  { slug: "rv_van", label: "RV / van life" },
  { slug: "off_grid_cabin", label: "Off-grid cabin" },
  { slug: "portable", label: "Portable / camping" },
  { slug: "backup", label: "Home backup" },
  { slug: "boat", label: "Boat / marine" },
  { slug: "grid_tied", label: "Grid-tied home" },
];

const slim = kb.entities.map((e) => ({
  id: e.id,
  sku: e.sku ?? e.id,
  name: e.name,
  type: e.type,
  brand: String(e.attributes.brand ?? ""),
  model: String(e.attributes.model ?? ""),
  price: typeof e.attributes.price_usd === "number" ? (e.attributes.price_usd as number) : null,
  note: (e.attributes.note as string) ?? "",
  asin: aff.products[e.id]?.asin ?? aff.products[e.sku ?? e.id]?.asin ?? null,
  attrs: e.attributes,
}));
const slimJSON = JSON.stringify(slim);

const byType = new Map<string, typeof kb.entities>();
for (const e of kb.entities) {
  if (!byType.has(e.type)) byType.set(e.type, []);
  byType.get(e.type)!.push(e);
}
---
<Layout
  title={`Solar configurator · panels, batteries, inverters, controllers · crosspec`}
  description="Build a compatible solar setup. Pick the components you want, see the build total, open everything on Amazon. Sourced specs, no signup."
  crumbs={["solar"]}
  kbStatus={`solar v0.1 · ${kb.entities.length} entities`}
>
  <section class="solar-hero" style={`--accent: ${ACCENT}`}>
    <div class="hero-inner">
      <p class="eyebrow">crosspec / solar</p>
      <h1>Build a solar setup that <em>actually works.</em></h1>
      <p class="lede">{kb.entities.length} components. Match panel Voc to controller, battery chemistry to charge profile, inverter watts to BMS amp limits. Sourced from manufacturer datasheets.</p>
    </div>
  </section>

  <section class="ai-helper" id="ai-helper">
    <div class="ai-inner">
      <div class="ai-head">
        <span class="ai-glyph" aria-hidden="true">⌘</span>
        <span class="ai-title">Describe what you need to power</span>
        <span class="ai-sub">e.g. "1000W irrigation pump for 2 hours a day" or "RV: fridge, lights, charge laptops"</span>
      </div>
      <div class="ai-transcript" id="ai-transcript"></div>
      <form id="ai-form" class="ai-form" autocomplete="off">
        <input type="text" name="q" id="ai-input" placeholder="What are you building?" maxlength="500" required />
        <button type="submit" class="ai-submit" id="ai-submit">Ask <span aria-hidden="true">→</span></button>
      </form>
      <div class="ai-examples">
        <button type="button" class="ai-chip" data-q="Power a 1000W irrigation pump for 2 hours a day, off-grid" data-params='{"load_watts":1000,"runtime_hours_per_day":2,"sun_hours_per_day":4.5,"battery_voltage":24,"use_case":"off_grid_cabin","wants":["solar_panel","battery","inverter","solar_charge_controller","solar_cable_kit"]}'>1000W pump · 2hr/day</button>
        <button type="button" class="ai-chip" data-q="RV setup for a 12V fridge, LED lights, and laptop charging, 24/7" data-params='{"load_watts":150,"runtime_hours_per_day":24,"sun_hours_per_day":4.5,"battery_voltage":12,"use_case":"rv_van","wants":["solar_panel","battery","solar_charge_controller","solar_cable_kit"]}'>RV essentials · 12V</button>
        <button type="button" class="ai-chip" data-q="Backup power for a 600W refrigerator during outages, 8 hours" data-params='{"load_watts":600,"runtime_hours_per_day":8,"sun_hours_per_day":4.5,"battery_voltage":12,"use_case":"backup","wants":["battery","inverter","solar_charge_controller","solar_cable_kit"]}'>Fridge backup · 8hr</button>
        <button type="button" class="ai-chip" data-q="Off-grid cabin: 200W of LED lighting and a 90W laptop, 6 hours/day, 24V system" data-params='{"load_watts":290,"runtime_hours_per_day":6,"sun_hours_per_day":4.5,"battery_voltage":24,"use_case":"off_grid_cabin","wants":["solar_panel","battery","inverter","solar_charge_controller","solar_cable_kit"]}'>Cabin · 24V · 6hr</button>
      </div>
    </div>
  </section>

  <form id="picker-form" class="picker-form">
    <fieldset class="picker-step">
      <legend><span class="step-num">1</span> What's the build for?</legend>
      <div class="chip-row">
        {USE_CASES.map((u, i) => (
          <label class="chip">
            <input type="radio" name="use_case" value={u.slug} checked={i === 0} />
            <span>{u.label}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <fieldset class="picker-step">
      <legend><span class="step-num">2</span> What components do you want?</legend>
      <div class="want-grid">
        {TYPES.map((t) => {
          const ents = byType.get(t.slug) ?? [];
          return (
            <label class="want-tile">
              <input type="checkbox" name="want" value={t.slug} />
              <div class="wt-body">
                <span class="wt-label">{t.label}</span>
                <span class="wt-blurb">{t.blurb}</span>
                <span class="wt-count">{ents.length} options</span>
              </div>
            </label>
          );
        })}
      </div>
    </fieldset>
  </form>

  <section id="picker-result" class="picker-result">
    <p class="picker-empty">Tick a component above to see compatible options.</p>
  </section>

  <section class="build-summary" id="build-summary" hidden>
    <div class="bs-totals">
      <span class="bs-label">build total</span>
      <span class="bs-amount" id="bs-amount">$0</span>
      <span class="bs-meta" id="bs-meta">tick the products you want</span>
    </div>
    <a class="bs-cart disabled" id="bs-cart" href={`/${VERTICAL}/cart/?skus=`} target="_blank">
      <span aria-hidden="true">▣</span>
      <span>Review &amp; checkout</span>
      <span aria-hidden="true">→</span>
    </a>
  </section>

  <details class="all-products">
    <summary>Or browse everything by category</summary>
    <div class="all-inner">
      {TYPES.map((t) => {
        const ents = byType.get(t.slug) ?? [];
        if (ents.length === 0) return null;
        return (
          <section class="cat-section" id={t.slug}>
            <header class="cat-head">
              <h3>{t.label}</h3>
              <span class="cat-count">{ents.length}</span>
            </header>
            <ul class="cat-grid">
              {ents.map((e) => {
                const sku = e.sku ?? e.id;
                const priceUsd = typeof e.attributes.price_usd === "number" ? e.attributes.price_usd : null;
                return (
                  <li class="cat-card">
                    <a class="cc-link" href={`/${VERTICAL}/devices/${sku}/`}>
                      <span class="cc-brand">{String(e.attributes.brand ?? "").replace(/_/g, " ")}</span>
                      <span class="cc-name">{e.name}</span>
                      <span class="cc-price">{priceUsd != null ? `$${priceUsd}` : ""}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </section>
        );
      })}
    </div>
  </details>
</Layout>

<script id="picker-data" type="application/json" set:html={slimJSON} />

<script>
  type Slim = {
    id: string;
    sku: string;
    name: string;
    type: string;
    brand: string;
    model: string;
    price: number | null;
    note: string;
    asin: string | null;
    attrs: Record<string, unknown>;
  };

  const VERTICAL = "solar";
  const dataEl = document.getElementById("picker-data");
  const data: Slim[] = dataEl ? JSON.parse(dataEl.textContent ?? "[]") : [];
  const bySku = new Map(data.map((d) => [d.sku, d]));
  const form = document.getElementById("picker-form") as HTMLFormElement | null;
  const resultEl = document.getElementById("picker-result");
  const buildSummary = document.getElementById("build-summary");

  const selected = new Set<string>();
  const qty = new Map<string, number>(); // sku → quantity
  let lastSizingTargets: { panelW: number; batteryAh: number; inverterW: number; ccA: number; voltage: number } | null = null;

  function escapeHtml(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function renderPicker() {
    if (!form || !resultEl) return;
    const wanted = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="want"]:checked')).map((i) => i.value);
    if (wanted.length === 0) {
      resultEl.innerHTML = '<p class="picker-empty">Tick a component above to see compatible options.</p>';
      buildSummary?.setAttribute("hidden", "");
      return;
    }
    buildSummary?.removeAttribute("hidden");

    const TYPE_LABEL: Record<string, string> = {
      solar_panel: "Solar panels",
      battery: "Batteries",
      inverter: "Inverters",
      solar_charge_controller: "Charge controllers",
      power_station: "Power stations",
      solar_mounting: "Mounts",
      solar_cable_kit: "Cables & accessories",
    };

    let html = "";
    for (const wantType of wanted) {
      const ofType = data.filter((d) => d.type === wantType);
      if (ofType.length === 0) continue;
      html += `<section class="res-section" data-type="${wantType}">
        <header class="res-head"><h2>${TYPE_LABEL[wantType] ?? wantType}</h2><span class="res-ct">${ofType.length}</span><label class="res-sort"><span class="res-sort-lbl">Sort</span><select class="res-sort-sel" data-type="${wantType}"><option value="default">Featured</option><option value="price-asc">Price · low to high</option><option value="price-desc">Price · high to low</option></select></label></header>
        <div class="card-grid">`;
      for (const d of ofType) {
        const isSelected = selected.has(d.sku);
        const q = qty.get(d.sku) ?? 1;
        const detailHref = `/${VERTICAL}/devices/${d.sku}/`;
        const buyHref = d.asin
          ? `https://www.amazon.com/dp/${d.asin}/?tag=crosspec20-20&ascsubtag=picker`
          : `/go/${VERTICAL}/${d.sku}?ref=picker`;
        const priceTxt = d.price != null ? `$${d.price}` : "—";
        html += `<article class="pcard" data-sku="${escapeHtml(d.sku)}" data-price="${d.price ?? 0}" data-selected="${isSelected ? "1" : "0"}">
          <div class="pc-top">
            <label class="pick-toggle"><input type="checkbox" class="pick-cb" ${isSelected ? "checked" : ""} aria-label="Include in build" /><span class="pick-box" aria-hidden="true"></span></label>
            <span class="pc-brand">${escapeHtml(d.brand.replace(/_/g, " "))}</span>
            <div class="pc-qty" ${isSelected ? "" : "hidden"}>
              <button type="button" class="qty-btn" data-act="dec" aria-label="Decrease quantity">−</button>
              <span class="qty-val" data-qty>${q}</span>
              <button type="button" class="qty-btn" data-act="inc" aria-label="Increase quantity">+</button>
            </div>
          </div>
          <h3 class="pc-name"><a href="${detailHref}">${escapeHtml(d.name)}</a></h3>
          ${d.note ? `<p class="pc-note">${escapeHtml(d.note.slice(0, 200))}</p>` : ""}
          <div class="pc-foot">
            <span class="pc-price">${priceTxt}</span>
            <a class="pc-cta" href="${buyHref}" target="_blank" rel="sponsored nofollow noopener">Open on Amazon →</a>
          </div>
        </article>`;
      }
      html += `</div></section>`;
    }
    resultEl.innerHTML = html;
    syncBuildSummary();
  }

  function syncBuildSummary() {
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".pcard[data-sku]"));
    let total = 0;
    let totalUnits = 0;
    const cartEntries: string[] = [];
    for (const card of cards) {
      const cb = card.querySelector<HTMLInputElement>(".pick-cb");
      const sku = card.dataset.sku ?? "";
      const qtyBlock = card.querySelector<HTMLElement>(".pc-qty");
      if (cb && cb.checked) {
        card.dataset.selected = "1";
        if (qtyBlock) qtyBlock.removeAttribute("hidden");
        const q = qty.get(sku) ?? 1;
        const price = parseFloat(card.dataset.price ?? "0") || 0;
        if (sku) {
          cartEntries.push(q > 1 ? `${sku}:${q}` : sku);
          selected.add(sku);
          total += price * q;
          totalUnits += q;
        }
      } else {
        card.dataset.selected = "0";
        if (qtyBlock) qtyBlock.setAttribute("hidden", "");
        selected.delete(sku);
        qty.delete(sku);
      }
    }
    const amountEl = document.getElementById("bs-amount");
    if (amountEl) amountEl.textContent = total > 0 ? `$${Math.round(total)}` : "$0";
    const metaEl = document.getElementById("bs-meta");
    if (metaEl) {
      if (cartEntries.length === 0) metaEl.textContent = "tick the products you want";
      else if (totalUnits === cartEntries.length) metaEl.textContent = `${cartEntries.length} ${cartEntries.length === 1 ? "pick" : "picks"} · review before buying`;
      else metaEl.textContent = `${cartEntries.length} ${cartEntries.length === 1 ? "pick" : "picks"} · ${totalUnits} units total`;
    }
    const cartEl = document.getElementById("bs-cart") as HTMLAnchorElement | null;
    if (cartEl) {
      cartEl.href = `/${VERTICAL}/cart/?skus=${cartEntries.join(",")}`;
      cartEl.classList.toggle("disabled", cartEntries.length === 0);
    }
    syncGapAnalysis();
  }

  function syncGapAnalysis() {
    if (!lastSizingTargets) return;
    const sizingEl = document.getElementById("ai-sizing");
    if (!sizingEl) return;

    let totalPanelW = 0;
    let totalBatteryAh = 0;
    let maxInverterW = 0;
    let maxCcA = 0;
    for (const sku of selected) {
      const d = bySku.get(sku);
      if (!d) continue;
      const q = qty.get(sku) ?? 1;
      const a = d.attrs as Record<string, unknown>;
      if (d.type === "solar_panel") {
        const w = Number(a.wattage ?? 0);
        if (w > 0) totalPanelW += w * q;
      } else if (d.type === "battery") {
        const ah = Number(a.capacity_ah ?? 0);
        const v = Number(a.nominal_voltage ?? 0);
        if (ah > 0 && v === lastSizingTargets.voltage) totalBatteryAh += ah * q;
        else if (ah > 0 && v && v < lastSizingTargets.voltage) {
          // batteries in series — count proportional Ah
          const factor = v / lastSizingTargets.voltage;
          totalBatteryAh += Math.round(ah * factor) * q;
        }
      } else if (d.type === "inverter") {
        const w = Number(a.continuous_watts ?? 0);
        if (w > maxInverterW) maxInverterW = w;
      } else if (d.type === "solar_charge_controller") {
        const amps = Number(a.max_current_amps ?? 0);
        if (amps > maxCcA) maxCcA = amps;
      }
    }

    const gap = (have: number, target: number, unit: string) => {
      if (target <= 0) return "";
      if (have >= target) return `<span class="gap-met">✓ ${have}${unit}</span>`;
      return `<span class="gap-short">${have}${unit} / ${target}${unit} · need <strong>${target - have}${unit}</strong> more</span>`;
    };

    let gapHtml = '<div class="gap-grid">';
    gapHtml += `<div class="gap-cell"><span class="gap-k">panels</span>${gap(totalPanelW, lastSizingTargets.panelW, "W")}</div>`;
    gapHtml += `<div class="gap-cell"><span class="gap-k">battery (Ah @ ${lastSizingTargets.voltage}V)</span>${gap(totalBatteryAh, lastSizingTargets.batteryAh, " Ah")}</div>`;
    gapHtml += `<div class="gap-cell"><span class="gap-k">inverter</span>${gap(maxInverterW, lastSizingTargets.inverterW, "W")}</div>`;
    gapHtml += `<div class="gap-cell"><span class="gap-k">MPPT</span>${gap(maxCcA, lastSizingTargets.ccA, "A")}</div>`;
    gapHtml += "</div>";

    const existing = sizingEl.querySelector(".sz-gap");
    if (existing) existing.remove();
    const gapDiv = document.createElement("div");
    gapDiv.className = "sz-gap";
    gapDiv.innerHTML = '<div class="sz-gap-head">Build progress vs target</div>' + gapHtml;
    sizingEl.appendChild(gapDiv);
  }

  // Soft compat warnings — non-blocking. Pick what you want; we just flag issues.
  const TYPE_DEPS: Record<string, string[]> = {
    solar_panel: ["solar_charge_controller", "solar_cable_kit"],
    battery: ["solar_charge_controller", "solar_cable_kit"],
    inverter: ["solar_cable_kit"],
  };
  const TYPE_LBL: Record<string, string> = {
    solar_panel: "panels", battery: "battery", inverter: "inverter",
    solar_charge_controller: "charge controller", solar_cable_kit: "cable kit",
    power_station: "power station", solar_mounting: "mount",
  };

  function pickedProducts(): Slim[] {
    const out: Slim[] = [];
    for (const card of document.querySelectorAll<HTMLElement>(".pcard[data-sku]")) {
      const cb = card.querySelector<HTMLInputElement>(".pick-cb");
      if (!cb?.checked) continue;
      const sku = card.dataset.sku ?? "";
      const item = data.find((d) => d.sku === sku);
      if (item) out.push(item);
    }
    return out;
  }

  function findCompatWarnings(): string[] {
    if (!form) return [];
    const warnings: string[] = [];
    const checked = new Set(
      Array.from(form.querySelectorAll<HTMLInputElement>('input[name="want"]:checked')).map((i) => i.value),
    );
    for (const [trigger, deps] of Object.entries(TYPE_DEPS)) {
      if (!checked.has(trigger)) continue;
      const missing = deps.filter((d) => !checked.has(d));
      if (missing.length === 0) continue;
      warnings.push(`Missing ${missing.map((m) => TYPE_LBL[m] ?? m).join(", ")} — required to wire up the ${TYPE_LBL[trigger] ?? trigger}.`);
    }
    // Spec-level: charge controller current rating vs panel array short-circuit current.
    const picked = pickedProducts();
    const panels = picked.filter((d) => d.type === "solar_panel");
    const ccs = picked.filter((d) => d.type === "solar_charge_controller");
    const inverters = picked.filter((d) => d.type === "inverter");
    const batteries = picked.filter((d) => d.type === "battery");
    if (panels.length > 0 && ccs.length > 0) {
      let arrayWatts = 0;
      for (const p of panels) arrayWatts += Number(p.attrs.wattage ?? 0);
      let ccCurrent = 0;
      for (const c of ccs) ccCurrent = Math.max(ccCurrent, Number(c.attrs.max_charge_current_a ?? c.attrs.current_a ?? 0));
      if (arrayWatts > 0 && ccCurrent > 0) {
        const minControllerA = Math.ceil((arrayWatts / 12) * 1.25);
        if (ccCurrent < minControllerA / 4) {
          warnings.push(`Charge controller may be undersized: ${arrayWatts}W array @12V needs ~${minControllerA}A; selected controllers max at ${ccCurrent}A.`);
        }
      }
    }
    // Inverter wattage vs battery bank capability (rough).
    if (inverters.length > 0 && batteries.length > 0) {
      let invW = 0;
      for (const i of inverters) invW = Math.max(invW, Number(i.attrs.continuous_watts ?? i.attrs.continuous_w ?? 0));
      let battV = 0;
      for (const b of batteries) battV = Math.max(battV, Number(b.attrs.voltage_v ?? b.attrs.voltage ?? 0));
      if (invW >= 2000 && battV && battV < 24) {
        warnings.push(`Inverter is ${invW}W but battery bank is ${battV}V — high-watt inverters need 24V or 48V banks to keep cable losses sane.`);
      }
    }
    return warnings;
  }

  function renderCompatBanner() {
    const warnings = findCompatWarnings();
    let banner = document.getElementById("deps-banner");
    if (warnings.length === 0) {
      if (banner) banner.remove();
      return;
    }
    if (!banner) {
      banner = document.createElement("div");
      banner.id = "deps-banner";
      banner.className = "deps-banner";
      const pickerForm = document.getElementById("picker-form");
      pickerForm?.parentNode?.insertBefore(banner, pickerForm.nextSibling);
    }
    banner.innerHTML = `<strong>Heads up:</strong><ul>${warnings.map((w) => `<li>${w.replace(/&/g, "&amp;").replace(/</g, "&lt;")}</li>`).join("")}</ul>`;
  }

  function autoSelectFirstOfEachType() {
    if (!form) return;
    const wantedTypes = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="want"]:checked')).map((i) => i.value);
    for (const wantType of wantedTypes) {
      const section = document.querySelector<HTMLElement>(`.res-section[data-type="${wantType}"]`);
      const firstCard = section?.querySelector<HTMLElement>(".pcard");
      if (firstCard) {
        const cb = firstCard.querySelector<HTMLInputElement>(".pick-cb");
        if (cb && !cb.checked) cb.checked = true;
      }
    }
    syncBuildSummary();
  }

  if (resultEl) {
    resultEl.addEventListener("change", (e) => {
      const t = e.target as HTMLElement;
      if (!t.matches(".res-sort-sel")) return;
      const sel = t as HTMLSelectElement;
      const grid = sel.closest<HTMLElement>(".res-section")?.querySelector<HTMLElement>(".card-grid");
      if (!grid) return;
      const cards = Array.from(grid.querySelectorAll<HTMLElement>(".pcard"));
      const order = sel.value;
      const priced = cards.filter((c) => parseFloat(c.dataset.price ?? "0") > 0);
      const unpriced = cards.filter((c) => !(parseFloat(c.dataset.price ?? "0") > 0));
      if (order === "price-asc") priced.sort((a, b) => parseFloat(a.dataset.price ?? "0") - parseFloat(b.dataset.price ?? "0"));
      else if (order === "price-desc") priced.sort((a, b) => parseFloat(b.dataset.price ?? "0") - parseFloat(a.dataset.price ?? "0"));
      else { renderPicker(); return; }
      for (const c of priced) grid.appendChild(c);
      for (const c of unpriced) grid.appendChild(c);
    });
  }

  if (form) {
    form.addEventListener("change", (e) => {
      const t = e.target as HTMLElement;
      if (t.matches('input[name="want"]')) {
        renderPicker();
        renderCompatBanner();
      } else if (t.classList.contains("pick-cb")) {
        syncBuildSummary();
        renderCompatBanner();
      }
    });
  }

  // Qty +/- handler (delegated on result area)
  if (resultEl) {
    resultEl.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".qty-btn");
      if (!btn) return;
      const card = btn.closest<HTMLElement>(".pcard");
      const sku = card?.dataset.sku;
      if (!sku) return;
      const cur = qty.get(sku) ?? 1;
      const next = btn.dataset.act === "inc" ? Math.min(cur + 1, 99) : Math.max(cur - 1, 1);
      qty.set(sku, next);
      const valEl = card?.querySelector<HTMLElement>("[data-qty]");
      if (valEl) valEl.textContent = String(next);
      syncBuildSummary();
    });
  }

  // ─── AI helper: natural language → params → applied to picker ───

  type Msg = { role: "user" | "assistant"; content: string };
  type LLMResp =
    | { kind: "question"; text: string }
    | { kind: "ready"; summary: string; params: SolarParams }
    | { kind: "error"; text: string };
  type SolarParams = {
    load_watts: number;
    runtime_hours_per_day: number;
    sun_hours_per_day: number;
    battery_voltage: 12 | 24 | 48;
    use_case: string;
    wants: string[];
  };

  const aiForm = document.getElementById("ai-form") as HTMLFormElement | null;
  const aiInput = document.getElementById("ai-input") as HTMLInputElement | null;
  const aiSubmit = document.getElementById("ai-submit") as HTMLButtonElement | null;
  const aiTranscript = document.getElementById("ai-transcript");
  const conversation: Msg[] = [];

  function appendBubble(role: "user" | "assistant" | "system", text: string) {
    if (!aiTranscript) return;
    const div = document.createElement("div");
    div.className = `ai-bubble ai-${role}`;
    div.textContent = text;
    aiTranscript.appendChild(div);
    aiTranscript.scrollTop = aiTranscript.scrollHeight;
  }

  function setBusy(busy: boolean) {
    if (aiInput) aiInput.disabled = busy;
    if (aiSubmit) {
      aiSubmit.disabled = busy;
      aiSubmit.textContent = busy ? "Thinking…" : "Ask →";
    }
  }

  async function askLLM(text: string) {
    conversation.push({ role: "user", content: text });
    appendBubble("user", text);
    setBusy(true);
    try {
      const r = await fetch("/api/llm-solve", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ vertical: "solar", messages: conversation }),
      });
      const data = (await r.json()) as LLMResp;
      if (data.kind === "question") {
        conversation.push({ role: "assistant", content: data.text });
        appendBubble("assistant", data.text);
      } else if (data.kind === "ready") {
        conversation.push({ role: "assistant", content: data.summary });
        appendBubble("assistant", data.summary);
        applyParams(data.params);
      } else {
        appendBubble("system", data.text);
      }
    } catch (e) {
      appendBubble("system", "Connection error — try again in a moment.");
    } finally {
      setBusy(false);
      if (aiInput) aiInput.value = "";
    }
  }

  function applyParams(p: SolarParams) {
    // Set use case radio
    if (form) {
      const useCaseRadio = form.querySelector<HTMLInputElement>(`input[name="use_case"][value="${p.use_case}"]`);
      if (useCaseRadio) useCaseRadio.checked = true;
      for (const want of p.wants) {
        const cb = form.querySelector<HTMLInputElement>(`input[name="want"][value="${want}"]`);
        if (cb) cb.checked = true;
      }
      renderCompatBanner();
    }
    // Compute sizing
    const dailyKwh = (p.load_watts * p.runtime_hours_per_day) / 1000;
    const panelW = Math.ceil((dailyKwh * 1000) / p.sun_hours_per_day * 1.4);
    const batteryAh = Math.ceil((dailyKwh * 1000) / p.battery_voltage / 0.9 * 1.5);
    const inverterW = Math.ceil(p.load_watts * 1.5);
    const ccA = Math.ceil(panelW / p.battery_voltage * 1.25);

    // Show the recommendation strip above the picker results
    const sizingEl = document.getElementById("ai-sizing") ?? (() => {
      const d = document.createElement("div");
      d.id = "ai-sizing";
      d.className = "ai-sizing";
      const aiHelper = document.getElementById("ai-helper");
      aiHelper?.parentNode?.insertBefore(d, aiHelper.nextSibling);
      return d;
    })();
    sizingEl.innerHTML = `
      <div class="sz-head">Sizing for ${dailyKwh.toFixed(1)} kWh/day at ${p.sun_hours_per_day} sun-hours · ${p.battery_voltage}V system</div>
      <div class="sz-grid">
        <div class="sz-cell"><span class="sz-k">solar panels</span><span class="sz-v">≥ ${panelW} W total</span></div>
        <div class="sz-cell"><span class="sz-k">battery (LFP)</span><span class="sz-v">≥ ${batteryAh} Ah @ ${p.battery_voltage}V</span></div>
        <div class="sz-cell"><span class="sz-k">inverter</span><span class="sz-v">≥ ${inverterW} W continuous</span></div>
        <div class="sz-cell"><span class="sz-k">MPPT controller</span><span class="sz-v">≥ ${ccA} A</span></div>
      </div>
      <p class="sz-foot">Targets are per-component minimums; pick anything ≥ each value below. Math: daily kWh × 1.4 oversize / sun-hours = panel watts; daily kWh × 1.5 autonomy / 0.9 LFP DoD / V = Ah.</p>
    `;
    // Filter the picker results to show items meeting these thresholds
    renderPicker();
    autoSelectFirstOfEachType();
    // Scroll
    sizingEl.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  if (aiForm) {
    aiForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const v = aiInput?.value.trim() ?? "";
      if (v) askLLM(v);
    });
  }
  document.querySelectorAll<HTMLButtonElement>(".ai-chip").forEach((btn) => {
    btn.addEventListener("click", () => {
      const q = btn.dataset.q ?? "";
      if (!q) return;
      if (aiInput) {
        aiInput.value = q;
        aiInput.focus();
        aiInput.scrollIntoView({ behavior: "smooth", block: "center" });
      }
      const paramsJson = btn.dataset.params;
      if (paramsJson) {
        try {
          const params = JSON.parse(paramsJson);
          appendBubble("user", q);
          appendBubble("assistant", `Applied template: ${q}`);
          applyParams(params);
          return;
        } catch (e) {
          // fall through to LLM if data-params is malformed
        }
      }
      askLLM(q);
    });
  });
</script>

