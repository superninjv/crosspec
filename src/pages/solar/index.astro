---
import Layout from "@engine/ui/Layout.astro";
import type { KnowledgeBase } from "@engine/solver";
import kbRaw from "@verticals/solar/kb.json";
import affRaw from "@verticals/solar/affiliates.json";

const kb = kbRaw as KnowledgeBase;
const VERTICAL = "solar";
const ACCENT = "oklch(0.62 0.16 70)";

interface ProductMap { products: Record<string, { merchant: string; asin?: string }>; }
const aff = affRaw as ProductMap;

const TYPES = [
  { slug: "solar_panel", label: "Solar panels", blurb: "100W to 400W rigid, flexible, and portable." },
  { slug: "battery", label: "Batteries", blurb: "LiFePO4 deep-cycle 12V/24V/48V banks." },
  { slug: "inverter", label: "Inverters", blurb: "Pure sine wave, off-grid + grid-tied." },
  { slug: "solar_charge_controller", label: "Charge controllers", blurb: "MPPT and PWM, 12V/24V/48V auto." },
  { slug: "power_station", label: "Power stations", blurb: "All-in-one solar generators." },
  { slug: "solar_mounting", label: "Mounts", blurb: "Z-bracket, ground mount, RV tilt, rail." },
  { slug: "solar_cable_kit", label: "Cables & accessories", blurb: "MC4, fuses, branch splitters." },
];

const USE_CASES = [
  { slug: "rv_van", label: "RV / van life" },
  { slug: "off_grid_cabin", label: "Off-grid cabin" },
  { slug: "portable", label: "Portable / camping" },
  { slug: "backup", label: "Home backup" },
  { slug: "boat", label: "Boat / marine" },
  { slug: "grid_tied", label: "Grid-tied home" },
];

const slim = kb.entities.map((e) => ({
  id: e.id,
  sku: e.sku ?? e.id,
  name: e.name,
  type: e.type,
  brand: String(e.attributes.brand ?? ""),
  model: String(e.attributes.model ?? ""),
  price: typeof e.attributes.price_usd === "number" ? (e.attributes.price_usd as number) : null,
  note: (e.attributes.note as string) ?? "",
  asin: aff.products[e.id]?.asin ?? aff.products[e.sku ?? e.id]?.asin ?? null,
  attrs: e.attributes,
}));
const slimJSON = JSON.stringify(slim);

const byType = new Map<string, typeof kb.entities>();
for (const e of kb.entities) {
  if (!byType.has(e.type)) byType.set(e.type, []);
  byType.get(e.type)!.push(e);
}
---
<Layout
  title={`Solar configurator · panels, batteries, inverters, controllers · crosspec`}
  description="Build a compatible solar setup. Pick the components you want, see the build total, open everything on Amazon. Sourced specs, no signup."
  crumbs={["solar"]}
  kbStatus={`solar v0.1 · ${kb.entities.length} entities`}
>
  <section class="solar-hero" style={`--accent: ${ACCENT}`}>
    <div class="hero-inner">
      <p class="eyebrow">crosspec / solar</p>
      <h1>Build a solar setup that <em>actually works.</em></h1>
      <p class="lede">{kb.entities.length} components. Match panel Voc to controller, battery chemistry to charge profile, inverter watts to BMS amp limits. Sourced from manufacturer datasheets.</p>
    </div>
  </section>

  <form id="picker-form" class="picker-form">
    <fieldset class="picker-step">
      <legend><span class="step-num">1</span> What's the build for?</legend>
      <div class="chip-row">
        {USE_CASES.map((u, i) => (
          <label class="chip">
            <input type="radio" name="use_case" value={u.slug} checked={i === 0} />
            <span>{u.label}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <fieldset class="picker-step">
      <legend><span class="step-num">2</span> What components do you want?</legend>
      <div class="want-grid">
        {TYPES.map((t) => {
          const ents = byType.get(t.slug) ?? [];
          return (
            <label class="want-tile">
              <input type="checkbox" name="want" value={t.slug} />
              <div class="wt-body">
                <span class="wt-label">{t.label}</span>
                <span class="wt-blurb">{t.blurb}</span>
                <span class="wt-count">{ents.length} options</span>
              </div>
            </label>
          );
        })}
      </div>
    </fieldset>
  </form>

  <section id="picker-result" class="picker-result">
    <p class="picker-empty">Tick a component above to see compatible options.</p>
  </section>

  <section class="build-summary" id="build-summary" hidden>
    <div class="bs-totals">
      <span class="bs-label">build total</span>
      <span class="bs-amount" id="bs-amount">$0</span>
      <span class="bs-meta" id="bs-meta">tick the products you want</span>
    </div>
    <a class="bs-cart disabled" id="bs-cart" href={`/${VERTICAL}/cart/?skus=`} target="_blank">
      <span aria-hidden="true">▣</span>
      <span>Review &amp; checkout</span>
      <span aria-hidden="true">→</span>
    </a>
  </section>

  <details class="all-products">
    <summary>Or browse everything by category</summary>
    <div class="all-inner">
      {TYPES.map((t) => {
        const ents = byType.get(t.slug) ?? [];
        if (ents.length === 0) return null;
        return (
          <section class="cat-section" id={t.slug}>
            <header class="cat-head">
              <h3>{t.label}</h3>
              <span class="cat-count">{ents.length}</span>
            </header>
            <ul class="cat-grid">
              {ents.map((e) => {
                const sku = e.sku ?? e.id;
                const priceUsd = typeof e.attributes.price_usd === "number" ? e.attributes.price_usd : null;
                return (
                  <li class="cat-card">
                    <a class="cc-link" href={`/${VERTICAL}/devices/${sku}/`}>
                      <span class="cc-brand">{String(e.attributes.brand ?? "").replace(/_/g, " ")}</span>
                      <span class="cc-name">{e.name}</span>
                      <span class="cc-price">{priceUsd != null ? `$${priceUsd}` : ""}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </section>
        );
      })}
    </div>
  </details>
</Layout>

<script id="picker-data" type="application/json" set:html={slimJSON} />

<script>
  type Slim = {
    id: string;
    sku: string;
    name: string;
    type: string;
    brand: string;
    model: string;
    price: number | null;
    note: string;
    asin: string | null;
    attrs: Record<string, unknown>;
  };

  const VERTICAL = "solar";
  const dataEl = document.getElementById("picker-data");
  const data: Slim[] = dataEl ? JSON.parse(dataEl.textContent ?? "[]") : [];
  const form = document.getElementById("picker-form") as HTMLFormElement | null;
  const resultEl = document.getElementById("picker-result");
  const buildSummary = document.getElementById("build-summary");

  const selected = new Set<string>();

  function escapeHtml(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function renderPicker() {
    if (!form || !resultEl) return;
    const wanted = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="want"]:checked')).map((i) => i.value);
    if (wanted.length === 0) {
      resultEl.innerHTML = '<p class="picker-empty">Tick a component above to see compatible options.</p>';
      buildSummary?.setAttribute("hidden", "");
      return;
    }
    buildSummary?.removeAttribute("hidden");

    const TYPE_LABEL: Record<string, string> = {
      solar_panel: "Solar panels",
      battery: "Batteries",
      inverter: "Inverters",
      solar_charge_controller: "Charge controllers",
      power_station: "Power stations",
      solar_mounting: "Mounts",
      solar_cable_kit: "Cables & accessories",
    };

    let html = "";
    for (const wantType of wanted) {
      const ofType = data.filter((d) => d.type === wantType);
      if (ofType.length === 0) continue;
      html += `<section class="res-section">
        <header class="res-head"><h2>${TYPE_LABEL[wantType] ?? wantType}</h2><span class="res-ct">${ofType.length}</span></header>
        <div class="card-grid">`;
      for (const d of ofType) {
        const isSelected = selected.has(d.sku);
        const detailHref = `/${VERTICAL}/devices/${d.sku}/`;
        const buyHref = d.asin
          ? `https://www.amazon.com/dp/${d.asin}/?tag=crosspec20-20&ascsubtag=picker`
          : `/go/${VERTICAL}/${d.sku}?ref=picker`;
        const priceTxt = d.price != null ? `$${d.price}` : "—";
        html += `<article class="pcard" data-sku="${escapeHtml(d.sku)}" data-price="${d.price ?? 0}" data-selected="${isSelected ? "1" : "0"}">
          <div class="pc-top">
            <label class="pick-toggle"><input type="checkbox" class="pick-cb" ${isSelected ? "checked" : ""} aria-label="Include in build" /><span class="pick-box" aria-hidden="true"></span></label>
            <span class="pc-brand">${escapeHtml(d.brand.replace(/_/g, " "))}</span>
          </div>
          <h3 class="pc-name"><a href="${detailHref}">${escapeHtml(d.name)}</a></h3>
          ${d.note ? `<p class="pc-note">${escapeHtml(d.note.slice(0, 200))}</p>` : ""}
          <div class="pc-foot">
            <span class="pc-price">${priceTxt}</span>
            <a class="pc-cta" href="${buyHref}" target="_blank" rel="sponsored nofollow noopener">Open on Amazon →</a>
          </div>
        </article>`;
      }
      html += `</div></section>`;
    }
    resultEl.innerHTML = html;
    syncBuildSummary();
  }

  function syncBuildSummary() {
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".pcard[data-sku]"));
    let total = 0;
    const skus: string[] = [];
    for (const card of cards) {
      const cb = card.querySelector<HTMLInputElement>(".pick-cb");
      const sku = card.dataset.sku ?? "";
      if (cb && cb.checked) {
        card.dataset.selected = "1";
        if (sku) {
          skus.push(sku);
          selected.add(sku);
          total += parseFloat(card.dataset.price ?? "0") || 0;
        }
      } else {
        card.dataset.selected = "0";
        selected.delete(sku);
      }
    }
    const amountEl = document.getElementById("bs-amount");
    if (amountEl) amountEl.textContent = total > 0 ? `$${Math.round(total)}` : "$0";
    const metaEl = document.getElementById("bs-meta");
    if (metaEl) metaEl.textContent = skus.length === 0 ? "tick the products you want" : `${skus.length} ${skus.length === 1 ? "pick" : "picks"} · review before buying`;
    const cartEl = document.getElementById("bs-cart") as HTMLAnchorElement | null;
    if (cartEl) {
      cartEl.href = `/${VERTICAL}/cart/?skus=${skus.join(",")}`;
      cartEl.classList.toggle("disabled", skus.length === 0);
    }
  }

  if (form) {
    form.addEventListener("change", (e) => {
      const t = e.target as HTMLElement;
      if (t.matches('input[name="want"]')) renderPicker();
      else if (t.classList.contains("pick-cb")) syncBuildSummary();
    });
  }
</script>

<style is:global>
  .solar-hero {
    background: linear-gradient(180deg, oklch(0.96 0.04 80) 0%, var(--paper-1) 100%);
    border-bottom: 1px solid var(--paper-edge);
    padding: 36px 24px 30px;
  }
  .solar-hero .hero-inner { max-width: 1100px; margin: 0 auto; }
  .solar-hero .eyebrow { font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: 0.05em; text-transform: uppercase; margin: 0 0 6px; }
  .solar-hero h1 { font-size: 38px; line-height: 1.1; letter-spacing: -0.02em; font-weight: 700; margin: 0 0 14px; color: var(--ink-0); text-wrap: balance; max-width: 820px; }
  .solar-hero h1 em { font-style: normal; color: var(--accent); }
  .solar-hero .lede { font-size: 16px; color: var(--ink-2); line-height: 1.55; max-width: 720px; margin: 0; }

  .picker-form { max-width: 1100px; margin: 0 auto; padding: 28px 24px 8px; display: flex; flex-direction: column; gap: 20px; }
  .picker-step { border: 0; padding: 0; margin: 0; }
  .picker-step legend { display: flex; align-items: center; gap: 10px; font-size: 16px; font-weight: 700; color: var(--ink-0); margin-bottom: 12px; }
  .step-num { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; background: var(--ink-0); color: var(--paper-0); font-family: var(--mono); font-size: 12px; font-weight: 700; }
  .chip-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip {
    display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px;
    background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 99px;
    font-size: 13.5px; cursor: pointer; transition: border-color .12s, background-color .12s;
  }
  .chip input { position: absolute; opacity: 0; pointer-events: none; }
  .chip:has(input:checked) { background: var(--ink-0); color: var(--paper-0); border-color: var(--ink-0); }
  .chip:hover { border-color: var(--ink-3); }

  .want-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; }
  .want-tile {
    cursor: pointer;
    background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 9px;
    padding: 12px 14px;
    display: grid; grid-template-columns: auto 1fr; gap: 10px; align-items: start;
    transition: border-color .12s, box-shadow .12s;
  }
  .want-tile input {
    appearance: none; -webkit-appearance: none;
    width: 18px; height: 18px; border: 1.5px solid var(--ink-3); border-radius: 4px;
    background: var(--paper-0); margin-top: 1px; cursor: pointer; position: relative;
  }
  .want-tile input:checked {
    background: var(--ink-0); border-color: var(--ink-0);
  }
  .want-tile input:checked::after {
    content: ""; position: absolute; left: 4px; top: 1px;
    width: 7px; height: 11px; border: solid var(--paper-0); border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .want-tile:hover { border-color: var(--ink-3); }
  .want-tile:has(input:checked) { border-color: var(--accent); box-shadow: 0 2px 12px -4px var(--accent); }
  .wt-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .wt-label { font-size: 14px; font-weight: 700; color: var(--ink-0); }
  .wt-blurb { font-size: 12.5px; color: var(--ink-2); line-height: 1.4; }
  .wt-count { font-family: var(--mono); font-size: 11px; color: var(--ink-3); margin-top: 2px; }

  .picker-result { max-width: 1100px; margin: 0 auto; padding: 8px 24px 0; min-height: 80px; }
  .picker-empty { color: var(--ink-3); font-size: 14px; padding: 20px 0; text-align: center; font-style: italic; }
  .res-section { margin-top: 24px; }
  .res-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--paper-edge); padding-bottom: 6px; margin-bottom: 10px; }
  .res-head h2 { font-size: 18px; font-weight: 700; margin: 0; }
  .res-ct { font-family: var(--mono); font-size: 12px; color: var(--ink-3); }
  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px; }
  .pcard {
    background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 10px;
    padding: 14px; display: flex; flex-direction: column; gap: 8px;
    transition: border-color .12s, opacity .12s;
  }
  .pcard[data-selected="0"] { opacity: 0.62; background: var(--paper-1); }
  .pcard:hover { border-color: var(--ink-4); }
  .pc-top { display: flex; align-items: center; gap: 8px; }
  .pick-toggle { display: inline-flex; align-items: center; cursor: pointer; }
  .pick-toggle input { position: absolute; opacity: 0; pointer-events: none; }
  .pick-box {
    width: 16px; height: 16px; border: 1.5px solid var(--ink-3); border-radius: 4px;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .pick-toggle input:checked + .pick-box { background: var(--ink-0); border-color: var(--ink-0); }
  .pick-toggle input:checked + .pick-box::after {
    content: ""; width: 8px; height: 4px; border-left: 2px solid var(--paper-0); border-bottom: 2px solid var(--paper-0); transform: rotate(-45deg) translate(1px, -1px);
  }
  .pc-brand { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); font-weight: 600; }
  .pc-name { font-size: 14.5px; font-weight: 600; line-height: 1.3; margin: 0; }
  .pc-name a { color: var(--ink-0); text-decoration: none; }
  .pc-name a:hover { text-decoration: underline; text-underline-offset: 3px; }
  .pc-note { font-size: 12.5px; color: var(--ink-2); line-height: 1.5; margin: 0; }
  .pc-foot { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: auto; padding-top: 6px; }
  .pc-price { font-family: var(--mono); font-size: 14.5px; font-weight: 700; color: var(--ink-0); }
  .pc-cta {
    display: inline-flex; align-items: center; gap: 4px; padding: 7px 12px;
    background: var(--ink-0); color: var(--paper-0);
    border-radius: 5px; font-size: 12.5px; font-weight: 600; text-decoration: none;
  }
  .pc-cta:hover { background: var(--ink-1); }

  .build-summary {
    position: sticky; bottom: 12px; z-index: 10;
    max-width: 1100px; margin: 24px auto 12px; padding: 14px 20px;
    background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 12px;
    box-shadow: 0 6px 20px -8px oklch(0.20 0.02 250 / 0.18);
    display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
  }
  .bs-totals { display: flex; align-items: baseline; gap: 12px; }
  .bs-label { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); font-weight: 600; }
  .bs-amount { font-family: var(--mono); font-size: 24px; font-weight: 700; color: var(--ink-0); }
  .bs-meta { font-family: var(--mono); font-size: 12px; color: var(--ink-2); }
  .bs-cart {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px;
    background: oklch(0.62 0.18 35); color: var(--paper-0);
    font-weight: 700; font-size: 14.5px; text-decoration: none;
    border-radius: 7px; box-shadow: 0 2px 0 oklch(0.45 0.18 35);
    transition: transform .12s, box-shadow .12s;
  }
  .bs-cart:hover { transform: translateY(-1px); box-shadow: 0 3px 0 oklch(0.45 0.18 35), 0 6px 14px -4px oklch(0.40 0.15 35 / 0.55); }
  .bs-cart.disabled { pointer-events: none; opacity: 0.45; box-shadow: none; }

  .all-products {
    max-width: 1100px; margin: 28px auto 80px; padding: 0 24px;
  }
  .all-products summary { font-family: var(--mono); font-size: 13px; color: var(--ink-2); cursor: pointer; padding: 10px 0; }
  .all-products summary:hover { color: var(--ink-0); }
  .all-inner { padding-top: 12px; }
  .cat-section { margin-top: 24px; }
  .cat-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--paper-edge); padding-bottom: 6px; margin-bottom: 10px; }
  .cat-head h3 { font-size: 17px; font-weight: 700; margin: 0; }
  .cat-count { font-family: var(--mono); font-size: 11px; color: var(--ink-3); }
  .cat-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 6px; }
  .cat-card .cc-link { display: grid; grid-template-columns: 1fr auto; align-items: baseline; column-gap: 8px; padding: 8px 10px; background: var(--paper-0); border: 1px solid var(--paper-edge); border-radius: 6px; text-decoration: none; color: var(--ink-0); transition: border-color .12s; }
  .cat-card .cc-link:hover { border-color: var(--ink-3); }
  .cc-brand { grid-column: 1; font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); font-weight: 600; }
  .cc-name { grid-column: 1; grid-row: 2; font-size: 13px; font-weight: 500; line-height: 1.25; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .cc-price { grid-column: 2; grid-row: 1 / 3; align-self: center; font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--ink-0); }
</style>
