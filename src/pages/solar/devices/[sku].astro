---
import Layout from "@engine/ui/Layout.astro";
import type { Entity, KnowledgeBase } from "@engine/solver";
import kbRaw from "@verticals/solar/kb.json";
import affiliatesRaw from "@verticals/solar/affiliates.json";

const kb = kbRaw as KnowledgeBase;

interface ProductMap {
  products: Record<string, { merchant: string; asin?: string }>;
}
const aff = affiliatesRaw as ProductMap;

const TYPE_LABEL: Record<string, string> = {
  solar_panel: "solar panel",
  inverter: "inverter",
  solar_charge_controller: "solar charge controller",
  battery: "battery",
  power_station: "power station",
  solar_mounting: "solar mount kit",
  solar_cable_kit: "solar cable kit",
};

export async function getStaticPaths() {
  const k = kbRaw as KnowledgeBase;
  return k.entities.map((e) => ({
    params: { sku: e.sku ?? e.id },
    props: { entityId: e.id },
  }));
}

interface PageProps { entityId: string }
const { entityId } = Astro.props as PageProps;
const entity = kb.entities.find((e) => e.id === entityId)! as Entity;
const sku = entity.sku ?? entity.id;
const attrs = entity.attributes;
const typeLabel = TYPE_LABEL[entity.type] ?? entity.type.replace(/_/g, " ");
const brand = String(attrs.brand ?? "").replace(/_/g, " ");
const priceUsd = typeof attrs.price_usd === "number" ? (attrs.price_usd as number) : null;
const asin = aff.products[entity.id]?.asin ?? aff.products[sku]?.asin ?? null;

const buyHref = asin
  ? `https://www.amazon.com/dp/${asin}/?tag=crosspec20-20&ascsubtag=device`
  : `/go/solar/${sku}?ref=device`;

// Spec rows: pull every primitive attribute except internal/meta keys.
const HIDE_KEYS = new Set([
  "brand", "model", "price_usd", "price_source", "price_as_of",
  "source_ids", "note", "type_label",
]);
const specRows: Array<{ k: string; v: string }> = [];
for (const [k, v] of Object.entries(attrs)) {
  if (HIDE_KEYS.has(k)) continue;
  if (v == null) continue;
  let str: string;
  if (Array.isArray(v)) str = v.join(", ");
  else if (typeof v === "boolean") str = v ? "yes" : "no";
  else str = String(v);
  if (!str || str === "[object Object]") continue;
  specRows.push({ k: k.replace(/_/g, " "), v: str });
}

const sourceIds = (attrs.source_ids ?? []) as number[];
const sources = sourceIds
  .map((id) => kb.sources.find((s) => s.id === id))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));

const related = kb.entities
  .filter((e) => e.type === entity.type && e.id !== entity.id)
  .slice(0, 8);

const productJsonLd = {
  "@context": "https://schema.org/",
  "@type": "Product",
  name: entity.name,
  description: (attrs.note as string) ?? `${entity.name} ${typeLabel} specifications and compatibility.`,
  brand: brand ? { "@type": "Brand", name: brand } : undefined,
  ...(attrs.model ? { mpn: String(attrs.model) } : {}),
  sku: String(sku),
  category: typeLabel,
  url: `https://crosspec.com/solar/devices/${sku}/`,
  ...(priceUsd != null
    ? {
        offers: {
          "@type": "Offer",
          priceCurrency: "USD",
          price: priceUsd,
          availability: "https://schema.org/InStock",
          url: `https://crosspec.com/go/solar/${sku}`,
          seller: { "@type": "Organization", name: "Amazon" },
        },
      }
    : {}),
};
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(productJsonLd)} />

<Layout
  title={`${entity.name} · ${typeLabel} specs, compatibility, price | crosspec`}
  description={(attrs.note as string) ?? `${entity.name} (${brand} ${attrs.model ?? ""}). Full specs sourced from manufacturer datasheet.`}
  crumbs={["solar", "devices", String(sku)]}
  kbStatus={`solar v0.1 · ${kb.entities.length} entities`}
>
  <section class="solar-device">
    <p class="dev-eyebrow">
      <a href="/solar/">solar</a>
      <span class="sep">›</span>
      <span>{typeLabel}</span>
    </p>
    <h1 class="dev-title">
      <span class="brand-line">{brand}</span>
      <span class="full">{entity.name}</span>
    </h1>
    {attrs.note && <p class="dev-lede">{attrs.note}</p>}

    <div class="dev-grid">
      <div class="dev-main">
        <h2>Specifications</h2>
        <dl class="spec-table">
          {specRows.map((r) => (
            <div class="spec-row">
              <dt>{r.k}</dt>
              <dd>{r.v}</dd>
            </div>
          ))}
        </dl>

        {sources.length > 0 && (
          <section class="sources">
            <h3>Sources</h3>
            <ol>
              {sources.map((s) => (
                <li>
                  {s.url ? <a href={s.url} rel="nofollow" target="_blank">{s.name}</a> : <span>{s.name}</span>}
                  <span class="ingest"> · ingest {s.ingest_date}</span>
                </li>
              ))}
            </ol>
          </section>
        )}
      </div>

      <aside class="dev-buy">
        <div class="buy-card">
          {priceUsd != null && (
            <p class="buy-price">${priceUsd}</p>
          )}
          <a class="buy-cta" href={buyHref} target="_blank" rel="sponsored nofollow noopener">
            <span>Open on Amazon</span>
            <span class="arr" aria-hidden="true">→</span>
          </a>
          <p class="buy-note">crosspec earns affiliate commission · price last verified {String(attrs.price_as_of ?? "2026-05-06")}</p>
        </div>
      </aside>
    </div>

    {related.length > 0 && (
      <section class="related">
        <h3>Other {typeLabel}s</h3>
        <ul class="related-list">
          {related.map((e) => {
            const rsku = e.sku ?? e.id;
            const rPrice = typeof e.attributes.price_usd === "number" ? e.attributes.price_usd : null;
            return (
              <li>
                <a href={`/solar/devices/${rsku}/`}>
                  <span class="r-name">{e.name}</span>
                  <span class="r-price">{rPrice != null ? `$${rPrice}` : ""}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}
  </section>
</Layout>

<style is:global>
  .solar-device { max-width: 1080px; margin: 0 auto; padding: 28px 24px 80px; }
  .dev-eyebrow { font-family: var(--mono); font-size: 12px; color: var(--ink-3); margin: 0 0 12px; }
  .dev-eyebrow a { color: var(--ink-2); text-decoration: none; }
  .dev-eyebrow a:hover { color: var(--ink-0); text-decoration: underline; }
  .dev-eyebrow .sep { margin: 0 6px; opacity: 0.5; }
  .dev-title { margin: 0 0 12px; }
  .brand-line {
    display: block;
    font-family: var(--mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .dev-title .full {
    display: block;
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: var(--ink-0);
    text-wrap: balance;
  }
  .dev-lede { font-size: 15.5px; color: var(--ink-1); line-height: 1.55; margin: 0 0 22px; max-width: 740px; }

  .dev-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 30px;
    align-items: start;
  }
  @media (max-width: 800px) { .dev-grid { grid-template-columns: 1fr; } }
  .dev-main h2 { font-size: 17px; font-weight: 700; letter-spacing: -0.01em; margin: 0 0 10px; }
  .spec-table {
    margin: 0 0 24px;
    border: 1px solid var(--paper-edge);
    border-radius: 8px;
    overflow: hidden;
    background: var(--paper-0);
  }
  .spec-row {
    display: grid;
    grid-template-columns: 240px 1fr;
    border-top: 1px solid var(--paper-edge);
    font-size: 14px;
  }
  .spec-row:first-child { border-top: 0; }
  .spec-row dt {
    padding: 9px 14px;
    background: var(--paper-1);
    font-family: var(--mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-2);
    font-weight: 600;
  }
  .spec-row dd {
    margin: 0;
    padding: 9px 14px;
    color: var(--ink-0);
    word-break: break-word;
  }
  @media (max-width: 600px) {
    .spec-row { grid-template-columns: 130px 1fr; }
    .spec-row dt { padding: 8px 10px; font-size: 11px; }
    .spec-row dd { padding: 8px 10px; font-size: 13px; }
  }
  .sources h3 { font-size: 14px; font-weight: 700; margin: 0 0 8px; color: var(--ink-1); }
  .sources ol { margin: 0; padding-left: 20px; font-size: 13px; color: var(--ink-2); line-height: 1.6; }
  .sources a { color: var(--ink-1); text-underline-offset: 2px; }
  .sources .ingest { color: var(--ink-3); font-family: var(--mono); font-size: 11.5px; }

  .buy-card {
    background: var(--paper-0);
    border: 1px solid var(--paper-edge);
    border-radius: 10px;
    padding: 18px;
    position: sticky;
    top: 80px;
  }
  .buy-price {
    font-family: var(--mono);
    font-size: 30px;
    font-weight: 700;
    margin: 0 0 12px;
    color: var(--ink-0);
  }
  .buy-cta {
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 20px;
    background: oklch(0.62 0.18 35);
    color: var(--paper-0);
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border-radius: 7px;
    box-shadow: 0 2px 0 oklch(0.45 0.18 35);
    transition: transform .12s, box-shadow .12s;
  }
  .buy-cta:hover { transform: translateY(-1px); box-shadow: 0 3px 0 oklch(0.45 0.18 35), 0 6px 14px -4px oklch(0.40 0.15 35 / 0.55); }
  .buy-note { font-size: 11.5px; color: var(--ink-3); margin: 10px 0 0; line-height: 1.5; }

  .related { margin-top: 36px; }
  .related h3 { font-size: 17px; font-weight: 700; letter-spacing: -0.01em; margin: 0 0 10px; }
  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 8px;
  }
  .related-list a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 10px 12px;
    background: var(--paper-0);
    border: 1px solid var(--paper-edge);
    border-radius: 7px;
    text-decoration: none;
    color: var(--ink-0);
    font-size: 13.5px;
  }
  .related-list a:hover { border-color: var(--ink-3); }
  .related-list .r-price { font-family: var(--mono); font-size: 13px; color: var(--ink-2); font-weight: 600; }
</style>
