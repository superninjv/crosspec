---
import Layout from "@engine/ui/Layout.astro";
import type { KnowledgeBase } from "@engine/solver";
import kbRaw from "@verticals/cnc/kb.json";
import affRaw from "@verticals/cnc/affiliates.json";

const kb = kbRaw as KnowledgeBase;
const VERTICAL = "cnc";
const ACCENT = "oklch(0.45 0.06 250)";

interface ProductMap { products?: Record<string, { merchant: string; asin?: string }>; skus?: Record<string, { merchant: string; asin?: string }>; }
const aff = affRaw as ProductMap;
const affProducts = aff.products ?? aff.skus ?? {};

const TYPES = [
  { slug: "cnc_machine", label: "Machine", blurb: "Shapeoko, Onefinity, Avid, X-Carve, Genmitsu." },
  { slug: "spindle", label: "Spindle / router", blurb: "Makita, DeWalt, Mafell, VFD spindles." },
  { slug: "bit", label: "Bits", blurb: "Endmills, V-bits, ballnose, compression, drag knives." },
  { slug: "fixture", label: "Fixtures", blurb: "Clamps, hold-downs, t-track, tooling plate." },
  { slug: "dust_shoe", label: "Dust shoe", blurb: "Boot or brush, sized to your router." },
  { slug: "controller", label: "Controller", blurb: "External GRBL boxes, Buildbotics, Masso." },
];

const MATERIALS = [
  { slug: "any", label: "Any material" },
  { slug: "wood", label: "Softwood" },
  { slug: "hardwood", label: "Hardwood" },
  { slug: "plywood", label: "Plywood / MDF" },
  { slug: "aluminum", label: "Aluminum" },
  { slug: "plastic", label: "Plastic / acrylic" },
  { slug: "carbon-fiber", label: "Carbon fiber" },
  { slug: "foam", label: "Foam" },
];

const slim = kb.entities.map((e) => ({
  id: e.id,
  sku: e.sku ?? e.id,
  name: e.name,
  type: e.type,
  brand: String(e.attributes.brand ?? ""),
  model: String(e.attributes.model ?? ""),
  price: typeof e.attributes.price_usd === "number" ? (e.attributes.price_usd as number) : null,
  note: (e.attributes.note as string) ?? "",
  asin: affProducts[e.id]?.asin ?? affProducts[e.sku ?? e.id]?.asin ?? null,
  attrs: e.attributes,
}));
const slimJSON = JSON.stringify(slim);

const byType = new Map<string, typeof kb.entities>();
for (const e of kb.entities) {
  if (!byType.has(e.type)) byType.set(e.type, []);
  byType.get(e.type)!.push(e);
}
---
<Layout
  title="CNC router configurator · machines, spindles, bits, fixtures · crosspec"
  description="Build a CNC setup that cuts what you need. Match collet to bit shank, spindle mount to machine, dust shoe to router diameter. Sourced from manufacturer specs."
  crumbs={["cnc"]}
  kbStatus={`cnc v0.1 · ${kb.entities.length} entities`}
>
  <section class="solar-hero" style={`--accent: ${ACCENT}`}>
    <div class="hero-inner">
      <p class="eyebrow">crosspec / cnc</p>
      <h1>Build a CNC setup that <em>cuts what you need.</em></h1>
      <p class="lede">{kb.entities.length} components. Match collet to bit shank, spindle mount to machine, dust shoe to router diameter. Sourced from manufacturer specs and the V1 Engineering / OpenBuilds community.</p>
    </div>
  </section>

  <section class="ai-helper" id="ai-helper">
    <div class="ai-inner">
      <div class="ai-head">
        <span class="ai-glyph" aria-hidden="true">⌘</span>
        <span class="ai-title">Tell me what you want to cut</span>
        <span class="ai-sub">e.g. "hardwood signs at 18×24 inches" or "carbon-fiber RC car parts"</span>
      </div>
      <div class="ai-transcript" id="ai-transcript"></div>
      <form id="ai-form" class="ai-form" autocomplete="off">
        <input type="text" name="q" id="ai-input" placeholder="What kind of CNC setup are you building?" maxlength="500" required />
        <button type="submit" class="ai-submit" id="ai-submit">Ask <span aria-hidden="true">→</span></button>
      </form>
      <div class="ai-examples">
        <button type="button" class="ai-chip" data-q="Hardwood signs at 18×24 inches">Hardwood signs · 18×24</button>
        <button type="button" class="ai-chip" data-q="RC parts in carbon fiber">RC parts · carbon fiber</button>
        <button type="button" class="ai-chip" data-q="First CNC under $2k">First CNC under $2k</button>
        <button type="button" class="ai-chip" data-q="Aluminum small parts milling">Aluminum · small parts</button>
      </div>
    </div>
  </section>

  <form id="picker-form" class="picker-form">
    <fieldset class="picker-step">
      <legend><span class="step-num">1</span> What material(s) will you cut?</legend>
      <div class="chip-row">
        {MATERIALS.map((l, i) => (
          <label class="chip">
            <input type="radio" name="material" value={l.slug} checked={i === 0} />
            <span>{l.label}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <fieldset class="picker-step">
      <legend><span class="step-num">2</span> What components do you want?</legend>
      <div class="want-grid">
        {TYPES.map((t) => {
          const ents = byType.get(t.slug) ?? [];
          return (
            <label class="want-tile">
              <input type="checkbox" name="want" value={t.slug} />
              <div class="wt-body">
                <span class="wt-label">{t.label}</span>
                <span class="wt-blurb">{t.blurb}</span>
                <span class="wt-count">{ents.length} options</span>
              </div>
            </label>
          );
        })}
      </div>
    </fieldset>
  </form>

  <section id="picker-result" class="picker-result">
    <p class="picker-empty">Tick a component above to see compatible options.</p>
  </section>

  <section class="build-summary" id="build-summary" hidden>
    <div class="bs-totals">
      <span class="bs-label">build total</span>
      <span class="bs-amount" id="bs-amount">$0</span>
      <span class="bs-meta" id="bs-meta">tick the products you want</span>
    </div>
    <a class="bs-cart disabled" id="bs-cart" href={`/${VERTICAL}/cart/?skus=`} target="_blank">
      <span aria-hidden="true">▣</span>
      <span>Review &amp; checkout</span>
      <span aria-hidden="true">→</span>
    </a>
  </section>

  <details class="all-products">
    <summary>Or browse everything by category</summary>
    <div class="all-inner">
      {TYPES.map((t) => {
        const ents = byType.get(t.slug) ?? [];
        if (ents.length === 0) return null;
        return (
          <section class="cat-section" id={t.slug}>
            <header class="cat-head">
              <h3>{t.label}</h3>
              <span class="cat-count">{ents.length}</span>
            </header>
            <ul class="cat-grid">
              {ents.map((e) => {
                const sku = e.sku ?? e.id;
                const priceUsd = typeof e.attributes.price_usd === "number" ? e.attributes.price_usd : null;
                return (
                  <li class="cat-card">
                    <a class="cc-link" href={`/${VERTICAL}/devices/${sku}/`}>
                      <span class="cc-brand">{String(e.attributes.brand ?? "").replace(/_/g, " ")}</span>
                      <span class="cc-name">{e.name}</span>
                      <span class="cc-price">{priceUsd != null ? `$${priceUsd}` : ""}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </section>
        );
      })}
    </div>
  </details>
</Layout>

<script id="picker-data" type="application/json" set:html={slimJSON} />

<script>
  type Slim = { id: string; sku: string; name: string; type: string; brand: string; model: string; price: number | null; note: string; asin: string | null; attrs: Record<string, unknown>; };

  const VERTICAL = "cnc";
  const TYPE_LABEL: Record<string, string> = {
    cnc_machine: "Machine", spindle: "Spindle / router", bit: "Bits",
    fixture: "Fixtures", dust_shoe: "Dust shoe", controller: "Controller",
  };
  const dataEl = document.getElementById("picker-data");
  const data: Slim[] = dataEl ? JSON.parse(dataEl.textContent ?? "[]") : [];
  const form = document.getElementById("picker-form") as HTMLFormElement | null;
  const resultEl = document.getElementById("picker-result");
  const buildSummary = document.getElementById("build-summary");
  const selected = new Set<string>();

  function escapeHtml(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function matchesMaterial(d: Slim, material: string): boolean {
    if (!material || material === "any") return true;
    const a = d.attrs as Record<string, unknown>;
    const materialAttr = String(a.material ?? a.materials ?? a.material_compat ?? "").toLowerCase();
    if (!materialAttr) return true;
    if (materialAttr.includes(material)) return true;
    // Bits and accessories are generally material-agnostic unless spec'd otherwise
    if (d.type === "bit" || d.type === "fixture" || d.type === "dust_shoe" || d.type === "controller") return true;
    return false;
  }

  function renderPicker() {
    if (!form || !resultEl) return;
    const wanted = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="want"]:checked')).map((i) => i.value);
    const material = (form.querySelector('input[name="material"]:checked') as HTMLInputElement | null)?.value ?? "any";
    if (wanted.length === 0) {
      resultEl.innerHTML = '<p class="picker-empty">Tick a component above to see compatible options.</p>';
      buildSummary?.setAttribute("hidden", "");
      return;
    }
    buildSummary?.removeAttribute("hidden");

    let html = "";
    for (const wantType of wanted) {
      const ofType = data.filter((d) => d.type === wantType && matchesMaterial(d, material));
      if (ofType.length === 0) {
        html += `<section class="res-section"><header class="res-head"><h2>${TYPE_LABEL[wantType] ?? wantType}</h2></header><p class="picker-empty">No matches for the selected material.</p></section>`;
        continue;
      }
      html += `<section class="res-section"><header class="res-head"><h2>${TYPE_LABEL[wantType] ?? wantType}</h2><span class="res-ct">${ofType.length}</span></header><div class="card-grid">`;
      for (const d of ofType) {
        const isSelected = selected.has(d.sku);
        const detailHref = `/${VERTICAL}/devices/${d.sku}/`;
        const buyHref = d.asin
          ? `https://www.amazon.com/dp/${d.asin}/?tag=crosspec20-20&ascsubtag=picker`
          : `/go/${VERTICAL}/${d.sku}?ref=picker`;
        const priceTxt = d.price != null ? `$${d.price}` : "—";
        html += `<article class="pcard" data-sku="${escapeHtml(d.sku)}" data-price="${d.price ?? 0}" data-selected="${isSelected ? "1" : "0"}">
          <div class="pc-top">
            <label class="pick-toggle"><input type="checkbox" class="pick-cb" ${isSelected ? "checked" : ""} aria-label="Include in build" /><span class="pick-box" aria-hidden="true"></span></label>
            <span class="pc-brand">${escapeHtml(d.brand.replace(/_/g, " "))}</span>
          </div>
          <h3 class="pc-name"><a href="${detailHref}">${escapeHtml(d.name)}</a></h3>
          ${d.note ? `<p class="pc-note">${escapeHtml(d.note.slice(0, 200))}</p>` : ""}
          <div class="pc-foot">
            <span class="pc-price">${priceTxt}</span>
            <a class="pc-cta" href="${buyHref}" target="_blank" rel="sponsored nofollow noopener">Open on Amazon →</a>
          </div>
        </article>`;
      }
      html += `</div></section>`;
    }
    resultEl.innerHTML = html;
    syncBuildSummary();
  }

  function syncBuildSummary() {
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".pcard[data-sku]"));
    let total = 0;
    const skus: string[] = [];
    for (const card of cards) {
      const cb = card.querySelector<HTMLInputElement>(".pick-cb");
      const sku = card.dataset.sku ?? "";
      if (cb && cb.checked) {
        card.dataset.selected = "1";
        if (sku) { skus.push(sku); selected.add(sku); total += parseFloat(card.dataset.price ?? "0") || 0; }
      } else {
        card.dataset.selected = "0";
        selected.delete(sku);
      }
    }
    const amountEl = document.getElementById("bs-amount");
    if (amountEl) amountEl.textContent = total > 0 ? `$${Math.round(total)}` : "$0";
    const metaEl = document.getElementById("bs-meta");
    if (metaEl) metaEl.textContent = skus.length === 0 ? "tick the products you want" : `${skus.length} ${skus.length === 1 ? "pick" : "picks"} · review before buying`;
    const cartEl = document.getElementById("bs-cart") as HTMLAnchorElement | null;
    if (cartEl) {
      cartEl.href = `/${VERTICAL}/cart/?skus=${skus.join(",")}`;
      cartEl.classList.toggle("disabled", skus.length === 0);
    }
  }

  // CNC dependency rules.
  const KB_DEPS: Record<string, string[]> = {
    cnc_machine: ["bit", "fixture", "dust_shoe"],
    spindle: ["bit"],
  };
  const DEP_REASON: Record<string, string> = {
    cnc_machine: "a machine without bits, fixtures, and a dust shoe is incomplete — bits are the cutting edge, fixtures hold the work, dust shoe handles chip ejection",
    spindle: "a spindle upgrade still needs collet-matched bits to do anything",
  };
  const KB_EXCLUSIVE: Array<[string, string]> = [];

  function enforceDeps(): string[] {
    if (!form) return [];
    const checked = new Set(
      Array.from(form.querySelectorAll<HTMLInputElement>('input[name="want"]:checked')).map((i) => i.value),
    );
    const reasons: string[] = [];
    for (const [trigger, deps] of Object.entries(KB_DEPS)) {
      if (!checked.has(trigger)) continue;
      let addedAny = false;
      for (const dep of deps) {
        if (!checked.has(dep)) {
          const cb = form.querySelector<HTMLInputElement>(`input[name="want"][value="${dep}"]`);
          if (cb && !cb.checked) {
            cb.checked = true;
            checked.add(dep);
            addedAny = true;
            const tile = cb.closest<HTMLElement>(".want-tile");
            if (tile) tile.classList.add("want-required");
          }
        }
      }
      if (addedAny) reasons.push(DEP_REASON[trigger]);
    }
    return reasons;
  }

  function renderDepsBanner(reasons: string[]) {
    let banner = document.getElementById("deps-banner");
    if (reasons.length === 0) {
      if (banner) banner.remove();
      return;
    }
    if (!banner) {
      banner = document.createElement("div");
      banner.id = "deps-banner";
      banner.className = "deps-banner";
      const pickerForm = document.getElementById("picker-form");
      pickerForm?.parentNode?.insertBefore(banner, pickerForm.nextSibling);
    }
    banner.innerHTML = `<strong>Auto-added:</strong> ${reasons.join("; ")}. Untick to opt out.`;
  }

  function enforceExclusives(triggerEl: HTMLInputElement | null): string[] {
    if (!form || !triggerEl || !triggerEl.checked) return [];
    const reasons: string[] = [];
    for (const [a, b] of KB_EXCLUSIVE) {
      const other = triggerEl.value === a ? b : triggerEl.value === b ? a : null;
      if (!other) continue;
      const otherEl = form.querySelector<HTMLInputElement>(`input[name="want"][value="${other}"]`);
      if (otherEl && otherEl.checked) {
        otherEl.checked = false;
        const tile = otherEl.closest<HTMLElement>(".want-tile");
        tile?.classList.remove("want-required");
        reasons.push(`unticked ${other} (alternative path to ${triggerEl.value})`);
      }
    }
    return reasons;
  }

  if (form) {
    form.addEventListener("change", (e) => {
      const t = e.target as HTMLElement;
      if (t.matches('input[name="want"]') || t.matches('input[name="material"]')) {
        const exclusiveReasons = t.matches('input[name="want"]')
          ? enforceExclusives(t as HTMLInputElement)
          : [];
        const depReasons = enforceDeps();
        renderDepsBanner([...exclusiveReasons, ...depReasons]);
        renderPicker();
      } else if (t.classList.contains("pick-cb")) {
        syncBuildSummary();
      }
    });
  }

  // ─── AI helper: natural language → params → applied to picker ───

  type Msg = { role: "user" | "assistant"; content: string };
  type CncParams = {
    material: string;
    work_area_min_mm?: number;
    bit_diameter_inch?: number;
    wants: string[];
  };
  type LLMResp =
    | { kind: "question"; text: string }
    | { kind: "ready"; summary: string; params: CncParams }
    | { kind: "error"; text: string };

  const aiForm = document.getElementById("ai-form") as HTMLFormElement | null;
  const aiInput = document.getElementById("ai-input") as HTMLInputElement | null;
  const aiSubmit = document.getElementById("ai-submit") as HTMLButtonElement | null;
  const aiTranscript = document.getElementById("ai-transcript");
  const conversation: Msg[] = [];

  function appendBubble(role: "user" | "assistant" | "system", text: string) {
    if (!aiTranscript) return;
    const div = document.createElement("div");
    div.className = `ai-bubble ai-${role}`;
    div.textContent = text;
    aiTranscript.appendChild(div);
    aiTranscript.scrollTop = aiTranscript.scrollHeight;
  }

  function setBusy(busy: boolean) {
    if (aiInput) aiInput.disabled = busy;
    if (aiSubmit) {
      aiSubmit.disabled = busy;
      aiSubmit.textContent = busy ? "Thinking…" : "Ask →";
    }
  }

  async function askLLM(text: string) {
    conversation.push({ role: "user", content: text });
    appendBubble("user", text);
    setBusy(true);
    try {
      const r = await fetch("/api/llm-solve", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ vertical: "cnc", messages: conversation }),
      });
      const data = (await r.json()) as LLMResp;
      if (data.kind === "question") {
        conversation.push({ role: "assistant", content: data.text });
        appendBubble("assistant", data.text);
      } else if (data.kind === "ready") {
        conversation.push({ role: "assistant", content: data.summary });
        appendBubble("assistant", data.summary);
        applyParams(data.params);
      } else {
        appendBubble("system", data.text);
      }
    } catch (e) {
      appendBubble("system", "Connection error — try again in a moment.");
    } finally {
      setBusy(false);
      if (aiInput) aiInput.value = "";
    }
  }

  function applyParams(p: CncParams) {
    if (form) {
      const materialRadio = form.querySelector<HTMLInputElement>(`input[name="material"][value="${p.material}"]`);
      if (materialRadio) materialRadio.checked = true;
      // No exclusives for CNC — just set all wants
      const wants = new Set(p.wants);
      for (const want of wants) {
        const cb = form.querySelector<HTMLInputElement>(`input[name="want"][value="${want}"]`);
        if (cb) cb.checked = true;
      }
      const reasons = enforceDeps();
      renderDepsBanner(reasons);
    }

    const MATERIAL_LABEL: Record<string, string> = {
      any: "any material", wood: "softwood", hardwood: "hardwood",
      plywood: "plywood / MDF", aluminum: "aluminum", plastic: "plastic / acrylic",
      "carbon-fiber": "carbon fiber", foam: "foam",
    };

    const sizingEl = document.getElementById("ai-sizing") ?? (() => {
      const d = document.createElement("div");
      d.id = "ai-sizing";
      d.className = "ai-sizing";
      const aiHelper = document.getElementById("ai-helper");
      aiHelper?.parentNode?.insertBefore(d, aiHelper.nextSibling);
      return d;
    })();
    sizingEl.innerHTML = `
      <div class="sz-head">Filtering for ${MATERIAL_LABEL[p.material] ?? p.material}${p.work_area_min_mm ? ` · ${p.work_area_min_mm} mm work area` : ""}${p.bit_diameter_inch ? ` · ${p.bit_diameter_inch}" bit` : ""}</div>
      <div class="sz-grid">
        <div class="sz-cell"><span class="sz-k">Material</span><span class="sz-v">${MATERIAL_LABEL[p.material] ?? p.material}</span></div>
        ${p.work_area_min_mm ? `<div class="sz-cell"><span class="sz-k">Work area</span><span class="sz-v">${p.work_area_min_mm} mm min</span></div>` : ""}
        ${p.bit_diameter_inch ? `<div class="sz-cell"><span class="sz-k">Bit diameter</span><span class="sz-v">${p.bit_diameter_inch}"</span></div>` : ""}
        <div class="sz-cell"><span class="sz-k">categories</span><span class="sz-v">${p.wants.length} ticked</span></div>
      </div>
      <p class="sz-foot">Material filters machine and bit compatibility — review individual specs before adding to your build.</p>
    `;
    renderPicker();
    sizingEl.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  if (aiForm) {
    aiForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const v = aiInput?.value.trim() ?? "";
      if (v) askLLM(v);
    });
  }
  document.querySelectorAll<HTMLButtonElement>(".ai-chip").forEach((btn) => {
    btn.addEventListener("click", () => {
      const q = btn.dataset.q ?? "";
      if (q) askLLM(q);
    });
  });
</script>
