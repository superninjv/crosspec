  "constraints": [
    {
      "id": "portafilter_matches_group",
      "description": "portafilter.size_mm must match espresso_machine group head: 58mm for E61 / La Marzocco, 53mm for Breville/Sage Bambino, 54mm for Gaggia Classic and Breville Barista Express line."
    },
    {
      "id": "basket_matches_portafilter",
      "description": "basket.size_mm must match portafilter.size_mm exactly. A 58mm basket will not seat in a 54mm Breville portafilter or a 53mm Bambino portafilter."
    },
    {
      "id": "basket_dose_matches_brew_pressure",
      "description": "basket.dose_g must be appropriate for brew_pressure_bar. At commercial 9 bar, doubles run 18-22g; the LM stock 14g basket is reference-only and dialed for traditional 7g/14g Italian shots."
    },
    {
      "id": "tamper_clearance",
      "description": "tamper.size_mm should be 0.1-0.3mm smaller than basket diameter for clearance: a 58.5mm tamper fits a 58mm basket; a 58.4mm tamper (Pullman) gives extra clearance for ridged baskets."
    },
    {
      "id": "grinder_consistency_floor",
      "description": "grinder.dose_consistency_g must be <= 0.3g for repeatable shots; grinders above 0.3g are excluded from prosumer espresso recommendations."
    },
    {
      "id": "plumb_in_water_workflow",
      "description": "espresso_machine.plumb_in_capable=false machines need a water-tank refill workflow in the recommendation; the configurator must surface tank size and refill frequency so the user knows what daily upkeep looks like."
    }
  ]
}
