  "constraints": [
    {
      "id": "c1",
      "description": "Amp output power must meet headphone power requirement derived from sensitivity and impedance. High-impedance (>=250 ohm) or low-sensitivity (<=94 dB/mW) headphones require a dedicated amp with sufficient output.",
      "rule": "dac_amp.max_output_mw_32ohm >= required_mw(headphone.impedance_ohm, headphone.sensitivity_db_mw)"
    },
    {
      "id": "c2",
      "description": "Cable connector_source must match headphone connector type for physical fit.",
      "rule": "cable.connector_source == headphone.connector"
    },
    {
      "id": "c3",
      "description": "IEM ear tips are only compatible with universal-fit IEMs using 2-pin 0.78mm or MMCX connector standard.",
      "rule": "ear_tip compatible_with iem where iem.connector in ['2pin_0.78mm', 'mmcx']"
    },
    {
      "id": "c4",
      "description": "A balanced cable termination (4.4mm or XLR 4-pin) requires a DAC/amp with balanced output.",
      "rule": "cable.connector_termination in ['4.4mm', 'xlr_4pin'] requires dac_amp.balanced_output == true"
    },
    {
      "id": "c5",
      "description": "Headphones with impedance >300 ohm require a high-power dedicated amp; dongles and portable amps with <200 mW @ 32 ohm are excluded.",
      "rule": "headphone.impedance_ohm > 300 requires dac_amp.max_output_mw_32ohm >= 200"
    },
    {
      "id": "c6",
      "description": "Planar magnetic headphones with low sensitivity (<96 dB/mW) require a dedicated amp with at least 500 mW output at 32 ohm.",
      "rule": "headphone.driver_type == 'planar' AND headphone.sensitivity_db_mw < 96 requires dac_amp.max_output_mw_32ohm >= 500"
    }
  ]
}
