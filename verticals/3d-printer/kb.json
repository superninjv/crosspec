  "constraints": [
    {
      "id": 1,
      "rule": "filament.hotend_min_temp_c <= printer.max_hotend_temp_c",
      "description": "Filament minimum processing temperature must not exceed the printer's rated hotend maximum. Pairing e.g. PC (260 C min) with Prusa Mini+ (280 C max) is fine; pairing with a printer capped at 250 C is not."
    },
    {
      "id": 2,
      "rule": "filament.bed_min_temp_c <= printer.max_bed_temp_c",
      "description": "Filament minimum bed temperature must not exceed the printer's heated-bed maximum. ABS (100 C bed min) requires a printer with ≥100 C bed capability."
    },
    {
      "id": 3,
      "rule": "filament.requires_enclosure == true -> printer.enclosed == true OR enclosure present in build",
      "description": "Engineering filaments (ABS, PC, PA-CF) require an enclosed chamber to prevent warping and delamination. An open-frame printer must be paired with a compatible enclosure entity."
    },
    {
      "id": 4,
      "rule": "filament.requires_hardened_nozzle == true -> nozzle.abrasive_safe == true",
      "description": "Abrasive filaments (PA-CF, PC-CF, glow) require a hardened steel, ruby, or tungsten carbide nozzle. Brass nozzles wear within a few hundred grams of abrasive material."
    },
    {
      "id": 5,
      "rule": "filament.requires_direct_drive == true -> printer.direct_drive == true",
      "description": "Flexible and fiber-reinforced filaments (TPU, PA-CF) require direct-drive extruders to prevent buckling and inconsistent extrusion in long Bowden paths."
    },
    {
      "id": 6,
      "rule": "nozzle.diameter_mm > 0.4 is acceptable but reduces detail resolution",
      "description": "Oversized nozzles (0.6 mm, 0.8 mm) increase volumetric flow rate and reduce print time for functional parts but limit minimum feature size. Default recommendation is 0.4 mm; escalate to 0.6 mm for structural or draft prints only."
    }
  ]
}
