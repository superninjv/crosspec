  "constraints": [
    {
      "id": "amp_power_within_speaker_range",
      "description": "Amplifier continuous power per channel must fall within the speaker's recommended_amp_w range. Under-power risks clipping distortion; over-power risks driver damage.",
      "applies_to": ["bookshelf", "floorstanding", "stereo_amp", "av_receiver"]
    },
    {
      "id": "impedance_amp_compatible",
      "description": "Speaker nominal impedance must be within the amplifier's stable drive range (typically 4–16 ohm). Receivers rated 6-ohm minimum must not drive 4-ohm speakers without derating.",
      "applies_to": ["bookshelf", "floorstanding", "stereo_amp", "av_receiver"]
    },
    {
      "id": "subwoofer_crossover_overlaps_main_rolloff",
      "description": "Subwoofer crossover_range_hz upper limit must exceed the main speaker's bass rolloff (approximately the lower bound of frequency_response_hz). Prevents a frequency gap in the bass-to-sub handoff.",
      "applies_to": ["subwoofer", "bookshelf", "floorstanding"]
    },
    {
      "id": "hdmi_2_1_required_for_4k_120hz",
      "description": "4K@120Hz pass-through and VRR (Variable Refresh Rate) require HDMI 2.1 inputs. HDMI 2.0 caps at 4K@60Hz. Receivers must have hdmi_2_1_inputs > 0 if user needs 4K@120Hz sources.",
      "applies_to": ["av_receiver"]
    },
    {
      "id": "cable_gauge_appropriate_for_run_length",
      "description": "Speaker cable gauge must be adequate for the run length and speaker impedance to keep resistance below 5% of speaker impedance. 16 AWG ≤ 20 ft at 8 ohm; 14 AWG ≤ 30 ft; 12 AWG ≤ 50 ft.",
      "applies_to": ["speaker_cable", "bookshelf", "floorstanding"]
    },
    {
      "id": "room_correction_benefits_untreated_rooms",
      "description": "Receivers with Dirac Live or Audyssey MultEQ XT32 room correction deliver measurably better bass integration in acoustically untreated rooms. Flag when user indicates untreated space.",
      "applies_to": ["av_receiver", "subwoofer"]
    }
  ],
