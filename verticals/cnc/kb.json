  "constraints": [
    {
      "id": "c1",
      "rule": "spindle_mount_fit",
      "description": "A router or VFD spindle can only be mounted on a machine whose spindle_mount_diameter_mm matches the spindle's base_diameter_mm. 65 mm mounts (Shapeoko, X-Carve, BobsCNC, Genmitsu) accept 65 mm body routers/spindles. 80 mm mounts (Onefinity, Avid) accept 80 mm body spindles. 52 mm mounts (Carvera, PROVerXL 4030) use integrated spindles only.",
      "applies_to_types": ["cnc_machine", "spindle"]
    },
    {
      "id": "c2",
      "rule": "collet_shank_fit",
      "description": "A bit's shank_diameter_inch must be <= the collet's maximum capacity. Makita RT0701C and DeWalt DWP611 accept only 1/4 inch shank natively. 1/8 inch shank bits require a 1/4-to-1/8 inch precision reducer sleeve (not recommended for production) OR an ER11/ER16 collet set on a VFD spindle. Never force a 1/4 inch shank into an ER11 (max 7 mm ≈ 0.276 inch — fits, but tight; verify collet rating).",
      "applies_to_types": ["spindle", "bit"]
    },
    {
      "id": "c3",
      "rule": "er_collet_range",
      "description": "ER11 collet accepts 1/16 to 1/4 inch shanks. ER16 collet accepts 1/16 to 3/8 inch shanks. ER20 collet accepts 1/16 to 1/2 inch shanks. Bit shank_diameter_inch must fall within the spindle's ER collet range when er_collet_compatible is true.",
      "applies_to_types": ["spindle", "bit"]
    },
    {
      "id": "c4",
      "rule": "dust_shoe_router_diameter",
      "description": "A dust shoe's fits_router_diameter_mm must match the mounted spindle's base_diameter_mm. 65 mm dust shoes (SuckIt, Rockler, generic) only fit 65 mm body routers. They do NOT fit 80 mm VFD spindles without an 80-to-65 mm adapter ring.",
      "applies_to_types": ["dust_shoe", "spindle"]
    },
    {
      "id": "c5",
      "rule": "drag_knife_spindle_off",
      "description": "The drag knife bit must be used with spindle not rotating (S0 in G-code or relay off). Using a drag knife in a spinning collet will destroy the tool and workpiece. CAM must output tangential knife offsets, not a rotating toolpath.",
      "applies_to_types": ["bit", "spindle"]
    },
    {
      "id": "c6",
      "rule": "micro_endmill_rigidity",
      "description": "The 1/16 inch micro endmill is unsuitable for belt-drive machines (Shapeoko 4, BobsCNC E4, X-Carve Pro) at feeds above 500 mm/min due to deflection amplified by belt compliance. Ballscrew machines (Onefinity, Avid, Carvera, Genmitsu PROVerXL) are required for micro endmill work.",
      "applies_to_types": ["cnc_machine", "bit"]
    },
    {
      "id": "c7",
      "rule": "vfd_spindle_requires_separate_controller_wiring",
      "description": "VFD spindles (1.5 kW air-cooled, 2.2 kW water-cooled) require a separate VFD drive unit wired between the controller and spindle. Machines with integrated spindles (Carvera, Genmitsu PROVerXL) cannot accept VFD spindle upgrades without significant electrical modification. Masso G3 and Buildbotics both support VFD RS485/Modbus spindle control.",
      "applies_to_types": ["cnc_machine", "spindle", "controller"]
    },
    {
      "id": "c8",
      "rule": "vacuum_table_airtight_perimeter",
      "description": "The DIY vacuum table fixture only holds stock that fully covers at least one vacuum zone and forms an airtight perimeter seal. Stock with large through-holes or irregular perimeters will not hold. Works best with sheet stock 300x300 mm or larger with flat underside.",
      "applies_to_types": ["fixture"]
    }
  ]
}
