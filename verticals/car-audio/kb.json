  "constraints": [
    {
      "id": "amp_power_matches_speaker_rms",
      "description": "Amplifier power_per_channel_w_4ohm should be within 0.5×–2× of the target speakers' power_handling_rms_w. Under-powering causes clipping; over-powering risks cone excursion damage.",
      "applies_to": ["amplifier", "component_speaker", "coaxial_speaker"]
    },
    {
      "id": "wiring_gauge_for_amp_current",
      "description": "Wiring kit gauge must be rated for the amplifier's peak current draw. At 13.8V, a 1200W amplifier draws ~90A RMS; a 0AWG kit (rated 300A+) is correct. A 4AWG kit (rated ~100A) is the minimum for amplifiers up to ~600W RMS total.",
      "applies_to": ["wiring_kit", "amplifier"]
    },
    {
      "id": "subwoofer_enclosure_compatibility",
      "description": "Subwoofers specified as enclosure_required: true must be paired with a sealed or ported box matching the manufacturer's recommended internal volume. Free-air install voids warranty and degrades performance.",
      "applies_to": ["subwoofer"]
    },
    {
      "id": "head_unit_preouts_gte_amp_channels",
      "description": "The head unit's num_preouts must be greater than or equal to the number of amplifier input channels. A 5-channel amplifier requires a head unit with at minimum 3 preout pairs (front + rear + sub) or an active signal processor.",
      "applies_to": ["head_unit", "amplifier"]
    },
    {
      "id": "component_speaker_mounting_depth_fits_door",
      "description": "Component speaker mounting_depth_mm must not exceed the available door-panel depth at the install location. Typical OEM door cavities range from 55 mm–90 mm; aftermarket shallow-mount options target ≤65 mm.",
      "applies_to": ["component_speaker"]
    },
    {
      "id": "subwoofer_impedance_matches_amp_sub_channel",
      "description": "Dual-voice-coil subwoofers wired in parallel present half the single-coil impedance. A D4 sub wired in parallel presents 2Ω to the amplifier — verify the amp's rated sub_channel_power_w_2ohm rather than the 4Ω figure.",
      "applies_to": ["subwoofer", "amplifier"]
    }
  ],
