  "constraints": [
    {
      "id": "C1_zigbee_requires_hub",
      "kind": "requires",
      "when": { "protocol": "zigbee" },
      "then": { "requires_hub": "any_zigbee_coordinator" },
      "rationale": "Zigbee is a mesh protocol that needs a coordinator (vendor hub like Hue Bridge / Aqara Hub / TRÅDFRI Gateway, or a generic Zigbee coordinator like SkyConnect / Conbee II / Sonoff ZBDongle paired to Home Assistant). No Zigbee device speaks directly to a phone or speaker.",
      "source_id": 2
    },
    {
      "id": "C2_zigbee_3_0_inherits_C1",
      "kind": "requires",
      "when": { "protocol": "zigbee_3_0" },
      "then": { "requires_hub": "any_zigbee_coordinator" },
      "rationale": "Zigbee 3.0 is a Zigbee variant — same hub requirement as C1.",
      "source_id": 2
    },
    {
      "id": "C3_thread_requires_border_router",
      "kind": "requires",
      "when": { "protocol": "thread_matter" },
      "then": { "requires_hub": "thread_border_router" },
      "rationale": "Thread is a low-power mesh that talks to the rest of the network via a Thread Border Router. HomePod mini, Apple TV 4K (Wi-Fi+Ethernet), Google Nest Hub (2nd gen), Echo (4th gen), Eero Pro 6E, and SkyConnect can all act as one.",
      "source_id": 1
    },
    {
      "id": "C4_matter_requires_controller",
      "kind": "requires",
      "when": { "protocol": "thread_matter" },
      "then": { "requires_hub": "matter_controller" },
      "rationale": "Matter devices need a controller in the chosen ecosystem (Apple Home Hub for HomeKit, Google Home / Nest Hub for Google, Echo for Alexa, the Matter integration in Home Assistant). The border router and the controller are often the same physical device.",
      "source_id": 1
    },
    {
      "id": "C5_wifi_2_4ghz_no_hub",
      "kind": "implies",
      "when": { "protocol": "wifi_2_4ghz" },
      "then": { "requires_hub": "none" },
      "rationale": "Wi-Fi smart devices join the household 2.4 GHz network directly. No hub. Trade-off: Wi-Fi devices add to AP client count and use more power than Zigbee/Thread mesh devices.",
      "source_id": 3
    },
    {
      "id": "C6_ecosystem_filter",
      "kind": "requires",
      "when": { "user_ecosystem": "<input>" },
      "then": { "entity.attributes.ecosystems": "must include user_ecosystem" },
      "rationale": "An entity is only a valid recommendation for a chosen ecosystem if that ecosystem appears in its supported list. Whether the path is direct, via vendor hub, or via Matter is captured per-entity in `ecosystems_via_*` attributes.",
      "source_id": 3
    }
  ],
  "goals": [
    {
      "id": "G1_max_native_compat",
      "prompt": "Prefer entities that work natively in the chosen ecosystem with the fewest hops.",
      "objective": "maximize",
      "target": "ecosystems.includes(user_ecosystem) && requires_hub == 'none'"
    },
    {
      "id": "G2_min_hub_count",
      "prompt": "Across all selected entities, minimize the number of distinct hubs the user has to own.",
      "objective": "minimize",
      "target": "distinct(entity.attributes.requires_hub) excluding 'none'"
    },
    {
      "id": "G3_prefer_matter",
      "prompt": "When two entities are equally compatible, prefer Matter-certified ones — they survive ecosystem switches without re-buying.",
      "objective": "maximize",
      "target": "entity.attributes.protocol == 'thread_matter' || entity.attributes.ecosystems_via_matter_firmware"
    }
  ]
}
