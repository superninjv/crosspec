  "constraints": [
    {
      "id": "hdd_must_be_cmr_for_zfs",
      "description": "hdd.recording_tech must be CMR for ZFS or RAID arrays. SMR drives stall during resilvering and are unsupported on TrueNAS / Unraid parity arrays.",
      "applies_to": ["hdd"],
      "rule": "hdd.recording_tech == 'CMR'"
    },
    {
      "id": "bays_fit_drives",
      "description": "Selected NAS unit's drive_bays must be greater than or equal to the count of selected hdds.",
      "applies_to": ["nas_unit", "hdd"],
      "rule": "nas_unit.drive_bays >= count(selected_hdds)"
    },
    {
      "id": "ecc_match",
      "description": "If the NAS unit does not support ECC, the selected RAM type must be non-ECC. If it requires ECC (e.g. Synology Plus units, Asustor Lockerstor Gen3), only ECC RAM is allowed.",
      "applies_to": ["nas_unit", "ram"],
      "rule": "nas_unit.ecc_ram_supported == ram.type.contains('ECC')"
    },
    {
      "id": "ddr_generation_match",
      "description": "RAM type DDR generation must match the NAS unit / DIY platform CPU memory controller. DDR4 platforms reject DDR5 modules and vice versa.",
      "applies_to": ["nas_unit", "diy_nas_platform", "ram"],
      "rule": "ram.type.ddr_generation == platform.cpu_memory_controller.ddr_generation"
    },
    {
      "id": "hba_it_mode_for_zfs",
      "description": "Any HBA used to pass disks to ZFS / TrueNAS must be flashed to IT mode. Hardware-RAID-only cards (e.g. Adaptec ASR-71605) are rejected for ZFS builds.",
      "applies_to": ["hba_card"],
      "rule": "hba_card.flashed_to_it_mode == true when filesystem == 'zfs'"
    },
    {
      "id": "raidz_minimum_drive_count",
      "description": "ZFS RAIDZ1 requires 3 or more hdds. RAIDZ2 requires 4 or more. Striped mirrors require an even count >= 2.",
      "applies_to": ["hdd"],
      "rule": "raidz1: count(hdd) >= 3 ; raidz2: count(hdd) >= 4 ; mirror: count(hdd) % 2 == 0 and count(hdd) >= 2"
    },
    {
      "id": "ups_watts_margin",
      "description": "Selected UPS watts must be at least 1.4x the NAS unit's expected continuous draw under load, sized for ~10 minute runtime safety margin.",
      "applies_to": ["nas_unit", "ups"],
      "rule": "ups.watts >= nas_unit.expected_load_watts * 1.4"
    }
  ]
}
