  "constraints": [
    {
      "id": "cpu_socket_matches_motherboard",
      "description": "CPU socket must match motherboard socket exactly.",
      "rule": "cpu.attributes.socket == motherboard.attributes.socket",
      "error_message": "CPU socket {cpu.socket} is incompatible with motherboard socket {motherboard.socket}."
    },
    {
      "id": "ram_speed_within_cpu_max",
      "description": "RAM speed (MT/s) must not exceed CPU's maximum supported memory speed.",
      "rule": "ram.attributes.speed_mt_s <= cpu.attributes.max_memory_mt_s",
      "error_message": "RAM speed {ram.speed_mt_s} MT/s exceeds CPU max of {cpu.max_memory_mt_s} MT/s; XMP profile will be capped or may not post."
    },
    {
      "id": "ram_speed_within_motherboard_max",
      "description": "RAM speed (MT/s) must not exceed motherboard's maximum supported memory speed.",
      "rule": "ram.attributes.speed_mt_s <= motherboard.attributes.max_memory_speed_mt_s",
      "error_message": "RAM speed {ram.speed_mt_s} MT/s exceeds motherboard max of {motherboard.max_memory_speed_mt_s} MT/s."
    },
    {
      "id": "motherboard_fits_case",
      "description": "Motherboard form factor must be in the list of form factors supported by the case.",
      "rule": "motherboard.attributes.form_factor in case.attributes.form_factors_supported",
      "error_message": "Motherboard form factor {motherboard.form_factor} is not supported by case {case.name} (supports: {case.form_factors_supported})."
    },
    {
      "id": "gpu_length_fits_case",
      "description": "GPU length must not exceed case's maximum GPU clearance.",
      "rule": "gpu.attributes.length_mm <= case.attributes.max_gpu_length_mm",
      "error_message": "GPU length {gpu.length_mm}mm exceeds case max GPU clearance of {case.max_gpu_length_mm}mm."
    },
    {
      "id": "cpu_cooler_height_fits_case",
      "description": "Air cooler height must not exceed case's maximum CPU cooler height clearance. Constraint skipped for AIO coolers.",
      "rule": "cooler.attributes.kind == 'aio' OR cooler.attributes.height_mm <= case.attributes.max_cpu_cooler_height_mm",
      "error_message": "Air cooler height {cooler.height_mm}mm exceeds case max CPU cooler height of {case.max_cpu_cooler_height_mm}mm."
    },
    {
      "id": "cooler_supports_cpu_socket",
      "description": "CPU cooler must explicitly list the CPU's socket in its supported sockets.",
      "rule": "cpu.attributes.socket in cooler.attributes.sockets_supported",
      "error_message": "Cooler {cooler.name} does not list support for socket {cpu.socket}."
    },
    {
      "id": "psu_wattage_covers_system",
      "description": "PSU wattage must be >= GPU recommended PSU wattage and >= cpu_tdp + gpu_tdp + 100W headroom.",
      "rule": "psu.attributes.wattage_w >= gpu.attributes.recommended_psu_w AND psu.attributes.wattage_w >= (cpu.attributes.tdp_w + gpu.attributes.tdp_w + 100)",
      "error_message": "PSU {psu.wattage_w}W is insufficient. GPU recommends {gpu.recommended_psu_w}W; system draw estimate is {cpu.tdp_w + gpu.tdp_w + 100}W."
    },
    {
      "id": "psu_has_12v2x6_if_gpu_requires",
      "description": "If GPU requires a 12V-2x6 (16-pin) connector, PSU must have at least one native 12V-2x6 connector.",
      "rule": "gpu.attributes.power_connectors != '1x_16pin_12v2x6' OR psu.attributes.connectors_12v2x6 >= 1",
      "error_message": "GPU requires a 12V-2x6 (16-pin) connector but PSU {psu.name} has none natively. An adapter can be used but is not recommended for high-TDP cards."
    },
    {
      "id": "m2_slots_cover_storage_drives",
      "description": "Motherboard must have at least as many M.2 slots as the number of M.2 NVMe drives selected.",
      "rule": "motherboard.attributes.m2_slots >= count(storage where storage.attributes.form_factor == 'M.2 2280')",
      "error_message": "Motherboard has only {motherboard.m2_slots} M.2 slot(s) but {storage_count} M.2 NVMe drive(s) selected."
    }
